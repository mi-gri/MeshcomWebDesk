<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0f3460" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="MeshCom" />
    <title>MeshCom WebDesk</title>
    <link rel="manifest" href="manifest.webmanifest" />
    <link rel="apple-touch-icon" href="icons/icon.svg" />
    <link rel="stylesheet" href="lib/leaflet/leaflet.css" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["MeshcomWebDesk.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <div id="blazor-error-ui" data-nosnippet>
        Ein Fehler ist aufgetreten. &nbsp;<a href="." class="reload">Neu laden</a><span class="dismiss">🗙</span>
    </div>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="lib/leaflet/leaflet.js"></script>
    <script src="map.js"></script>
    <script src="chat.js"></script>
    <script>
        window.scrollToBottom = function (id) {
            var el = document.getElementById(id);
            if (el) el.scrollTop = el.scrollHeight;
        };

        // ── Notification sound via Web Audio API (no audio file required) ──────
        (function () {
            var _audioCtx = null;
            var _audioUnlocked = false;

            function getAudioContext() {
                if (!_audioCtx) {
                    _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                }
                return _audioCtx;
            }

            // iOS requires AudioContext.resume() to be called synchronously inside
            // a user-gesture handler (touchstart fires before click on iOS).
            // We also create the context here so it is ready when the first beep arrives.
            function unlockAudio() {
                if (_audioUnlocked) return;
                try {
                    var ctx = getAudioContext();
                    if (ctx.state === 'suspended') {
                        ctx.resume().then(function () { _audioUnlocked = true; });
                    } else {
                        _audioUnlocked = true;
                    }
                } catch (e) { /* ignore */ }
            }

            document.addEventListener('touchstart', unlockAudio, { passive: true, once: true });
            document.addEventListener('click',      unlockAudio, { passive: true, once: true });

            function playBeep(ctx) {
                var now = ctx.currentTime;
                // Two-tone beep: 880 Hz then 660 Hz
                [0, 0.18].forEach(function (offset, i) {
                    var osc  = ctx.createOscillator();
                    var gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.value = i === 0 ? 880 : 660;
                    gain.gain.setValueAtTime(0.0, now + offset);
                    gain.gain.linearRampToValueAtTime(0.25, now + offset + 0.02);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + offset + 0.15);
                    osc.start(now + offset);
                    osc.stop(now + offset + 0.15);
                });
            }

            window.playNotificationBeep = function () {
                try {
                    var ctx = getAudioContext();
                    if (ctx.state === 'suspended') {
                        ctx.resume().then(function () { playBeep(ctx); });
                    } else {
                        playBeep(ctx);
                    }
                } catch (e) {
                    console.warn('Audio notification failed:', e);
                }
            };

            // Three-tone ascending beep (660 → 880 → 1100 Hz) for watchlist alerts
            window.playWatchlistBeep = function () {
                try {
                    var ctx = getAudioContext();
                    function doPlay() {
                        var now = ctx.currentTime;
                        [0, 0.15, 0.30].forEach(function (offset, i) {
                            var osc  = ctx.createOscillator();
                            var gain = ctx.createGain();
                            osc.connect(gain);
                            gain.connect(ctx.destination);
                            osc.type = 'sine';
                            osc.frequency.value = [660, 880, 1100][i];
                            gain.gain.setValueAtTime(0.0, now + offset);
                            gain.gain.linearRampToValueAtTime(0.3, now + offset + 0.02);
                            gain.gain.exponentialRampToValueAtTime(0.001, now + offset + 0.12);
                            osc.start(now + offset);
                            osc.stop(now + offset + 0.12);
                        });
                    }
                    if (ctx.state === 'suspended') {
                        ctx.resume().then(doPlay);
                    } else {
                        doPlay();
                    }
                } catch (e) {
                    console.warn('Watchlist audio notification failed:', e);
                }
            };
        })();

        // ── Text-to-Speech via Web Speech API ────────────────────────────────
        // iOS/iPadOS: TTS from background callbacks is blocked by Apple – skipped on iOS.
        // Desktop: cancel() + speak() as usual.
        window.speakText = function (text, lang) {
            // iOS/iPadOS: speechSynthesis from background callbacks is blocked by Apple.
            // Beep sounds (AudioContext) are used instead – skip TTS entirely on iOS.
            var isIos = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
            if (isIos) return;

            try {
                if (!window.speechSynthesis) return;
                var localeMap = { 'de': 'de-DE', 'en': 'en-US', 'it': 'it-IT', 'es': 'es-ES' };
                var locale = localeMap[lang] || 'de-DE';

                function doSpeak() {
                    var utter = new SpeechSynthesisUtterance(text);
                    utter.lang   = locale;
                    utter.rate   = 0.95;
                    utter.pitch  = 1.0;
                    utter.volume = 1.0;
                    window.speechSynthesis.speak(utter);
                }

                window.speechSynthesis.cancel();
                doSpeak();
            } catch (e) {
                console.warn('speakText failed:', e);
            }
        };

        // Register service worker for PWA install prompt
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js');
        }
    </script>
</body>

</html>
