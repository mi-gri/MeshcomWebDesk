@inherits LayoutComponentBase
@inject MeshcomWebDesk.Services.LanguageService Loc
@inject Microsoft.Extensions.Options.IOptionsMonitor<MeshcomWebDesk.Models.MeshcomSettings> SettingsMon
@inject MeshcomWebDesk.Services.AppLicenseService LicenseService
@implements IDisposable

<div class="app-layout">
    <header class="app-header">
        <div class="app-header-brand">
            <span>📡</span>
            <span class="app-title">MeshCom WebDesk <span class="app-version">v@_version</span>
                @if (LicenseService.IsLicensed)
                {
                    <span class="app-license-badge app-license-badge--licensed">✅ <span class="app-license-text">@Loc.T("Lizenziert für", "Licensed for") @LicenseService.LicensedCallsign</span></span>
                }
                else
                {
                    <a class="app-license-badge app-license-badge--unlicensed" href="/about" title="@Loc.T("Lizenz erhalten: PayPal-Spende → Rufzeichen-Lizenzschlüssel", "Get a license: PayPal donation → callsign license key")">💛 @Loc.T("Kostenlos – Per PayPal lizenzieren?", "Free – License via PayPal?")</a>
                }
            </span>
        </div>
        <nav class="app-nav">
            <NavLink class="app-nav-link" href="/" Match="NavLinkMatch.All">💬 <span class="nav-label">@Loc.T("Chat", "Chat")</span></NavLink>
            <NavLink class="app-nav-link" href="/mh">📻 <span class="nav-label">MH</span></NavLink>
            <NavLink class="app-nav-link" href="/map">🗺️ <span class="nav-label">@Loc.T("Karte", "Map")</span></NavLink>
            @if (SettingsMon.CurrentValue.TelnetEnabled)
            {
                <NavLink class="app-nav-link" href="/telnet">🖥️ <span class="nav-label">TLS Console</span></NavLink>
            }
            <NavLink class="app-nav-link" href="/settings">⚙️ <span class="nav-label">@Loc.T("Einstellungen", "Settings")</span></NavLink>
            <NavLink class="app-nav-link" href="/clear">🗑️ <span class="nav-label">@Loc.T("Löschen", "Clear")</span></NavLink>
            <NavLink class="app-nav-link" href="/about">ℹ️ <span class="nav-label">@Loc.T("Über", "About")</span></NavLink>
            <a class="app-nav-link" href="@($"https://github.com/DH1FR/MeshcomWebDesk/blob/master/docs/node-connection-{Loc.Current}.md")" target="_blank" rel="noopener">
                ❓ <span class="nav-label">@Loc.T("Hilfe", "Help")</span>
            </a>
        </nav>
    </header>

    <UpdateBanner />

    <div class="app-body">
        @Body
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string _version =
        System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString(3) ?? string.Empty;

    private void OnLocChange() => _ = InvokeAsync(StateHasChanged);
    private void OnLicenseChange() => _ = InvokeAsync(StateHasChanged);

    protected override void OnInitialized()
    {
        Loc.OnChange     += OnLocChange;
        LicenseService.OnLicenseChanged += OnLicenseChange;
        SettingsMon.OnChange((settings, name) => InvokeAsync(StateHasChanged));
    }

    public void Dispose()
    {
        Loc.OnChange -= OnLocChange;
        LicenseService.OnLicenseChanged -= OnLicenseChange;
    }
}
