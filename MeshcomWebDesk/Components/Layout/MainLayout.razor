@inherits LayoutComponentBase
@inject MeshcomWebDesk.Services.LanguageService Loc
@implements IDisposable

<div class="app-layout">
    <header class="app-header">
        <div class="app-header-brand">
            <span>📡</span>
            <span class="app-title">MeshCom WebDesk <span class="app-version">v@_version</span></span>
        </div>
        <nav class="app-nav">
            <NavLink class="app-nav-link" href="/" Match="NavLinkMatch.All">💬 <span class="nav-label">@Loc.T("Chat", "Chat")</span></NavLink>
            <NavLink class="app-nav-link" href="/mh">📻 <span class="nav-label">MH</span></NavLink>
            <NavLink class="app-nav-link" href="/map">🗺️ <span class="nav-label">@Loc.T("Karte", "Map", "Mappa", "Mapa")</span></NavLink>
            <NavLink class="app-nav-link" href="/settings">⚙️ <span class="nav-label">@Loc.T("Einstellungen", "Settings", "Impostazioni", "Configuración")</span></NavLink>
            <NavLink class="app-nav-link" href="/clear">🗑️ <span class="nav-label">@Loc.T("Löschen", "Clear", "Elimina", "Borrar")</span></NavLink>
            <NavLink class="app-nav-link" href="/about">ℹ️ <span class="nav-label">@Loc.T("Über", "About", "Info", "Acerca de")</span></NavLink>
            <a class="app-nav-link" href="@($"https://github.com/DH1FR/MeshcomWebDesk/blob/master/docs/node-connection-{Loc.Current}.md")" target="_blank" rel="noopener">
                ❓ <span class="nav-label">@Loc.T("Hilfe", "Help", "Aiuto", "Ayuda")</span>
            </a>
        </nav>
    </header>

    <UpdateBanner />

    <div class="app-body">
        @Body
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string _version =
        System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString(3) ?? string.Empty;

    protected override void OnInitialized() => Loc.OnChange += StateHasChanged;

    public void Dispose() => Loc.OnChange -= StateHasChanged;
}
