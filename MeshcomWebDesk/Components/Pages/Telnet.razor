@page "/telnet"
@using MeshcomWebDesk.Models
@using MeshcomWebDesk.Services
@using Microsoft.Extensions.Options
@rendermode InteractiveServer
@inject TelnetService TelnetService
@inject SerialConsoleService SerialConsoleService
@inject IOptionsMonitor<MeshcomSettings> SettingsMon
@inject LanguageService Loc
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>🖥️ Console – MeshCom WebDesk</PageTitle>

<ErrorBoundary>
<ChildContent>
<div class="telnet-page">

    @* ── Header ── *@
    <div class="telnet-header">
        <span class="telnet-title">
            @if (_isSerial)
            {
                <span>🔌 @Loc.T("Seriell Console", "Serial Console", "Console seriale", "Consola serie")</span>
            }
            else
            {
                <span>🖥️ TLS Console</span>
            }
            &nbsp;·&nbsp;
            <span class="status-badge @(Console.IsConnected ? "status-badge-ok" : "status-badge-err")">
                @if (Console.IsConnected)
                {
                    @if (_isSerial)
                    { @($"● {Loc.T("Verbunden", "Connected", "Connesso", "Conectado")} {_settings.SerialPortName}") }
                    else
                    { @($"● {Loc.T("Verbunden", "Connected", "Connesso", "Conectado")} {_settings.DeviceIp}:{_settings.TelnetPort}") }
                }
                else
                {
                    @($"○ {Loc.T("Getrennt", "Disconnected", "Disconnesso", "Desconectado")}")
                }
            </span>
            &nbsp;<a href="https://github.com/icssw-org/MeshCom-Firmware" target="_blank" rel="noopener"
                     title="MeshCom Firmware – GitHub" style="font-size:.8rem;opacity:.6;text-decoration:none">📦 Firmware</a>
        </span>
        <div style="display:flex;gap:.4rem">
            @if (Console.IsConnected)
            {
                <button class="btn-action btn-sm" title="@Loc.T("OTA-Update starten – sendet --ota-update an den Node und öffnet den OTA-Webserver", "Start OTA update – sends --ota-update to node and opens OTA web server", "Avvia aggiornamento OTA", "Iniciar actualización OTA")"
                        @onclick="StartOtaAsync">
                    🔄 OTA
                </button>
                <button class="btn-warn btn-sm" title="@Loc.T("Node neu starten – sendet --reboot an den Node", "Reboot node – sends --reboot to node", "Riavvia il nodo", "Reiniciar nodo")"
                        @onclick="() => _rebootConfirm = true">
                    🔁 @Loc.T("Reboot", "Reboot", "Riavvio", "Reiniciar")
                </button>
                <button class="btn-danger btn-sm" @onclick="DisconnectAsync">
                    @Loc.T("Trennen", "Disconnect", "Disconnetti", "Desconectar")
                </button>
            }
            <button class="btn-sm @(_paused ? "btn-primary" : "btn-action")" @onclick="TogglePause"
                    title="@(_paused ? Loc.T("Ausgabe fortsetzen (Scroll wieder aktiv)", "Resume output (scroll re-enabled)", "Riprendi output", "Reanudar salida") : Loc.T("Ausgabe pausieren (neue Zeilen kommen weiter rein)", "Pause output (new lines still buffered)", "Pausa output", "Pausar salida"))">
                @(_paused ? "▶ " + Loc.T("Weiter", "Resume", "Riprendi", "Reanudar") : "⏸ " + Loc.T("Pause", "Pause", "Pausa", "Pausa"))
            </button>
            <button class="btn-sm @(_loraHighlight ? "btn-primary" : "btn-action")" @onclick="() => _loraHighlight = !_loraHighlight"
                    title="@Loc.T("LoRa-Debug-Hervorhebung ein/aus", "LoRa debug highlighting on/off", "Evidenziazione LoRa debug on/off", "Resaltado LoRa debug on/off")">
                📻 @Loc.T("LoRa", "LoRa", "LoRa", "LoRa")
            </button>
            <button class="btn-action btn-sm" @onclick="ClearLines">
                @Loc.T("Löschen", "Clear", "Cancella", "Borrar")
            </button>
        </div>
    </div>

    @* ── Reboot-Bestätigung ── *@
    @if (_rebootConfirm)
    {
        <div class="ota-overlay">
            <div class="ota-dialog">
                <div class="ota-icon">🔁</div>
                <div class="ota-title">@Loc.T("Node neu starten?", "Reboot node?", "Riavviare il nodo?", "¿Reiniciar el nodo?")</div>
                <div class="ota-msg">@Loc.T("Der Node wird neu gestartet. Die TLS-Verbindung wird danach getrennt.", "The node will be rebooted. The TLS connection will be disconnected afterwards.", "Il nodo verrà riavviato. La connessione TLS verrà disconnessa.", "El nodo se reiniciará. La conexión TLS se desconectará.")</div>
                <div style="display:flex;gap:.6rem;justify-content:center;margin-top:.8rem">
                    <button class="btn-danger btn-sm" @onclick="RebootConfirmedAsync">🔁 @Loc.T("Ja, neu starten", "Yes, reboot", "Sì, riavvia", "Sí, reiniciar")</button>
                    <button class="btn-action btn-sm" @onclick="() => _rebootConfirm = false">@Loc.T("Abbrechen", "Cancel", "Annulla", "Cancelar")</button>
                </div>
            </div>
        </div>
    }

    @* ── OTA-Dialog ── *@
    @if (_otaCountdown >= 0)
    {
        <div class="ota-overlay">
            <div class="ota-dialog">
                <div class="ota-icon">🔄</div>
                <div class="ota-title">@Loc.T("OTA-Update wird gestartet", "Starting OTA Update", "Avvio aggiornamento OTA", "Iniciando actualización OTA")</div>
                <div class="ota-msg">@Loc.T("Der Node startet den OTA-Webserver. Die Seite öffnet sich in", "The node is starting the OTA web server. Page opens in", "Il nodo sta avviando il server OTA. La pagina si apre tra", "El nodo está iniciando el servidor OTA. La página se abrirá en")
                    <strong>&nbsp;@_otaCountdown @Loc.T("Sekunden", "seconds", "secondi", "segundos")</strong> …
                </div>
                <div class="ota-progress">
                    <div class="ota-progress-bar" style="width:@((5 - _otaCountdown) * 20)%"></div>
                </div>
            </div>
        </div>
    }

    @* ── Output ── *@
    <div class="telnet-output" id="telnet-output">
        @lock (Console.Lines)
        {
            @foreach (var line in Console.Lines)
            {
                @if (_loraHighlight)
                {
                    var cl = ClassifyLine(line);
                    <div class="telnet-line @cl.Css" title="@cl.Hint">@((MarkupString)cl.Html)</div>
                }
                else
                {
                    <div class="telnet-line">@line</div>
                }
            }
        }
    </div>

    @* ── Input ── *@
    <div class="telnet-input-bar">
        <span class="telnet-prompt">&gt;</span>
        <input class="telnet-input"
               @bind="_inputText"
               @bind:event="oninput"
               @onkeydown="OnKeyDown"
               placeholder="@(Console.IsConnected ? Loc.T("Befehl eingeben …", "Enter command …", "Inserisci comando …", "Introduce comando …") : Loc.T("Nicht verbunden", "Not connected", "Non connesso", "No conectado"))"
               autocomplete="off"
               spellcheck="false"
               disabled="@(!Console.IsConnected)"
               id="telnet-input" />
        @if (Console.IsConnected)
        {
            <button class="btn-action btn-sm" @onclick="SendInputAsync">
                @Loc.T("Senden", "Send", "Invia", "Enviar")
            </button>
        }
        else
        {
            <button class="btn-action btn-sm" @onclick="ConnectAsync">
                @Loc.T("Verbinden", "Connect", "Connetti", "Conectar")
            </button>
        }
    </div>

</div>
</ChildContent>
<ErrorContent Context="ex">
    <div class="alert alert-danger">Console Fehler: @ex.Message</div>
</ErrorContent>
</ErrorBoundary>

@code {
    private MeshcomSettings _settings = new();
    private string _inputText = string.Empty;
    private bool _paused = false;
    private bool _loraHighlight = false;

    // Active console service (TLS or Serial)
    private IConsoleService Console => _isSerial ? SerialConsoleService : TelnetService;
    private bool _isSerial => SettingsMon.CurrentValue.ConsoleMode == "serial";

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _settings = SettingsMon.CurrentValue;
        TelnetService.OnChange += HandleChange;
        SerialConsoleService.OnChange += HandleChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await ScrollToBottomAsync();
    }

    public void Dispose()
    {
        TelnetService.OnChange -= HandleChange;
        SerialConsoleService.OnChange -= HandleChange;
    }

    // ── Input handling ────────────────────────────────────────────────────

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendInputAsync();
    }

    private async Task SendInputAsync()
    {
        var text = _inputText.Trim();
        if (string.IsNullOrEmpty(text)) return;

        _inputText = string.Empty;
        await Console.SendLineAsync(text);
        await ScrollToBottomAsync();
    }

    private void ClearLines()
    {
        lock (Console.Lines)
            Console.Lines.Clear();
        StateHasChanged();
    }

    private async Task ConnectAsync()
    {
        await Console.ConnectAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task DisconnectAsync()
    {
        await Console.DisconnectAsync();
        await InvokeAsync(StateHasChanged);
    }

    private int _otaCountdown = -1;  // -1 = dialog hidden
    private bool _rebootConfirm = false;

    private async Task RebootConfirmedAsync()
    {
        _rebootConfirm = false;
        await InvokeAsync(StateHasChanged);
        await Console.SendLineAsync("--reboot");
        await Task.Delay(1500);
        await Console.DisconnectAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task StartOtaAsync()
    {
        await Console.SendLineAsync("--ota-update");
        var url = $"http://{SettingsMon.CurrentValue.DeviceIp}/";

        for (var i = 5; i >= 0; i--)
        {
            _otaCountdown = i;
            await InvokeAsync(StateHasChanged);
            if (i > 0) await Task.Delay(1000);
        }

        await JS.InvokeVoidAsync("open", url, "_blank");
        _otaCountdown = -1;
        await InvokeAsync(StateHasChanged);
        await Console.DisconnectAsync();
        await InvokeAsync(StateHasChanged);
    }

    // ── Events ────────────────────────────────────────────────────────────

    private void HandleChange()
    {
        if (_paused) return;
        InvokeAsync(async () => { StateHasChanged(); await ScrollToBottomAsync(); });
    }

    private void TogglePause()
    {
        _paused = !_paused;
        if (!_paused)
            InvokeAsync(async () => { StateHasChanged(); await ScrollToBottomAsync(); });
    }

    private async Task ScrollToBottomAsync()
    {
        try { await JS.InvokeVoidAsync("scrollElementToBottom", "telnet-output"); }
        catch { /* JS not ready */ }
    }

    private record LineInfo(string Css, string Html, string Hint);

    private static LineInfo ClassifyLine(string raw)
    {
        if (string.IsNullOrEmpty(raw))
            return new("", "", "");

        var esc = System.Net.WebUtility.HtmlEncode(raw);

        // ── State Machine ───────────────────────────────────────────────
        if (raw.StartsWith("[MC-SM]"))
        {
            var hint = raw.Contains("rc=0") ? "OK" : raw.Contains("rc=") ? "⚠ Fehler" : "";
            var hasErr = raw.Contains("rc=") && !raw.Contains("rc=0");
            return new(hasErr ? "lora-sm lora-err" : "lora-sm", Highlight(esc, "lora-sm-kw", "->", "rc="), hint);
        }

        // ── Warnings ────────────────────────────────────────────────────
        if (raw.StartsWith("[MC-WARN]") || raw.Contains("RX_BUF_OVERWRITE") || raw.Contains("ONRXDONE_SLOW"))
            return new("lora-warn", Highlight(esc, "lora-warn-kw", "WARN", "SLOW", "OVERWRITE"), "⚠ Warnung");

        // ── HWM ─────────────────────────────────────────────────────────
        if (raw.StartsWith("[MC-HWM]"))
            return new("lora-hwm", esc, "High-Water-Mark Statistik");

        // ── Channel Util ─────────────────────────────────────────────────
        if (raw.Contains("CHANNEL_UTIL"))
            return new("lora-util", HighlightKv(esc), "Kanalauslastung");

        // ── Debug: RX ───────────────────────────────────────────────────
        if (raw.StartsWith("[MC-DBG]") && (raw.Contains("RX_") || raw.Contains("OnRx") || raw.Contains("CAD")))
            return new("lora-dbg-rx", HighlightKv(esc), "RX / CAD Debug");

        // ── Debug: TX / CSMA ────────────────────────────────────────────
        if (raw.StartsWith("[MC-DBG]") && (raw.Contains("TX_") || raw.Contains("CSMA") || raw.Contains("CAD_FREE") || raw.Contains("RADIO_TX") || raw.Contains("RING_TX") || raw.Contains("RETRANSMIT")))
            return new("lora-dbg-tx", HighlightKv(esc), "TX / CSMA Debug");

        // ── Debug: ACK ──────────────────────────────────────────────────
        if (raw.StartsWith("[MC-DBG]") && raw.Contains("ACK"))
            return new("lora-dbg-ack", HighlightKv(esc), "ACK Debug");

        // ── Debug: RING ─────────────────────────────────────────────────
        if (raw.StartsWith("[MC-DBG]") && raw.Contains("RING"))
            return new("lora-dbg-ring", HighlightKv(esc), "Ring-Buffer");

        // ── Debug: RELAY ────────────────────────────────────────────────
        if (raw.StartsWith("[MC-DBG]") && raw.Contains("RELAY"))
            return new("lora-dbg-relay", HighlightKv(esc), "Relay");

        // ── Generic MC-DBG ──────────────────────────────────────────────
        if (raw.StartsWith("[MC-DBG]"))
            return new("lora-dbg", HighlightKv(esc), "Debug");

        // ── Received packet ─────────────────────────────────────────────
        if (raw.StartsWith("[LoRa]") && raw.Contains("Received"))
            return new("lora-rx-pkt", HighlightKv(esc), "Empfangenes Paket");

        // ── TX/RX LoRa lines ────────────────────────────────────────────
        if (raw.StartsWith("TX-LoRa"))
            return new("lora-tx", esc, "Gesendetes Paket");
        if (raw.StartsWith("RX-LoRa") || raw.StartsWith("MH-LoRa"))
            return new("lora-rx", esc, "Empfangenes Paket");

        // ── OnRxDone / OnRxTimeout / OnRxError ──────────────────────────
        if (raw.StartsWith("OnRxDone"))  return new("lora-dbg-rx", esc, "OnRxDone");
        if (raw.StartsWith("OnRxTimeout")) return new("lora-dim",  esc, "OnRxTimeout");
        if (raw.StartsWith("OnRxError"))   return new("lora-warn", esc, "OnRxError – CRC/Header-Fehler");

        // ── APRS errors ─────────────────────────────────────────────────
        if (raw.StartsWith("APRS decode"))
            return new("lora-aprs-err", esc, "APRS Protokollfehler");

        // ── CHECK (CAD scan) ────────────────────────────────────────────
        if (raw.StartsWith("[CHECK]"))
            return new("lora-dbg-tx", esc, "CAD Scan");

        // ── Dedup ───────────────────────────────────────────────────────
        if (raw.Contains("RX_DEDUP"))
            return new(raw.Contains("DUP") ? "lora-dim" : "lora-dbg-rx", HighlightKv(esc),
                       raw.Contains("DUP") ? "Duplikat verworfen" : "Neues Paket");

        return new("", esc, "");
    }

    // Bold key=value pairs like rssi=-110, wait=4675, util=15%
    private static string HighlightKv(string html) =>
        System.Text.RegularExpressions.Regex.Replace(
            html,
            @"(\b\w+=)(-?\d+\w*%?)",
            "<span class=\"lora-kv-key\">$1</span><span class=\"lora-kv-val\">$2</span>");

    // Bold specific keywords within the line
    private static string Highlight(string html, string css, params string[] keywords)
    {
        foreach (var kw in keywords)
            html = html.Replace(kw, $"<span class=\"{css}\">{kw}</span>");
        return html;
    }
}
