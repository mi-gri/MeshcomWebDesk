@using Microsoft.Extensions.Options
@using MeshcomWebDesk.Models
@using MeshcomWebDesk.Services
@inject IOptionsMonitor<MeshcomSettings> SettingsMonitor
@inject MeshcomUdpService UdpService
@inject SettingsService SettingsSvc
@inject ChatService ChatService

<div class="send-bar-wrap">
    @if (_flyoutOpen && _quickTexts.Count > 0)
    {
        <div class="quicktext-flyout" id="qt-flyout">
            @for (var i = 0; i < _quickTexts.Count; i++)
            {
                var idx = i;
                var qt = _quickTexts[i];
                <button class="quicktext-btn" draggable="true" data-qt-idx="@idx"
                        @onclick="() => LoadQuickText(qt.Text)" title="@qt.Text">
                    @qt.Label
                </button>
            }
            <button class="quicktext-close" @onclick="() => _flyoutOpen = false" title="@Loc.T("Schließen", "Close")">✕</button>
        </div>
    }
    <div class="send-bar">
        @if (_quickTexts.Count > 0)
        {
            <button class="btn-quicktext @(_flyoutOpen ? "btn-quicktext-active" : "")"
                    @onclick="ToggleFlyout"
                    title="@Loc.T("Schnelltexte", "Quick Texts")">⚡</button>
        }
        <textarea id="send-bar-input"
                  placeholder="@Loc.T("Nachricht eingeben...", "Enter message...")"
                  maxlength="149"
                  spellcheck="true"
                  autocomplete="on"
                  lang="de"
                  rows="1"></textarea>
        <span class="char-counter">0/149</span>
        <button class="btn-send @(ChatService.TxCooldownRemaining > 0 ? "btn-send-cooldown" : "")"
                disabled="@(ChatService.TxCooldownRemaining > 0 ? "disabled" : null)"
                @onclick="SendAsync">
            @if (ChatService.TxCooldownRemaining > 0)
            {
                <span>⏳ @ChatService.TxCooldownRemaining s</span>
            }
            else
            {
                @Loc.T("Senden", "Send")
            }
        </button>
    </div>
</div>

@implements IDisposable
@inject IJSRuntime JS

@code {
    [Parameter, EditorRequired] public EventCallback<string> OnSend { get; set; }
    /// <summary>Callsign of the current chat partner (or group). Used for {callsign}, {rssi}, … variable expansion.</summary>
    [Parameter] public string? Callsign { get; set; }

    [Inject] private LanguageService Loc { get; set; } = default!;

    private string _text = string.Empty;
    private bool   _flyoutOpen;
    private List<QuickTextEntry> _quickTexts = [];
    private const int MaxLength = 149;
    private DotNetObjectReference<SendBar>? _dotNetRef;
    private IDisposable? _settingsListener;
    private CancellationTokenSource? _cooldownCts;

    protected override void OnInitialized()
    {
        Loc.OnChange += OnLocChange;
        LoadQuickTextsFromSettings();
        _settingsListener = SettingsMonitor.OnChange(_ => { LoadQuickTextsFromSettings(); InvokeAsync(ForceRerender); });
    }

    private bool _rendered;

    protected override bool ShouldRender()
    {
        if (ChatService.TxCooldownRemaining > 0) { _rendered = false; return true; }
        if (!_rendered) { _rendered = true; return true; }
        return false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("meshcomChat.initSendBarCounter", "send-bar-input", _dotNetRef);
        }

        if (_flyoutOpen && _quickTexts.Count > 0)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("meshcomChat.initQuickTextDrag", _dotNetRef);
        }
    }

    private void OnLocChange() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        // Do NOT cancel _cooldownCts here – the timer must finish its countdown
        // even if the component is disposed (e.g. on navigation away).
        Loc.OnChange -= OnLocChange;
        _settingsListener?.Dispose();
        _dotNetRef?.Dispose();
    }

    private void LoadQuickTextsFromSettings()
    {
        _quickTexts = SettingsMonitor.CurrentValue.QuickTexts
            .Where(q => !string.IsNullOrWhiteSpace(q.Label) && !string.IsNullOrWhiteSpace(q.Text))
            .ToList();
    }

    [JSInvokable]
    public async Task MoveQuickText(int fromIdx, int toIdx)
    {
        if (fromIdx < 0 || fromIdx >= _quickTexts.Count || toIdx < 0 || toIdx >= _quickTexts.Count || fromIdx == toIdx)
            return;

        // Reorder the in-memory list
        var item = _quickTexts[fromIdx];
        _quickTexts.RemoveAt(fromIdx);
        _quickTexts.Insert(toIdx, item);

        // Persist: replace the valid entries in the settings list with the new order
        var fullList   = SettingsMonitor.CurrentValue.QuickTexts;
        var validIdxs  = fullList
            .Select((q, i) => new { q, i })
            .Where(x => !string.IsNullOrWhiteSpace(x.q.Label) && !string.IsNullOrWhiteSpace(x.q.Text))
            .Select(x => x.i)
            .ToList();

        if (fromIdx < validIdxs.Count && toIdx < validIdxs.Count)
        {
            // Build reordered list of valid entries
            var validEntries = validIdxs.Select(i => fullList[i]).ToList();
            var moved = validEntries[fromIdx];
            validEntries.RemoveAt(fromIdx);
            validEntries.Insert(toIdx, moved);

            // Write back into the full list at the same slot positions
            for (var i = 0; i < validIdxs.Count; i++)
                fullList[validIdxs[i]] = validEntries[i];
        }

        // Save to appsettings.override.json
        _ = SettingsSvc.SaveMeshcomSettingsAsync(SettingsMonitor.CurrentValue);

        _rendered = false;
        await InvokeAsync(StateHasChanged);
    }

    private void ForceRerender() { _rendered = false; StateHasChanged(); }

    private void ToggleFlyout() { _flyoutOpen = !_flyoutOpen; ForceRerender(); }

    private async Task LoadQuickText(string text)
    {
        var expanded = await UdpService.ExpandVariablesAsync(text, Callsign);
        _text       = expanded.Length > MaxLength ? expanded[..MaxLength] : expanded;
        _flyoutOpen = false;
        _rendered   = false;
        await JS.InvokeVoidAsync("meshcomChat.setSendBarValue", "send-bar-input", _text);
    }

    [JSInvokable]
    public async Task JsSendAsync()
    {
        if (ChatService.TxCooldownRemaining > 0) return;
        _text = await JS.InvokeAsync<string>("meshcomChat.getSendBarValue", "send-bar-input");
        if (string.IsNullOrWhiteSpace(_text) || _text.Length > MaxLength) return;
        var expanded = await UdpService.ExpandVariablesAsync(_text, Callsign);
        var text = expanded.Length > MaxLength ? expanded[..MaxLength] : expanded;
        _text = string.Empty;
        await JS.InvokeVoidAsync("meshcomChat.setSendBarValue", "send-bar-input", string.Empty);
        await OnSend.InvokeAsync(text);
        _ = StartCooldownTimerAsync();
    }

    private async Task StartCooldownTimerAsync()
    {
        _cooldownCts?.Cancel();
        _cooldownCts = new CancellationTokenSource();
        var token = _cooldownCts.Token;
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            while (!token.IsCancellationRequested && ChatService.TxCooldownRemaining > 0)
            {
                await timer.WaitForNextTickAsync(token);
                await InvokeAsync(StateHasChanged);
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    [JSInvokable]
    public async Task<string> JsExpandVariables(string text)
    {
        var expanded = await UdpService.ExpandVariablesAsync(text, Callsign);
        return expanded.Length > MaxLength ? expanded[..MaxLength] : expanded;
    }

    private async Task SendAsync()
    {
        await JsSendAsync();
    }

    /// <summary>Fügt @CALLSIGN an der aktuellen Cursorposition im Eingabefeld ein.</summary>
    public async Task InsertMentionAsync(string callsign)
    {
        var mention = "@" + callsign;
        await JS.InvokeVoidAsync("meshcomChat.insertAtCursor", "send-bar-input", mention);
    }
}
