    // ── Full Settings Backup / Restore (AES-256-CBC + PBKDF2) ─────────────

    private string _backupPassword  = string.Empty;
    private string _restorePassword = string.Empty;
    private string? _backupError;
    private bool    _backupSuccess;

    // Magic header to identify MeshComWebDesk backup files: ASCII "MCWD"
    private static readonly byte[] BackupMagic = [0x4D, 0x43, 0x57, 0x44];

    private async Task ExportSettingsAsync()
    {
        _backupError   = null;
        _backupSuccess = false;

        if (string.IsNullOrWhiteSpace(_backupPassword))
        {
            _backupError = Loc.T(
                "Bitte ein Passwort eingeben.",
                "Please enter a password.");
            return;
        }

        try
        {
            // Serialize current settings to JSON (all fields incl. sensitive ones)
            var settings  = _model.ToSettings();
            var json      = System.Text.Json.JsonSerializer.Serialize(
                settings, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            var plaintext = System.Text.Encoding.UTF8.GetBytes(json);
            var password  = _backupPassword;

            // Run CPU-intensive crypto on thread-pool so SignalR heartbeat is not blocked
            var file = await Task.Run(() =>
            {
                var salt = System.Security.Cryptography.RandomNumberGenerator.GetBytes(16);
                var key = System.Security.Cryptography.Rfc2898DeriveBytes.Pbkdf2(
                    password, salt, 100_000,
                    System.Security.Cryptography.HashAlgorithmName.SHA256, outputLength: 32);

                using var aes = System.Security.Cryptography.Aes.Create();
                aes.KeySize = 256;
                aes.Mode    = System.Security.Cryptography.CipherMode.CBC;
                aes.Key     = key;
                aes.GenerateIV();
                var iv = aes.IV;

                using var ms        = new System.IO.MemoryStream();
                using var encryptor = aes.CreateEncryptor();
                using var cs        = new System.Security.Cryptography.CryptoStream(
                    ms, encryptor, System.Security.Cryptography.CryptoStreamMode.Write);
                cs.Write(plaintext);
                cs.FlushFinalBlock();
                var ciphertext = ms.ToArray();

                var result = new byte[BackupMagic.Length + salt.Length + iv.Length + ciphertext.Length];
                var pos    = 0;
                BackupMagic.CopyTo(result, pos); pos += BackupMagic.Length;
                salt.CopyTo(result, pos);        pos += salt.Length;
                iv.CopyTo(result, pos);          pos += iv.Length;
                ciphertext.CopyTo(result, pos);
                return result;
            });

            var fn = string.IsNullOrWhiteSpace(_filenameBackup) ? "MeshComWebDesk-settings.enc" : _filenameBackup;
            await JS.InvokeVoidAsync("meshcomChat.downloadBinary", fn, file);

            _backupSuccess  = true;
            _backupPassword = string.Empty;
        }
        catch (Exception ex)
        {
            _backupError = $"Export: {ex.Message}";
        }
    }

    private async Task ImportSettingsAsync(InputFileChangeEventArgs e)
    {
        _backupError   = null;
        _backupSuccess = false;
        StateHasChanged();

        if (string.IsNullOrWhiteSpace(_restorePassword))
        {
            _backupError = Loc.T(
                "Bitte das Passwort der Backup-Datei eingeben.",
                "Please enter the backup file password.");
            StateHasChanged();
            return;
        }

        try
        {
            var browserFile = e.File;
            if (browserFile is null) return;

            // Read file directly via Blazor IBrowserFile – avoids JS-interop SignalR size limit
            using var stream = browserFile.OpenReadStream(maxAllowedSize: 1024 * 1024); // 1 MB max
            using var ms     = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var file = ms.ToArray();

            // Validate magic header
            if (file.Length < BackupMagic.Length + 16 + 16 + 1 ||
                !file.Take(BackupMagic.Length).SequenceEqual(BackupMagic))
            {
                _backupError = Loc.T(
                    "Ungültige Backup-Datei (kein MeshComWebDesk-Format).",
                    "Invalid backup file (not a MeshComWebDesk format).");
                StateHasChanged();
                return;
            }

            var pos  = BackupMagic.Length;
            var salt = file[pos..(pos + 16)]; pos += 16;
            var iv   = file[pos..(pos + 16)]; pos += 16;
            var ciphertext = file[pos..];
            var password   = _restorePassword;

            // Run CPU-intensive PBKDF2 + AES on thread-pool so SignalR heartbeat is not blocked
            byte[]? plaintext = null;
            string? cryptoError = null;
            await Task.Run(() =>
            {
                try
                {
                    var key = System.Security.Cryptography.Rfc2898DeriveBytes.Pbkdf2(
                        password, salt, 100_000,
                        System.Security.Cryptography.HashAlgorithmName.SHA256, outputLength: 32);

                    using var aes = System.Security.Cryptography.Aes.Create();
                    aes.KeySize = 256;
                    aes.Mode    = System.Security.Cryptography.CipherMode.CBC;
                    aes.Key     = key;
                    aes.IV      = iv;

                    using var ms        = new System.IO.MemoryStream();
                    using var decryptor = aes.CreateDecryptor();
                    using var cs        = new System.Security.Cryptography.CryptoStream(
                        ms, decryptor, System.Security.Cryptography.CryptoStreamMode.Write);
                    cs.Write(ciphertext);
                    cs.FlushFinalBlock();
                    plaintext = ms.ToArray();
                }
                catch (System.Security.Cryptography.CryptographicException)
                {
                    cryptoError = "crypto";
                }
            });

            if (cryptoError != null)
            {
                _backupError = Loc.T(
                    "Entschlüsselung fehlgeschlagen – falsches Passwort oder beschädigte Datei.",
                    "Decryption failed – wrong password or corrupted file.");
                StateHasChanged();
                return;
            }

            var json = System.Text.Encoding.UTF8.GetString(plaintext!);

            MeshcomSettings? imported;
            try
            {
                imported = System.Text.Json.JsonSerializer.Deserialize<MeshcomSettings>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            catch (System.Text.Json.JsonException ex)
            {
                _backupError = Loc.T(
                    $"Import fehlgeschlagen: JSON-Fehler – {ex.Message}",
                    $"Import failed: JSON error – {ex.Message}");
                StateHasChanged();
                return;
            }

            if (imported is null)
            {
                _backupError = Loc.T(
                    "Import fehlgeschlagen: Ungültiges Format.",
                    "Import failed: invalid format.");
                StateHasChanged();
                return;
            }

            // Null-safety: ensure nested objects and collections exist
            imported.QuickTexts       ??= [];
            imported.GroupLabels      ??= [];
            imported.BotCommands      ??= [];
            imported.TelemetryMapping ??= [];
            imported.WatchCallsigns   ??= [];
            imported.Groups           ??= [];
            imported.Database         ??= new();
            imported.Webhook          ??= new();
            imported.Mqtt             ??= new();
            imported.Qrz              ??= new();
            imported.Ai               ??= new();

            // Load imported settings into form model (same mapping as OnInitialized)
            var s = imported;
            _model = new FormModel
            {
                ListenIp            = s.ListenIp,
                ListenPort          = s.ListenPort,
                DeviceIp            = s.DeviceIp,
                DevicePort          = s.DevicePort,
                MyCallsign          = s.MyCallsign,
                Nodes               = (s.Nodes ?? []).Select(n => new NodeProfile
                {
                    Id                    = n.Id,
                    Name                  = n.Name,
                    Callsign              = n.Callsign,
                    DeviceIp              = n.DeviceIp,
                    DevicePort            = n.DevicePort,
                    ListenIp              = n.ListenIp,
                    ListenPort            = n.ListenPort,
                    IsPrimary             = n.IsPrimary,
                    TelnetCertThumbprint  = n.TelnetCertThumbprint,
                    TelnetPassword        = n.TelnetPassword,
                    ConsoleLogEnabled     = n.ConsoleLogEnabled
                }).ToList(),
                LogPath             = s.LogPath,
                LogRetainDays       = s.LogRetainDays,
                LogUdpTraffic       = s.LogUdpTraffic,
                ConsoleLogEnabled   = s.ConsoleLogEnabled,
                MonitorMaxMessages  = s.MonitorMaxMessages,
                TabMaxMessages      = s.TabMaxMessages,
                MhMaxAgeHours       = s.MhMaxAgeHours,
                GroupFilterEnabled  = s.GroupFilterEnabled,
                GroupsText          = string.Join("\n", s.Groups),
                WatchCallsignsText  = string.Join("\n", s.WatchCallsigns),
                WatchOnMessage      = s.WatchOnMessage,
                WatchOnPosition     = s.WatchOnPosition,
                WatchOnTelemetry    = s.WatchOnTelemetry,
                WatchOnAck          = s.WatchOnAck,
                WatchAlertMinutes   = s.WatchAlertMinutes,
                DataPath            = s.DataPath,
                TimeOffsetHours     = s.TimeOffsetHours,
                AutoReplyEnabled    = s.AutoReplyEnabled,
                AutoReplyText       = s.AutoReplyText,
                ReplyDelaySeconds   = s.ReplyDelaySeconds,
                BotEnabled          = s.BotEnabled,
                BotCommands         = s.BotCommands
                    .Select(c => new BotCommandEntry { Name = c.Name, Response = c.Response, Description = c.Description })
                    .ToList(),
                BeaconEnabled       = s.BeaconEnabled,
                BeaconGroup         = s.BeaconGroup,
                BeaconText          = s.BeaconText,
                BeaconIntervalHours = s.BeaconIntervalHours,
                TelemetryEnabled       = s.TelemetryEnabled,
                TelemetryFilePath      = s.TelemetryFilePath,
                TelemetryGroup         = s.TelemetryGroup,
                TelemetryScheduleHours = s.TelemetryScheduleHours,
                TelemetryMapping       = s.TelemetryMapping
                    .Select(m => new TelemetryMappingEntry { JsonKey = m.JsonKey, Label = m.Label, Unit = m.Unit, Decimals = m.Decimals, WeatherRole = m.WeatherRole })
                    .ToList(),
                TelemetryApiEnabled = s.TelemetryApiEnabled,
                TelemetryApiKey     = s.TelemetryApiKey,
                Language            = s.Language,
                DbProvider              = s.Database.Provider,
                DbMySqlConnectionString = s.Database.MySqlConnectionString,
                DbMySqlTableName        = s.Database.MySqlTableName,
                DbInfluxUrl             = s.Database.InfluxUrl,
                DbInfluxToken           = s.Database.InfluxToken,
                DbInfluxOrg             = s.Database.InfluxOrg,
                DbInfluxBucket          = s.Database.InfluxBucket,
                DbLogInserts            = s.Database.LogInserts,
                WebhookEnabled     = s.Webhook.Enabled,
                WebhookUrl         = s.Webhook.Url,
                WebhookOnMessage   = s.Webhook.OnMessage,
                WebhookOnPosition  = s.Webhook.OnPosition,
                WebhookOnTelemetry = s.Webhook.OnTelemetry,
                MqttEnabled             = s.Mqtt.Enabled,
                MqttHost                = s.Mqtt.Host,
                MqttPort                = s.Mqtt.Port,
                MqttClientId            = s.Mqtt.ClientId,
                MqttUsername            = s.Mqtt.Username,
                MqttPassword            = s.Mqtt.Password,
                MqttUseTls              = s.Mqtt.UseTls,
                MqttTopicPrefix         = s.Mqtt.TopicPrefix,
                MqttPublishMessage      = s.Mqtt.PublishMessage,
                MqttPublishPosition     = s.Mqtt.PublishPosition,
                MqttPublishTelemetry    = s.Mqtt.PublishTelemetry,
                MqttSubscribeEnabled    = s.Mqtt.SubscribeEnabled,
                MqttLogRequests         = s.Mqtt.LogRequests,
                QrzEnabled         = s.Qrz.Enabled,
                QrzUsername        = s.Qrz.Username,
                QrzPassword        = s.Qrz.Password,
                QrzLogRequests     = s.Qrz.LogRequests,
                QrzCacheMaxAgeDays = s.Qrz.CacheMaxAgeDays,
                AiEnabled          = s.Ai.Enabled,
                AiProvider         = s.Ai.Provider,
                AiApiKey           = s.Ai.ApiKey,
                AiModel            = s.Ai.Model,
                AiAzureEndpoint    = s.Ai.AzureEndpoint,
                AiAzureApiVersion  = s.Ai.AzureApiVersion,
                AiThresholdDays    = s.Ai.ThresholdDays,
                AiSummaryDays      = s.Ai.SummaryDays,
                AiMaxMessages      = s.Ai.MaxMessages,
                AiLogRequests      = s.Ai.LogRequests,
                TxPowerDbm              = s.TxPowerDbm,
                CableType               = s.CableType,
                CableLengthM            = s.CableLengthM,
                CustomCableLossDbPer10m = s.CustomCableLossDbPer10m,
                AntennaGainDbi          = s.AntennaGainDbi,
                AntennaType             = s.AntennaType,
                AntennaHeightM          = s.AntennaHeightM,
                OwnMessagesAlignLeft    = s.OwnMessagesAlignLeft,
                TxCooldownSeconds       = s.TxCooldownSeconds,
                GatewayHighlightEnabled = s.GatewayHighlightEnabled,
                GatewayServer           = s.GatewayServer,
                TelnetEnabled           = s.TelnetEnabled,
                ConsoleMode             = s.ConsoleMode,
                TelnetPort              = s.TelnetPort,
                TelnetPassword          = s.TelnetPassword,
                TelnetCertThumbprint    = s.TelnetCertThumbprint,
                SerialPortName          = s.SerialPortName,
                SerialBaudRate          = s.SerialBaudRate,
                GroupLabels = s.GroupLabels.Select(g => new GroupLabelEntry { Group = g.Group, ShortLabel = g.ShortLabel, Label = g.Label }).ToList()
            };
            await SettingsService.SaveMeshcomSettingsAsync(_model.ToSettings());
            // Reload page – file-watcher triggers config reload which drops the SignalR
            // connection; navigating first ensures a clean reconnect with success feedback.
            Nav.NavigateTo("/settings?restored=1", forceLoad: true);
        }
        catch (Exception ex)
        {
            _backupError = $"Import: {ex.Message}";
            StateHasChanged();
        }
    }

