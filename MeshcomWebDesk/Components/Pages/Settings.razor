    private async Task TestMqttConnectionAsync()
    {
        _mqttTestResult = null;
        _mqttTesting    = true;
        try
        {
            var cfg = _model.ToSettings().Mqtt;
            using var client = new MQTTnet.MqttFactory().CreateMqttClient();
            var optBuilder = new MQTTnet.Client.MqttClientOptionsBuilder()
                .WithTcpServer(cfg.Host, cfg.Port)
                .WithClientId(cfg.ClientId + "-test")
                .WithCleanSession();

            if (!string.IsNullOrEmpty(cfg.Username))
                optBuilder = optBuilder.WithCredentials(cfg.Username, cfg.Password);

            if (cfg.UseTls)
                optBuilder = optBuilder.WithTlsOptions(o => o.UseTls());

            using var cts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(10));
            await client.ConnectAsync(optBuilder.Build(), cts.Token);
            await client.DisconnectAsync(new MQTTnet.Client.MqttClientDisconnectOptionsBuilder().Build());
            _mqttTestResult = $"✅ {Loc.T("Verbindung erfolgreich.", "Connection successful.", "Connessione riuscita.", "Conexión exitosa.")})";
        }
        catch (Exception ex)
        {
            _mqttTestResult = $"❌ {Loc.T("Verbindung fehlgeschlagen:", "Connection failed:", "Connessione fallita:", "Conexión fallida:")} {ex.Message}";
        }
        finally
        {
            _mqttTesting = false;
        }
    }

