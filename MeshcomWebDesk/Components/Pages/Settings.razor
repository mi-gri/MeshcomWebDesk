@page "/settings"
@rendermode InteractiveServer
@using Microsoft.Extensions.Options
@using MeshcomWebDesk.Services.Database
@inject IOptionsMonitor<MeshcomSettings> SettingsMonitor
@inject SettingsService SettingsService
@inject MeshcomUdpService UdpService
@inject NodeManager NodeManager
@inject LanguageService Loc
@inject DatabaseSetupService DatabaseSetupService
@inject QrzService QrzService
@inject IJSRuntime JS
@inject MeshcomWebDesk.Services.Bot.BotCommandService BotCommandService
@inject MeshcomWebDesk.Services.QsoSummaryService QsoSummaryService
@inject NavigationManager Nav
@inject ChatService ChatService
@inject TelnetService TelnetService
@inject SerialConsoleService SerialConsoleService
@inject MeshcomWebDesk.Models.ResolvedLogPath ResolvedLogPath
@inject MeshcomWebDesk.Services.WeatherApiPollingService WeatherPollingService
@inject MeshcomWebDesk.Services.WeatherLicenseService WeatherLicenseService
@implements IDisposable

<PageTitle>@Loc.T("Einstellungen", "Settings") – MeshCom WebDesk</PageTitle>

<div class="settings-page">
    <div class="settings-container">

        <div class="settings-header">
            <span class="settings-icon">⚙️</span>
            <h1 class="settings-title">@Loc.T("Einstellungen", "Settings")</h1>
        </div>

        <div class="settings-notice">
            ℹ️ @Loc.T("Die meisten Einstellungen werden", "Most settings are applied")
            <strong>@Loc.T("sofort", "immediately")</strong>
            @Loc.T("übernommen, ohne Neustart.", "without a restart.")<br />
            @Loc.T("Ausnahmen:", "Exceptions:")
            <strong>Listen-IP / Listen-Port</strong>
            @Loc.T("(Socket-Binding) und", "(socket binding) and")
            <strong>@Loc.T("Log-Pfad / Log-Aufbewahrung", "Log Path / Log Retention")</strong>
            @Loc.T("(Serilog) erfordern einen Neustart der Anwendung.", "(Serilog) require an application restart.")
        </div>

        @if (_errorMessage != null)
        {
            <div class="settings-error">❌ @Loc.T("Fehler:", "Error:") @_errorMessage</div>
        }

        <!-- Verbindung / Connection -->
        <div class="settings-section @(IsOpen("conn") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("conn")'>🔌 @Loc.T("Verbindung", "Connection") <span class="section-chevron">@(IsOpen("conn") ? "▲" : "▼")</span></h2>
            @if (IsOpen("conn")) {
            <div class="settings-grid">
                <label>Listen IP</label>
                <input type="text" @bind="_model.ListenIp" />

                <label>Listen Port</label>
                <input type="number" min="1" max="65535" @bind="_model.ListenPort" />

                <label>Device IP</label>
                <input type="text" @bind="_model.DeviceIp" />

                <label>Device Port</label>
                <input type="number" min="1" max="65535" @bind="_model.DevicePort" />

                <label>@Loc.T("Eigenes Rufzeichen", "Own Callsign")</label>
                <input type="text" @bind="_model.MyCallsign" />
            </div>
            <a class="settings-help-banner"
               href="@($"https://github.com/DH1FR/MeshcomWebDesk/blob/master/docs/node-connection-{Loc.Current}.md")"
               target="_blank" rel="noopener">
                ❓ @Loc.T(
                    "Wie konfiguriere ich meinen MeshCom-Node für WebDesk?",
                    "How do I configure my MeshCom node for WebDesk?")
                <span class="settings-help-banner-arrow">→</span>
            </a>
            }
        </div>

        <!-- Multi-Node -->
        <div class="settings-section @(IsOpen("nodes") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("nodes")'>🖧 @Loc.T("Weitere Nodes", "Additional Nodes") <span class="section-chevron">@(IsOpen("nodes") ? "▲" : "▼")</span></h2>
            @if (IsOpen("nodes")) {
            <p style="color:#8b949e;font-size:.85em;margin:0 0 .5rem 0">
                @Loc.T(
                    "Konfiguriere mehrere MeshCom-Nodes. Der Primär-Node treibt alle globalen Funktionen (Karte, MH, Bot, Telemetrie …). Weitere Nodes sind im Chat auswählbar.",
                    "Configure multiple MeshCom nodes. The primary node drives all global features (map, MH, bot, telemetry …). Additional nodes are selectable in the chat view.")
            </p>
            @if (_model.Nodes.Count == 0) {
                <p style="color:#8b949e;font-size:.85em">
                    @Loc.T(
                        "Kein weiterer Node konfiguriert. Die Verbindungseinstellungen oben gelten für den einzigen (Primär-)Node.",
                        "No additional nodes configured. The connection settings above apply to the single (primary) node.")
                </p>
            }
            @foreach (var node in _model.Nodes) {
                <div class="settings-node-card">
                    <div class="settings-node-header">
                        <strong>@node.Name</strong>
                        @if (node.IsPrimary) {
                            <span class="settings-node-primary-badge">★ @Loc.T("Primär", "Primary")</span>
                        }
                        <div class="settings-node-actions">
                            @if (!node.IsPrimary) {
                                <button class="btn-small" @onclick="() => SetPrimaryNode(node)">@Loc.T("Als Primär", "Set Primary")</button>
                            }
                            <button class="btn-small btn-danger" @onclick="() => RemoveNode(node)">✕</button>
                        </div>
                    </div>
                    <div class="settings-grid" style="margin-top:.5rem">
                        <label>@Loc.T("Name", "Name")</label>
                        <input type="text" @bind="node.Name" />
                        <label>@Loc.T("Rufzeichen", "Callsign")</label>
                        <div>
                            <input type="text" @bind="node.Callsign" placeholder="OE1ABC-2" style="text-transform:uppercase;width:100%" />
                            @if (string.IsNullOrWhiteSpace(node.Callsign))
                            {
                                <small style="color:#f85149">⚠️ @Loc.T("Rufzeichen darf nicht leer sein.", "Callsign must not be empty.")</small>
                            }
                            else if (_model.Nodes.Count(n => string.Equals(n.Callsign, node.Callsign, StringComparison.OrdinalIgnoreCase)) > 1)
                            {
                                <small style="color:#f85149">⚠️ @Loc.T("Rufzeichen wird von mehreren Nodes verwendet – Echo-Erkennung schlägt fehl!", "Callsign used by multiple nodes – echo detection will fail!")</small>
                            }
                        </div>
                        <label>Device IP</label>
                        <input type="text" @bind="node.DeviceIp" />
                        <label>Device Port</label>
                        <input type="number" min="1" max="65535" @bind="node.DevicePort" />
                        <label>Listen IP</label>
                        <input type="text" @bind="node.ListenIp" />
                        <label>Listen Port</label>
                        <input type="number" min="1" max="65535" @bind="node.ListenPort" />
                        @* ── TLS Console ── *@
                        <label>
                            @Loc.T("TLS Passwort", "TLS Password")<br />
                            <small>@Loc.T("Leer = kein Passwort (--passwd am Node)", "Empty = no password (--passwd on node)")</small>
                        </label>
                        <input type="password" @bind="node.TelnetPassword" placeholder="••••••••" autocomplete="new-password" />
                        <label>
                            @Loc.T("TLS Zertifikat-Fingerprint", "TLS Certificate Fingerprint")<br />
                            <small>@Loc.T("Leer = beim ersten Verbinden anzeigen", "Empty = show on first connect")</small>
                        </label>
                        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                            <input type="text" @bind="node.TelnetCertThumbprint"
                                   placeholder="AA:BB:CC:…"
                                   style="flex:1;min-width:200px;font-family:monospace;font-size:11px;" />
                            @if (!string.IsNullOrEmpty(node.TelnetCertThumbprint))
                            {
                                <button class="btn-danger" style="padding:2px 8px;font-size:11px;"
                                        @onclick="() => node.TelnetCertThumbprint = string.Empty"
                                        title="@Loc.T("Fingerprint löschen (First-Connect-Modus)", "Clear fingerprint (first-connect mode)")">
                                    🗑
                                </button>
                            }
                        </div>

                        @* ── Console Log ── *@
                        <label>
                            @Loc.T("Console-Log", "Console Log")<br />
                            <small>@Loc.T("Konsolenausgabe dieses Nodes in Datei sichern (console-{IP}-{datum}.log)", "Save this node's console output to file (console-{IP}-{date}.log)")</small>
                        </label>
                        <label class="settings-toggle">
                            <input type="checkbox" @bind="node.ConsoleLogEnabled" />
                            <span>@(node.ConsoleLogEnabled ? Loc.T("Aktiv", "Active") : Loc.T("Inaktiv", "Inactive"))</span>
                        </label>
                    </div>
                </div>
            }
            <button class="btn-secondary" style="margin-top:.5rem" @onclick="AddNode">+ @Loc.T("Node hinzufügen", "Add Node")</button>
            }
        </div>

        <!-- Station / RF -->
        <div class="settings-section @(IsOpen("station") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("station")'>📻 @Loc.T("Station / HF-Parameter", "Station / RF Parameters") <span class="section-chevron">@(IsOpen("station") ? "▲" : "▼")</span></h2>
            @if (IsOpen("station")) {
            var cableLossMap = new Dictionary<string, double> { ["none"]=0.0,["rg174"]=5.0,["rg58"]=2.5,["rg8x"]=3.0,["rg8"]=1.8,["rg213"]=1.2,["h155"]=0.8,["aircell7"]=0.6,["lmr200"]=1.0,["lmr240"]=0.75,["lmr400"]=0.4,["lmr600"]=0.25,["ecoflex10"]=0.55,["ecoflex15"]=0.37,["h2000flex"]=0.33,["cfd400"]=0.45,["custom"]=_model.CustomCableLossDbPer10m };
            var lossPerM     = cableLossMap.TryGetValue(_model.CableType, out var lpm) ? lpm / 10.0 : 0.0;
            var cableLossDb  = lossPerM * _model.CableLengthM;
            var eirp         = _model.TxPowerDbm - cableLossDb + _model.AntennaGainDbi;
            var linkBudget   = eirp - (-120) - _model.SystemMarginDb;
            var fsplKm       = Math.Pow(10, (linkBudget - 20 * Math.Log10(_model.FrequencyMhz) - 32.44) / 20);
            <div class="settings-grid">
                <label>@Loc.T("TX-Leistung", "TX Power") (dBm)</label>
                <div style="display:flex;align-items:center;gap:8px">
                    <input type="number" min="-10" max="40" step="1" @bind="_model.TxPowerDbm" style="width:80px" />
                    <small style="color:#8b949e">@(Math.Round(Math.Pow(10, _model.TxPowerDbm / 10.0), 0).ToString("F0")) mW</small>
                </div>

                <label>@Loc.T("Kabeltyp", "Cable Type")</label>
                <select @bind="_model.CableType">
                    <option value="none">@Loc.T("Direktmontage / &lt; 0,5 m (0,0 dB/10m)", "Direct mount / &lt; 0.5 m (0.0 dB/10m)")</option>
                    <optgroup label="Niedrige Dämpfung">
                        <option value="lmr600">LMR-600 (0,25 dB/10m)</option>
                        <option value="lmr400">LMR-400 (0,40 dB/10m)</option>
                        <option value="h2000flex">H-2000 Flex (0,33 dB/10m)</option>
                        <option value="ecoflex15">Ecoflex 15 (0,37 dB/10m)</option>
                        <option value="cfd400">CFD-400 (0,45 dB/10m)</option>
                        <option value="ecoflex10">Ecoflex 10 (0,55 dB/10m)</option>
                    </optgroup>
                    <optgroup label="Mittlere Dämpfung">
                        <option value="aircell7">Aircell 7 (0,60 dB/10m)</option>
                        <option value="lmr240">LMR-240 (0,75 dB/10m)</option>
                        <option value="h155">H-155 (0,80 dB/10m)</option>
                        <option value="lmr200">LMR-200 (1,00 dB/10m)</option>
                        <option value="rg213">RG-213 (1,20 dB/10m)</option>
                        <option value="rg8">RG-8/U (1,80 dB/10m)</option>
                    </optgroup>
                    <optgroup label="Hohe Dämpfung">
                        <option value="rg8x">RG-8X (3,00 dB/10m)</option>
                        <option value="rg58">RG-58 (2,50 dB/10m)</option>
                        <option value="rg174">RG-174 (5,00 dB/10m)</option>
                    </optgroup>
                    <optgroup label="Manuell">
                        <option value="custom">@Loc.T("Manuell eingeben …", "Enter manually …")</option>
                    </optgroup>
                </select>

                @if (_model.CableType == "custom") {
                <label>@Loc.T("Dämpfung manuell", "Manual Loss") (dB/10m)</label>
                <div style="display:flex;align-items:center;gap:8px">
                    <input type="number" min="0" max="30" step="0.05" @bind="_model.CustomCableLossDbPer10m" style="width:90px" />
                    <small style="color:#8b949e">@Loc.T("z.B. 1,5 für Ihr Spezialverlust", "e.g. 1.5 for your special cable")</small>
                </div>
                }
                <label>@Loc.T("Kabellänge", "Cable Length") (m)</label>
                <div style="display:flex;align-items:center;gap:8px">
                    <input type="number" min="0" max="500" step="0.5" @bind="_model.CableLengthM" style="width:80px" />
                    <small style="color:#8b949e">@Loc.T("Verlust", "Loss"): @cableLossDb.ToString("F2") dB</small>
                </div>

                <label>@Loc.T("Antennengewinn", "Antenna Gain") (dBi)</label>
                <input type="number" min="-5" max="30" step="0.1" @bind="_model.AntennaGainDbi" style="width:80px" />

                <label>@Loc.T("Antennentyp", "Antenna Type")</label>
                <input type="text" maxlength="80" placeholder="@Loc.T("z.B. Dipol, Yagi 3-El., Groundplane …", "e.g. Dipole, 3-el. Yagi, Ground plane …")" @bind="_model.AntennaType" style="max-width:300px" />

                <label>@Loc.T("Antennenhöhe (ü. Boden)", "Antenna Height (AGL)") (m)</label>
                <input type="number" min="0" max="500" step="0.5" @bind="_model.AntennaHeightM" style="width:80px" />

                <label>@Loc.T("Frequenz", "Frequency") (MHz)</label>
                <input type="number" min="300" max="1000" step="0.025" @bind="_model.FrequencyMhz" style="width:100px" />

                <label>@Loc.T("Systemreserve", "System Margin") (dB)</label>
                <div style="display:flex;align-items:center;gap:8px">
                    <input type="number" min="0" max="60" step="1" @bind="_model.SystemMarginDb" style="width:80px" />
                    <small style="color:#8b949e">@Loc.T("Geländeverluste etc. (Standard: 30 dB → realistischere Reichweite)", "Terrain loss etc. (default: 30 dB → more realistic range)")</small>
                </div>
            </div>
            <div style="margin-top:0.75rem;padding:0.5rem 0.75rem;background:#161b22;border:1px solid #30363d;border-radius:6px;display:flex;gap:1.5rem;flex-wrap:wrap">
                <span>⚡ EIRP: <strong style="color:@(eirp >= 20 ? "#3fb950" : eirp >= 10 ? "#e3b341" : "#f85149")">@eirp.ToString("F2") dBm</strong> (@(Math.Round(Math.Pow(10, eirp / 10.0), 0).ToString("F0")) mW)</span>
                <span>📻 @Loc.T("Reichweite (theor.):", "Range (theor.):"): <strong style="color:#e3b341">@(fsplKm >= 1 ? fsplKm.ToString("F0") + " km" : (fsplKm * 1000).ToString("F0") + " m")</strong></span>
                <small style="color:#8b949e;align-self:center">= TX @_model.TxPowerDbm dBm − Kabel @cableLossDb.ToString("F2") dB + Antenne @_model.AntennaGainDbi dBi − Reserve @_model.SystemMarginDb dB</small>
            </div>
            <div style="margin-top:0.4rem">
                <small style="color:#8b949e">💡 @Loc.T(
                    "EIRP-Kreis auf der Karte zeigt die theoretische Freiraumreichweite (ohne Geländeberücksichtigung).",
                    "EIRP circle on the map shows the theoretical free-space range (no terrain considered).")</small>
            </div>
            }
        </div>

        <!-- Logging -->
        <div class="settings-section @(IsOpen("log") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("log")'>📝 Logging <span class="section-chevron">@(IsOpen("log") ? "▲" : "▼")</span></h2>
            @if (IsOpen("log")) {
            <div class="settings-grid">
                <label>@Loc.T("Log-Pfad", "Log Path")</label>
                <input type="text" @bind="_model.LogPath" placeholder="@ResolvedLogPath.Path" />
                @if (string.IsNullOrWhiteSpace(_model.LogPath))
                {
                    <span></span>
                    <small style="color:#8b949e">@Loc.T("Leer = Standard-Pfad wird verwendet:", "Empty = default path is used:") <code>@ResolvedLogPath.Path</code></small>
                }

                <label>@Loc.T("Log-Aufbewahrung (Tage)", "Log Retention (Days)")</label>
                <input type="number" min="1" @bind="_model.LogRetainDays" />

                <label>
                    @Loc.T("UDP-Traffic loggen", "Log UDP Traffic")
                </label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.LogUdpTraffic" />
                    <span>@(_model.LogUdpTraffic ? Loc.T("Aktiv", "Active") : Loc.T("Inaktiv", "Inactive"))</span>
                </label>

                <label>
                    @Loc.T("Console-Log (Serial / Legacy)", "Console Log (Serial / Legacy)")<br />
                    <small>@Loc.T("Konsolenausgabe in Datei sichern (console-{host}-{datum}.log). Für TLS/NET-Console pro Node konfigurierbar.", "Save console output to file (console-{host}-{date}.log). For TLS/NET Console configurable per node.")</small>
                </label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.ConsoleLogEnabled" />
                    <span>@(_model.ConsoleLogEnabled ? Loc.T("Aktiv", "Active") : Loc.T("Inaktiv", "Inactive"))</span>
                </label>
            </div>
            }
        </div>

        <!-- Chat & Monitor -->
        <div class="settings-section @(IsOpen("chat") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("chat")'>💬 Chat &amp; Monitor <span class="section-chevron">@(IsOpen("chat") ? "▲" : "▼")</span></h2>
            @if (IsOpen("chat")) {
            <div class="settings-grid">
                <label>@Loc.T("Monitor-Limit (Einträge)", "Monitor Limit (Entries)")</label>
                <input type="number" min="10" @bind="_model.MonitorMaxMessages" />

                <label>
                    @Loc.T("Tab-Limit (Nachrichten)", "Tab Limit (Messages)")<br />
                    <small>@Loc.T("Max. Nachrichten pro Chat-Tab. Älteste werden gelöscht. 0 = unbegrenzt.", "Max. messages per chat tab. Oldest are removed first. 0 = unlimited.")</small>
                </label>
                <input type="number" min="0" @bind="_model.TabMaxMessages" />

                <label>
                    @Loc.T("MH-Liste: Max. Alter (Stunden)", "MH List: Max. Age (Hours)")<br />
                    <small>@Loc.T("Einträge älter als x Stunden werden automatisch gelöscht. 0 = deaktiviert. (z. B. 24 = 1 Tag, 168 = 1 Woche)", "Entries older than x hours are automatically removed. 0 = disabled. (e.g. 24 = 1 day, 168 = 1 week)")</small>
                </label>
                <input type="number" min="0" @bind="_model.MhMaxAgeHours" />

                <label>
                    @Loc.T("Zeitversatz (Stunden)", "Time Offset (Hours)")<br />
                    <small>@Loc.T("UTC-Korrektur für Zeitanzeige, z.\u00a0B. 1 für MEZ, 2 für MESZ, 0 wenn Zeitzone bereits korrekt", "UTC offset for time display, e.\u00a0g. 1 for CET, 2 for CEST, 0 if timezone already correct")</small>
                </label>
                <input type="number" step="0.5" @bind="_model.TimeOffsetHours" />

                <label>@Loc.T("Gruppenfilter aktiv", "Group Filter Active")</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.GroupFilterEnabled" />
                    <span>@(_model.GroupFilterEnabled ? Loc.T("Aktiv", "Active") : Loc.T("Inaktiv", "Inactive"))</span>
                </label>

                <label>
                    @Loc.T("Gruppen-Whitelist", "Group Whitelist")<br />
                    <small>@Loc.T("(eine pro Zeile, z.\u00a0B. #262)", "(one per line, e.\u00a0g. #262)")</small>
                </label>
                <textarea rows="4" @bind="_model.GroupsText"></textarea>

                <label>
                    @Loc.T("Eigene Nachrichten linksbündig", "Own messages left-aligned")<br />
                    <small>@Loc.T("Eigene gesendete Nachrichten werden links statt rechts angezeigt", "Own sent messages are displayed on the left instead of the right")</small>
                </label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.OwnMessagesAlignLeft" />
                    <span>@(_model.OwnMessagesAlignLeft ? Loc.T("Linksbündig", "Left-aligned") : Loc.T("Rechtsbündig (Standard)", "Right-aligned (default)"))</span>
                </label>

                <label>
                    @Loc.T("Sendepause (Sekunden)", "TX Cooldown (seconds)")<br />
                    <small>@Loc.T("Mindestwartezeit zwischen zwei Sendungen (5–60 Sek.).", "Minimum wait time between two transmissions (5–60 s).")</small>
                </label>
                <div style="display:flex; gap:.75rem; align-items:center;">
                    <input type="range" min="5" max="60" step="1"
                           value="@_model.TxCooldownSeconds"
                           @oninput="@(e => _model.TxCooldownSeconds = int.Parse(e.Value!.ToString()!))"
                           style="flex:1;" />
                    <span style="min-width:3rem; text-align:right; font-weight:600;">@_model.TxCooldownSeconds s</span>
                </div>

                <label>
                    @Loc.T("Gateway-Hervorhebung", "Gateway Highlight")<br />
                    <small>@Loc.T("Gateway-Stationen mit 🌐-Symbol und Farbe hervorheben.", "Highlight gateway stations with a 🌐 symbol and colour.")</small>
                </label>
                <label>
                    <input type="checkbox" @bind="_model.GatewayHighlightEnabled" />
                    <span>@(_model.GatewayHighlightEnabled ? Loc.T("Aktiviert", "Enabled") : Loc.T("Deaktiviert", "Disabled"))</span>
                </label>

                <label>
                    @Loc.T("Gateway-Quelle", "Gateway Source")<br />
                    <small>@Loc.T("Server für die Gateway-Liste.", "Server for the gateway list.")</small>
                </label>
                <select @bind="_model.GatewayServer">
                    <option value="oe">🇦🇹 OE – meshcom.oevsv.at</option>
                    <option value="dl">🇩🇪 DL – meshcom.hamnet.network</option>
                </select>
            </div>
            }
        </div>

        <!-- Datenspeicherung / Data Storage -->
        <div class="settings-section @(IsOpen("data") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("data")'>💾 @Loc.T("Datenspeicherung", "Data Storage") <span class="section-chevron">@(IsOpen("data") ? "▲" : "▼")</span></h2>
            @if (IsOpen("data")) {
            <div class="settings-grid">
                <label>@Loc.T("Datenpfad", "Data Path")</label>
                <input type="text" @bind="_model.DataPath" />
            </div>
            }
        </div>

        <!-- Console -->
        <div class="settings-section @(IsOpen("telnet") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("telnet")'>🖥️ @Loc.T("Console", "Console") <span class="section-chevron">@(IsOpen("telnet") ? "▲" : "▼")</span></h2>
            @if (IsOpen("telnet")) {
            <div class="settings-grid">
                <label>
                    @Loc.T("Console aktivieren", "Enable Console")<br />
                    <small>@Loc.T("Öffnet den Console-Tab (TLS oder Seriell).", "Opens the Console tab (TLS or Serial).")</small>
                </label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.TelnetEnabled" />
                    <span>@(_model.TelnetEnabled ? Loc.T("Aktiv", "Active") : Loc.T("Inaktiv", "Inactive"))</span>
                </label>

                <label>@Loc.T("Modus", "Mode")</label>
                <div style="display:flex; gap:1rem; align-items:center;">
                    <label style="display:flex; gap:.3rem; align-items:center; cursor:pointer;">
                        <input type="radio" name="consoleMode" value="tls"
                               checked="@(_model.ConsoleMode == "tls")"
                               @onchange="@(() => _model.ConsoleMode = "tls")" />
