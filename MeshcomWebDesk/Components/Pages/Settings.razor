    private async Task TestAiAsync()
    {
        _aiTesting    = true;
        _aiTestResult = null;
        StateHasChanged();

        try
        {
            // Save current settings first so QsoSummaryService picks them up
            await SettingsService.SaveMeshcomSettingsAsync(_model.ToSettings());

            var cs = _aiTestCallsign.Trim();
            if (string.IsNullOrEmpty(cs))
            {
                _aiTestResult = Loc.T("❌ Bitte ein Rufzeichen eingeben.", "❌ Please enter a callsign.");
                return;
            }

            // Strip SSID for the base callsign
            var csBase = cs.Contains('-') ? cs[..cs.IndexOf('-')] : cs;

            // Step 1: DB check
            var hasData = await QsoSummaryService.HasSummaryAsync(csBase);
            var lastQso = await QsoSummaryService.GetLastQsoTimeAsync(csBase);

            var dbLine = lastQso.HasValue
                ? Loc.T($"✅ DB: Letztes QSO mit {csBase}: {lastQso:dd.MM.yyyy HH:mm}",
                         $"✅ DB: Last QSO with {csBase}: {lastQso:dd.MM.yyyy HH:mm}")
                : Loc.T($"⚠️ DB: Keine Nachrichten für {csBase} gefunden.",
                         $"⚠️ DB: No messages found for {csBase}.");

            var iconLine = hasData
                ? Loc.T("✅ Icon: würde angezeigt werden.", "✅ Icon: would be shown.")
                : Loc.T("ℹ️ Icon: wird nicht angezeigt (Schwellwert nicht erreicht oder keine Daten).",
                         "ℹ️ Icon: not shown (threshold not reached or no data).");

            // Step 2: quick API ping (generate with max 1 message to test connectivity)
            var apiLine = string.Empty;
            var s = SettingsMonitor.CurrentValue.Ai;
            if (!string.IsNullOrWhiteSpace(s.ApiKey))
            {
                try
                {
                    var summary = await QsoSummaryService.GenerateSummaryAsync(csBase, _model.MyCallsign);
                    apiLine = summary != null
                        ? Loc.T("✅ API: Verbindung erfolgreich, Zusammenfassung generiert.",
                                 "✅ API: Connection successful, summary generated.")
                        : Loc.T("❌ API: Anfrage fehlgeschlagen. Bitte Log prüfen.",
                                 "❌ API: Request failed. Please check log.");
                }
                catch (Exception ex)
                {
                    apiLine = $"❌ API: {ex.Message}";
                }
            }
            else
            {
                apiLine = Loc.T("ℹ️ API: Kein API-Key konfiguriert – nur DB-Test möglich.",
                                 "ℹ️ API: No API key configured – DB test only.");
            }

            _aiTestResult = string.Join("\n", new[] { dbLine, iconLine, apiLine }.Where(l => !string.IsNullOrEmpty(l)));
        }
        catch (Exception ex)
        {
            _aiTestResult = $"❌ {ex.Message}";
        }
        finally
        {
            _aiTesting = false;
        }
    }

