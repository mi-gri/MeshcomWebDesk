@page "/settings"
@rendermode InteractiveServer
@using Microsoft.Extensions.Options
@using MeshcomWebDesk.Services.Database
@inject IOptionsMonitor<MeshcomSettings> SettingsMonitor
@inject SettingsService SettingsService
@inject MeshcomUdpService UdpService
@inject LanguageService Loc
@inject DatabaseSetupService DatabaseSetupService
@inject QrzService QrzService
@inject IJSRuntime JS
@inject MeshcomWebDesk.Services.Bot.BotCommandService BotCommandService
@implements IDisposable

<PageTitle>@Loc.T("Einstellungen", "Settings", "Impostazioni", "Configuración") – MeshCom WebDesk</PageTitle>

<div class="settings-page">
    <div class="settings-container">

        <div class="settings-header">
            <span class="settings-icon">⚙️</span>
            <h1 class="settings-title">@Loc.T("Einstellungen", "Settings", "Impostazioni", "Configuración")</h1>
        </div>

        <div class="settings-notice">
            ℹ️ @Loc.T("Die meisten Einstellungen werden", "Most settings are applied", "La maggior parte delle impostazioni vengono", "La mayoría de los ajustes se aplican")
            <strong>@Loc.T("sofort", "immediately", "immediatamente", "inmediatamente")</strong>
            @Loc.T("übernommen, ohne Neustart.", "without a restart.", "applicate senza riavvio.", "sin reiniciar.")<br />
            @Loc.T("Ausnahmen:", "Exceptions:", "Eccezioni:", "Excepciones:")
            <strong>Listen-IP / Listen-Port</strong>
            @Loc.T("(Socket-Binding) und", "(socket binding) and", "(binding socket) e", "(binding de socket) y")
            <strong>@Loc.T("Log-Pfad / Log-Aufbewahrung", "Log Path / Log Retention", "Percorso / Conservazione Log", "Ruta / Retención de Log")</strong>
            @Loc.T("(Serilog) erfordern einen Neustart der Anwendung.", "(Serilog) require an application restart.", "(Serilog) richiedono il riavvio dell'app.", "(Serilog) requieren reiniciar la aplicación.")
        </div>

        @if (_saved)
        {
            <div class="settings-success">✅ @Loc.T("Einstellungen gespeichert.", "Settings saved.", "Impostazioni salvate.", "Ajustes guardados.")</div>
        }
        @if (_errorMessage != null)
        {
            <div class="settings-error">❌ @Loc.T("Fehler:", "Error:", "Errore:", "Error:") @_errorMessage</div>
        }

        <!-- Verbindung / Connection -->
        <div class="settings-section @(IsOpen("conn") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("conn")'>🔌 @Loc.T("Verbindung", "Connection", "Connessione", "Conexión") <span class="section-chevron">@(IsOpen("conn") ? "▲" : "▼")</span></h2>
            <div class="settings-grid">
                <label>Listen IP</label>
                <input type="text" @bind="_model.ListenIp" />

                <label>Listen Port</label>
                <input type="number" min="1" max="65535" @bind="_model.ListenPort" />

                <label>Device IP</label>
                <input type="text" @bind="_model.DeviceIp" />

                <label>Device Port</label>
                <input type="number" min="1" max="65535" @bind="_model.DevicePort" />

                <label>@Loc.T("Eigenes Rufzeichen", "Own Callsign", "Nominativo", "Indicativo propio")</label>
                <input type="text" @bind="_model.MyCallsign" />
            </div>
            <a class="settings-help-banner"
               href="@($"https://github.com/DH1FR/MeshcomWebDesk/blob/master/docs/node-connection-{Loc.Current}.md")"
               target="_blank" rel="noopener">
                ❓ @Loc.T(
                    "Wie konfiguriere ich meinen MeshCom-Node für WebDesk?",
                    "How do I configure my MeshCom node for WebDesk?",
                    "Come configuro il mio nodo MeshCom per WebDesk?",
                    "¿Cómo configuro mi nodo MeshCom para WebDesk?")
                <span class="settings-help-banner-arrow">→</span>
            </a>
        </div>

        <!-- Logging -->
        <div class="settings-section @(IsOpen("log") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("log")'>📝 Logging <span class="section-chevron">@(IsOpen("log") ? "▲" : "▼")</span></h2>
            <div class="settings-grid">
                <label>@Loc.T("Log-Pfad", "Log Path", "Percorso Log", "Ruta de Log")</label>
                <input type="text" @bind="_model.LogPath" />

                <label>@Loc.T("Log-Aufbewahrung (Tage)", "Log Retention (Days)", "Conservazione Log (giorni)", "Retención de Log (días)")</label>
                <input type="number" min="1" @bind="_model.LogRetainDays" />

                <label>
                    @Loc.T("UDP-Traffic loggen", "Log UDP Traffic", "Registra traffico UDP", "Registrar tráfico UDP")
                </label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.LogUdpTraffic" />
                    <span>@(_model.LogUdpTraffic ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                </label>
            </div>
        </div>

        <!-- Chat & Monitor -->
        <div class="settings-section @(IsOpen("chat") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("chat")'>💬 Chat &amp; Monitor <span class="section-chevron">@(IsOpen("chat") ? "▲" : "▼")</span></h2>
            <div class="settings-grid">
                <label>@Loc.T("Monitor-Limit (Einträge)", "Monitor Limit (Entries)", "Limite monitor (voci)", "Límite monitor (entradas)")</label>
                <input type="number" min="10" @bind="_model.MonitorMaxMessages" />

                <label>
                    @Loc.T("Zeitversatz (Stunden)", "Time Offset (Hours)", "Offset orario (ore)", "Desfase horario (horas)")<br />
                    <small>@Loc.T("UTC-Korrektur für Zeitanzeige, z.\u00a0B. 1 für MEZ, 2 für MESZ, 0 wenn Zeitzone bereits korrekt", "UTC offset for time display, e.\u00a0g. 1 for CET, 2 for CEST, 0 if timezone already correct", "Offset UTC per visualizzazione, es. 1 per CET, 2 per CEST", "Desfase UTC para visualización, p.ej. 1 para CET, 2 para CEST")</small>
                </label>
                <input type="number" step="0.5" @bind="_model.TimeOffsetHours" />

                <label>@Loc.T("Gruppenfilter aktiv", "Group Filter Active", "Filtro gruppi attivo", "Filtro de grupos activo")</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.GroupFilterEnabled" />
                    <span>@(_model.GroupFilterEnabled ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                </label>

                <label>
                    @Loc.T("Gruppen-Whitelist", "Group Whitelist", "Whitelist gruppi", "Lista blanca de grupos")<br />
                    <small>@Loc.T("(eine pro Zeile, z.\u00a0B. #262)", "(one per line, e.\u00a0g. #262)", "(uno per riga, es. #262)", "(uno por línea, p.ej. #262)")</small>
                </label>
                <textarea rows="4" @bind="_model.GroupsText"></textarea>
            </div>
        </div>

        <!-- Datenspeicherung / Data Storage -->
        <div class="settings-section @(IsOpen("data") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("data")'>💾 @Loc.T("Datenspeicherung", "Data Storage", "Archiviazione dati", "Almacenamiento de datos") <span class="section-chevron">@(IsOpen("data") ? "▲" : "▼")</span></h2>
            <div class="settings-grid">
                <label>@Loc.T("Datenpfad", "Data Path", "Percorso dati", "Ruta de datos")</label>
                <input type="text" @bind="_model.DataPath" />
            </div>
        </div>

        <!-- Auto-Reply -->
        <div class="settings-section @(IsOpen("autoreply") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("autoreply")'>↩️ Auto-Reply <span class="section-chevron">@(IsOpen("autoreply") ? "▲" : "▼")</span></h2>
            <div class="settings-grid">
                <label>@Loc.T("Auto-Reply aktiv", "Auto-Reply Active", "Auto-risposta attiva", "Auto-respuesta activa")</label>
                <label class="settings-toggle">
                    <input type="checkbox" @bind="_model.AutoReplyEnabled" />
                    <span>@(_model.AutoReplyEnabled ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                </label>

                <label>Auto-Reply Text</label>
                <div class="settings-input-hint">
                    <input type="text" @bind="_model.AutoReplyText" />
                    <div style="display:flex;align-items:center;gap:8px;margin-top:4px">
                        <span class="settings-hint">@Loc.T("Variablen verfügbar:", "Variables available:", "Variabili disponibili:", "Variables disponibles:")</span>
                        <button type="button" class="btn-add" style="padding:2px 10px;font-size:12px"
                                @onclick="() => _showAutoReplyVars = !_showAutoReplyVars">
                            📋 @(_showAutoReplyVars
                                ? Loc.T("Ausblenden", "Hide", "Nascondi", "Ocultar")
                                : Loc.T("Anzeigen", "Show", "Mostra", "Mostrar"))
                        </button>
                    </div>
                    @if (_showAutoReplyVars)
                    {
                        var ver  = System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString(3) ?? "?";
                        var now  = DateTime.Now;
                        <table class="telemetry-mapping-table" style="margin-top:0.5rem;font-size:12px">
                            <thead>
                                <tr>
                                    <th>@Loc.T("Variable", "Variable", "Variabile", "Variable")</th>
                                    <th>@Loc.T("Bedeutung", "Meaning", "Significato", "Significado")</th>
                                    <th>@Loc.T("Beispiel", "Example", "Esempio", "Ejemplo")</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td><code>{version}</code></td>  <td>@Loc.T("App-Version",           "App version",          "Versione app",           "Versión app")</td>          <td style="font-family:monospace">@ver</td></tr>
                                <tr><td><code>{mycall}</code></td>   <td>@Loc.T("Eigenes Rufzeichen",   "Own callsign",          "Nominativo proprio",     "Indicativo propio")</td>    <td style="font-family:monospace">@_model.MyCallsign</td></tr>
                                <tr><td><code>{callsign}</code></td> <td>@Loc.T("Anrufendes Rufzeichen","Caller's callsign",    "Nominativo chiamante",   "Indicativo llamante")</td>  <td style="font-family:monospace">OE1KBC-1</td></tr>
                                <tr><td><code>{mylocator}</code></td> <td>@Loc.T("Eigener QTH-Locator", "Own QTH Locator", "Locatore QTH proprio", "Localizador QTH propio")</td>         <td style="font-family:monospace">JN48QN</td></tr>
                                <tr><td><code>{dest-name}</code></td><td>@Loc.T("QRZ-Vorname",          "QRZ first name",        "Nome QRZ",               "Nombre QRZ")</td>           <td style="font-family:monospace;color:#7ee787">@Loc.T("Max ⚠️ nur wenn gecacht","Max ⚠️ if cached","Max ⚠️ se in cache","Max ⚠️ si en caché")</td></tr>
                                <tr><td><code>{dest-loc}</code></td> <td>@Loc.T("QRZ-Ort",              "QRZ location",          "Luogo QRZ",              "Lugar QRZ")</td>            <td style="font-family:monospace;color:#7ee787">@Loc.T("Wien ⚠️ nur wenn gecacht","Wien ⚠️ if cached","Wien ⚠️ se in cache","Wien ⚠️ si en caché")</td></tr>
                                <tr><td><code>{locator}</code></td>  <td>@Loc.T("QTH-Locator (Gesprächspartner)", "QTH Locator (partner)", "Locatore QTH (partner)", "Localizador QTH (interlocutor)")</td> <td style="font-family:monospace">JN48QN</td></tr>
                                <tr><td><code>{rssi}</code></td>     <td>@Loc.T("RSSI (dBm)",           "RSSI (dBm)",            "RSSI (dBm)",             "RSSI (dBm)")</td>           <td style="font-family:monospace">-85</td></tr>
                                <tr><td><code>{snr}</code></td>      <td>@Loc.T("SNR (dB)",             "SNR (dB)",              "SNR (dB)",               "SNR (dB)")</td>             <td style="font-family:monospace">9.5</td></tr>
                                <tr><td><code>{hw}</code></td>       <td>@Loc.T("Hardware-Name",        "Hardware name",         "Nome hardware",          "Nombre hardware")</td>      <td style="font-family:monospace">T-BEAM</td></tr>
                                <tr><td><code>{route}</code></td>    <td>@Loc.T("Relay-Pfad (leer = direkt)","Relay path (empty = direct)","Percorso relay (vuoto = diretto)","Ruta relay (vacío = directo)")</td> <td style="font-family:monospace">OE1KBC → DB0TAW</td></tr>
                                <tr><td><code>{hops}</code></td>     <td>@Loc.T("Anzahl Relay-Hops (0 = direkt)","Relay hop count (0 = direct)","Numero hop relay (0 = diretto)","Número saltos relay (0 = directo)")</td> <td style="font-family:monospace">1</td></tr>
                                <tr><td><code>{srctype}</code></td>  <td>@Loc.T("Verbindungstyp (roh)","Connection type (raw)","Tipo connessione (raw)","Tipo conexión (raw)")</td> <td style="font-family:monospace">lora</td></tr>
                                <tr><td><code>{srctype-label}</code></td><td>@Loc.T("Verbindungstyp (lesbar)","Connection type (readable)","Tipo connessione (leggibile)","Tipo conexión (legible)")</td><td style="font-family:monospace">LoRa / UDP/Gateway</td></tr>
                                <tr><td><code>{date}</code></td>     <td>@Loc.T("Aktuelles Datum",      "Current date",          "Data corrente",          "Fecha actual")</td>         <td style="font-family:monospace">@now.ToString("dd.MM.yyyy")</td></tr>
                                <tr><td><code>{time}</code></td>     <td>@Loc.T("Aktuelle Uhrzeit",     "Current time",          "Ora corrente",           "Hora actual")</td>          <td style="font-family:monospace">@now.ToString("HH:mm")</td></tr>
                            </tbody>
                        </table>
                        <p style="font-size:11px;color:#8b949e;margin-top:4px">
                            ⚠️ @Loc.T(
                                "{dest-name} und {dest-loc} sind nur verfügbar, wenn das Rufzeichen bereits im QRZ-Cache liegt.",
                                "{dest-name} and {dest-loc} are only available if the callsign is already in the QRZ cache.",
                                "{dest-name} e {dest-loc} sono disponibili solo se il nominativo è già nella cache QRZ.",
                                "{dest-name} y {dest-loc} solo están disponibles si el indicativo ya está en la caché QRZ.")
                        </p>
                    }
                </div>

                <label>@Loc.T("Test-Rufzeichen", "Test Callsign", "Nominativo di test", "Indicativo de prueba")</label>
                <div style="display:flex; gap:8px; align-items:center;">
                    <input type="text" @bind="_autoReplyTestCallsign" placeholder="z.B. DH1FR-2" style="flex:1" />
                    <button class="btn-send-now" @onclick="SendAutoReplyTestAsync" disabled="@(_autoReplySending || string.IsNullOrWhiteSpace(_autoReplyTestCallsign))">
                        @if (_autoReplySending)
                        {
                            <span>⏳ @Loc.T("Wird gesendet…", "Sending…", "Invio in corso…", "Enviando…")</span>
                        }
                        else
                        {
                            <span>📤 @Loc.T("Auto-Reply testen", "Test Auto-Reply", "Testa auto-risposta", "Probar auto-respuesta")</span>
                        }
                    </button>
                </div>
                @if (_autoReplyResult != null)
                {
                    <span></span>
                    <div class="@(_autoReplyResult.StartsWith("✅") ? "settings-success" : "settings-error")" style="margin-top:0">
                                         @_autoReplyResult
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Bot-Befehle / Bot Commands -->
                        <div class="settings-section @(IsOpen("bot") ? "" : "settings-section-collapsed")">
                            <h2 class="settings-section-title" @onclick='() => Toggle("bot")'>🤖 Bot <span class="section-chevron">@(IsOpen("bot") ? "▲" : "▼")</span></h2>
                            <div class="settings-notice" style="background:#1a2535;border-color:#3a5a8a;margin-bottom:0.75rem">
                                ℹ️ @Loc.T(
                                    "Eingehende Direkt-Nachrichten, die mit -- beginnen, werden als Befehle interpretiert. Eingebaut: --version, --time, --mh, --ping, --echo, --help.",
                                    "Incoming direct messages starting with -- are interpreted as commands. Built-in: --version, --time, --mh, --ping, --echo, --help.",
                                    "Messaggi diretti con -- vengono interpretati come comandi. Integrati: --version, --time, --mh, --ping, --echo, --help.",
                                    "Los mensajes directos que comienzan con -- se interpretan como comandos. Integrados: --version, --time, --mh, --ping, --echo, --help.")
                            </div>
                            <div class="settings-grid">
                                <label>@Loc.T("Bot aktiv", "Bot Active", "Bot attivo", "Bot activo")</label>
                                <label class="settings-toggle">
                                    <input type="checkbox" @bind="_model.BotEnabled" />
                                    <span>@(_model.BotEnabled ? Loc.T("Aktiv", "Active", "Attivo", "Activo") : Loc.T("Inaktiv", "Inactive", "Inattivo", "Inactivo"))</span>
                                </label>
                            </div>

                            <div style="margin-top:1rem">
                                <h3 style="font-size:1rem;margin-bottom:0.25rem">@Loc.T("Eigene Befehle", "Custom Commands", "Comandi personalizzati", "Comandos personalizados")</h3>
                                <p style="margin:0 0 0.5rem"><small>@Loc.T(
                                    "Name: Befehlsname ohne -- (z.\u00a0B. info). Antwort: Text oder {Variablen}. Beschreibung: erscheint in --help.",
                                    "Name: command name without -- (e.\u00a0g. info). Response: text or {variables}. Description: shown in --help.",
                                    "Nome: senza -- (es. info). Risposta: testo o {variabili}. Descrizione: mostrata in --help.",
                                    "Nombre: sin -- (p.ej. info). Respuesta: texto o {variables}. Descripción: aparece en --help.")</small>
                                </p>
                                <table class="telemetry-mapping-table">
                                    <thead>
                                        <tr>
                                            <th>@Loc.T("Name (--…)", "Name (--…)", "Nome (--…)", "Nombre (--…)")</th>
                                            <th>@Loc.T("Antwort", "Response", "Risposta", "Respuesta")</th>
                                            <th>@Loc.T("Beschreibung (--help)", "Description (--help)", "Descrizione (--help)", "Descripción (--help)")</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cmd in _model.BotCommands)
                                        {
                                            <tr>
                                                <td><input type="text" @bind="cmd.Name" placeholder="info" style="width:100%;font-family:monospace" /></td>
                                                <td><input type="text" @bind="cmd.Response" placeholder="QTH: Wien, 73 de {mycall}" style="width:100%" /></td>
                                                <td><input type="text" @bind="cmd.Description" placeholder="@Loc.T("Stationsinfo", "Station info", "Info stazione", "Info estación")" style="width:100%" /></td>
                                                <td><button type="button" class="btn-remove" @onclick="() => _model.BotCommands.Remove(cmd)">✕</button></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                                <div style="margin-top:0.5rem;display:flex;align-items:center;gap:0.5rem">
                                    <button type="button" class="btn-add"
                                            @onclick="() => _model.BotCommands.Add(new BotCommandEntry())">
                                        + @Loc.T("Befehl hinzufügen", "Add Command", "Aggiungi comando", "Añadir comando")
                                    </button>
                                    <button type="button" class="btn-add" style="padding:2px 10px;font-size:12px"
                                            @onclick="() => _showBotVars = !_showBotVars">
                                        📋 @(_showBotVars
                                            ? Loc.T("Variablen ausblenden", "Hide Variables", "Nascondi variabili", "Ocultar variables")
                                            : Loc.T("Variablen anzeigen", "Show Variables", "Mostra variabili", "Mostrar variables"))
                                    </button>
                                </div>
                                @if (_showBotVars)
                                {
                                    var ver = System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString(3) ?? "?";
                                    var now = DateTime.Now;
                                    <table class="telemetry-mapping-table" style="margin-top:0.5rem;font-size:12px">
                                        <thead>
                                            <tr>
                                                <th>@Loc.T("Variable", "Variable", "Variabile", "Variable")</th>
                                                <th>@Loc.T("Bedeutung", "Meaning", "Significato", "Significado")</th>
                                                <th>@Loc.T("Beispiel", "Example", "Esempio", "Ejemplo")</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr><td><code>{version}</code></td>  <td>@Loc.T("App-Version",           "App version",       "Versione app",         "Versión app")</td>       <td style="font-family:monospace">@ver</td></tr>
                                            <tr><td><code>{mycall}</code></td>   <td>@Loc.T("Eigenes Rufzeichen",     "Own callsign",      "Nominativo proprio",   "Indicativo propio")</td> <td style="font-family:monospace">@_model.MyCallsign</td></tr>
                                            <tr><td><code>{callsign}</code></td>  <td>@Loc.T("Anrufendes Rufzeichen",       "Caller's callsign",    "Nominativo chiamante",  "Indicativo llamante")</td> <td style="font-family:monospace">OE1KBC-1</td></tr>
                                            <tr><td><code>{mylocator}</code></td>   <td>@Loc.T("Eigener QTH-Locator", "Own QTH Locator", "Locatore QTH proprio", "Localizador QTH propio")</td> <td style="font-family:monospace">JN48QN</td></tr>
                                            <tr><td><code>{dest-name}</code></td><td>@Loc.T("Vorname (QRZ, Anrufer)",    "First name (QRZ, caller)", "Nome (QRZ, chiamante)", "Nombre (QRZ, llamante)")</td><td style="font-family:monospace">Max</td></tr>
                                            <tr><td><code>{dest-loc}</code></td> <td>@Loc.T("Standort (QRZ, Anrufer)",   "Location (QRZ, caller)",   "Luogo (QRZ, chiamante)","Lugar (QRZ, llamante)")</td> <td style="font-family:monospace">Wien</td></tr>
                                            <tr><td><code>{locator}</code></td>   <td>@Loc.T("QTH-Locator (Gesprächspartner)", "QTH Locator (partner)", "Locatore QTH (partner)",   "Localizador QTH (interlocutor)")</td> <td style="font-family:monospace">JN48QN</td></tr>
                                            <tr><td><code>{rssi}</code></td>     <td>@Loc.T("RSSI (dBm)",                "RSSI (dBm)",               "RSSI (dBm)",            "RSSI (dBm)")</td>           <td style="font-family:monospace">-85</td></tr>
                                            <tr><td><code>{snr}</code></td>      <td>@Loc.T("SNR (dB)",               "SNR (dB)",          "SNR (dB)",             "SNR (dB)")</td>          <td style="font-family:monospace">9.5</td></tr>
                                            <tr><td><code>{hw}</code></td>       <td>@Loc.T("Hardware-Name",          "Hardware name",     "Nome hardware",        "Nombre hardware")</td>   <td style="font-family:monospace">T-BEAM</td></tr>
                                            <tr><td><code>{route}</code></td>    <td>@Loc.T("Relay-Pfad",             "Relay path",        "Percorso relay",       "Ruta relay")</td>        <td style="font-family:monospace">OE1KBC → DB0TAW</td></tr>
                                            <tr><td><code>{hops}</code></td>     <td>@Loc.T("Anzahl Relay-Hops",      "Relay hop count",   "Numero hop relay",     "Número saltos")</td>     <td style="font-family:monospace">1</td></tr>
                                            <tr><td><code>{srctype}</code></td>  <td>@Loc.T("Verbindungstyp (roh)",   "Connection type (raw)", "Tipo connessione (raw)", "Tipo conexión (raw)")</td> <td style="font-family:monospace">lora</td></tr>
