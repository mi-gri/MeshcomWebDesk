    private async Task ExportBotCommandsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(
                _model.BotCommands,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            var fn = string.IsNullOrWhiteSpace(_filenameBotCommands) ? "MeshComWebDesk-bot-commands.json" : _filenameBotCommands;
            await JS.InvokeVoidAsync("meshcomChat.downloadJson", fn, json);
        }
        catch (Exception ex) { _importError = $"Export: {ex.Message}"; }
    }

    private async Task ImportBotCommandsAsync(InputFileChangeEventArgs e)
    {
        _importError = null;
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 512 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            if (string.IsNullOrWhiteSpace(json)) return;

            var entries = System.Text.Json.JsonSerializer.Deserialize<List<BotCommandEntry>>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (entries is null)
            {
                _importError = Loc.T("Import fehlgeschlagen: Ungültiges JSON-Format.",
                    "Import failed: invalid JSON format.",
                    "Importazione fallita: formato JSON non valido.",
                    "Importación fallida: formato JSON no válido.");
                return;
            }

            var invalid = entries.Where(e => string.IsNullOrWhiteSpace(e.Name)).ToList();
            if (invalid.Count > 0)
            {
                _importError = Loc.T(
                    $"Import fehlgeschlagen: {invalid.Count} Einträge ohne Name gefunden.",
                    $"Import failed: {invalid.Count} entries without a name.",
                    $"Importazione fallita: {invalid.Count} voci senza nome.",
                    $"Importación fallida: {invalid.Count} entradas sin nombre.");
                return;
            }

            _model.BotCommands = entries;
            await SaveAsync();
        }
        catch (System.Text.Json.JsonException ex)
        {
            _importError = Loc.T(
                $"Import fehlgeschlagen: JSON-Fehler – {ex.Message}",
                $"Import failed: JSON error – {ex.Message}",
                $"Importazione fallita: errore JSON – {ex.Message}",
                $"Importación fallida: error JSON – {ex.Message}");
        }
        catch (Exception ex) { _importError = $"Import: {ex.Message}"; }
    }

