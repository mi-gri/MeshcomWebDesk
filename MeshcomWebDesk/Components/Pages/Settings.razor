                            <tr><td><code>{date}</code></td>      <td>@Loc.T("Aktuelles Datum",          "Current date")</td>            <td style="font-family:monospace">@now.ToString("dd.MM.yyyy")</td></tr>
                            <tr><td><code>{time}</code></td>      <td>@Loc.T("Aktuelle Uhrzeit",         "Current time")</td>             <td style="font-family:monospace">@now.ToString("HH:mm")</td></tr>
                            <tr><td><code>{telemetry}</code></td> <td>@Loc.T("Telemetrie-String (aus JSON-Datei)", "Telemetry string (from JSON file)")</td><td style="font-family:monospace">Temp=22.5°C Hum=60%</td></tr>
                            <tr><td><code>{last-qso}</code></td>  <td>@Loc.T("Letztes QSO mit diesem Rufzeichen", "Last QSO with this callsign")</td><td style="font-family:monospace">@now.ToString("dd.MM.yyyy HH:mm")</td></tr>
                            <tr><td><code>{my-tx-power}</code></td><td>@Loc.T("Sendeleistung der eigenen Station","Own station TX power")</td><td style="font-family:monospace">22 dBm</td></tr>
                            <tr><td><code>{my-eirp}</code></td>    <td>@Loc.T("Effektive Strahlungsleistung (EIRP)","Effective isotropic radiated power (EIRP)")</td><td style="font-family:monospace">23.50 dBm</td></tr>
                            <tr><td><code>{my-antenna}</code></td> <td>@Loc.T("Antennengewinn der eigenen Station","Own station antenna gain")</td><td style="font-family:monospace">2.5 dBi</td></tr>
                            <tr><td><code>{my-antenna-type}</code></td><td>@Loc.T("Antennentyp der eigenen Station","Own station antenna type")</td><td style="font-family:monospace">Dipol</td></tr>
                            <tr><td><code>{my-antenna-height}</code></td><td>@Loc.T("Antennenhöhe der eigenen Station","Own station antenna height")</td><td style="font-family:monospace">10 m</td></tr>
                            <tr><td><code>{my-freq}</code></td>    <td>@Loc.T("Sendefrequenz der eigenen Station","Own station frequency")</td><td style="font-family:monospace">433.175 MHz</td></tr>
                        </tbody>
                    </table>
                </div>
            }
            </div>
            }
        </div>

        <!-- Gruppen-Labels -->
        <div class="settings-section @(IsOpen("grouplabels") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("grouplabels")'>
                🏷️ @Loc.T("Gruppen-Labels", "Group Labels")
                <span class="section-chevron">@(IsOpen("grouplabels") ? "▲" : "▼")</span>
            </h2>
            @if (IsOpen("grouplabels")) {
            <div class="settings-notice" style="background:#1a2535;border-color:#3a5a8a;margin-bottom:0.75rem">
                ℹ️ @Loc.T(
                    "Gruppen-Nummern werden im Chat-Tab mit einem Kurznamen angezeigt. Der vollständige Name erscheint als Tooltip. Quelle: icssw.org/meshcom-grc-gruppen/",
                    "Group numbers are shown with a short label in the chat tab. The full name appears as a tooltip. Source: icssw.org/meshcom-grc-gruppen/")
            </div>
            <div>
                <table class="telemetry-mapping-table">
                    <thead>
                        <tr>
                            <th>@Loc.T("Gruppe", "Group")</th>
                            <th>@Loc.T("Kurzname (Tab)", "Short Label (Tab)")</th>
                            <th>@Loc.T("Vollständiger Name", "Full Name")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var gl in _model.GroupLabels)
                        {
                            <tr>
                                <td><input type="text" @bind="gl.Group" placeholder="262" style="width:90px" /></td>
                                <td><input type="text" @bind="gl.ShortLabel" placeholder="DL" style="width:80px" /></td>
                                <td><input type="text" @bind="gl.Label" placeholder="DL – Deutschland" style="width:100%" /></td>
                                <td><button type="button" class="btn-remove" @onclick="() => _model.GroupLabels.Remove(gl)">✕</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div style="margin-top:0.5rem;display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap">
                    <button type="button" class="btn-add"
                            @onclick="() => _model.GroupLabels.Add(new GroupLabelEntry())">
                        + @Loc.T("Gruppe hinzufügen", "Add Group")
                    </button>
                    <button type="button" class="btn-add" style="padding:2px 10px;font-size:12px"
                            @onclick="() => _model.GroupLabels = GroupLabelEntry.Defaults.Select(g => new GroupLabelEntry { Group = g.Group, ShortLabel = g.ShortLabel, Label = g.Label }).ToList()">
                        🔄 @Loc.T("Standard wiederherstellen", "Restore Defaults")
                    </button>
                    <button type="button" class="btn-add" style="padding:2px 10px;font-size:12px"
                            title="@Loc.T("Ergänzt fehlende Standard-Gruppen, vorhandene Einträge bleiben unverändert.", "Adds missing default groups; existing entries are not changed.")"
                            @onclick="() => { foreach (var d in GroupLabelEntry.Defaults) { if (!_model.GroupLabels.Any(g => g.Group == d.Group)) _model.GroupLabels.Add(new GroupLabelEntry { Group = d.Group, ShortLabel = d.ShortLabel, Label = d.Label }); } }">
                        ➕ @Loc.T("Fehlende ergänzen", "Add Missing")
                    </button>
                    <button type="button" class="btn-add" style="padding:2px 10px;font-size:12px"
                            title="@Loc.T("Alle Gruppen-Labels löschen", "Clear all group labels")"
                            @onclick="() => _model.GroupLabels.Clear()">
                        🗑️ @Loc.T("Liste leeren", "Clear List")
                    </button>
                    <input type="text" @bind="_filenameGroupLabels" style="width:220px;font-size:12px;padding:2px 6px" />
                    <button type="button" class="btn-add" style="padding:2px 10px;font-size:12px" @onclick="ExportGroupLabelsAsync">
                        📤 @Loc.T("Exportieren", "Export")
                    </button>
                    <label class="btn-add" style="padding:2px 10px;font-size:12px;cursor:pointer"
                           title="@Loc.T("JSON-Datei importieren (ersetzt vorhandene Einträge)", "Import JSON file (replaces existing entries)")">
                        📥 @Loc.T("Importieren", "Import")
                        <InputFile accept=".json" style="display:none" OnChange="ImportGroupLabelsAsync" />
                    </label>
                </div>
                @if (_importError != null)
                {
                    <div class="settings-error" style="margin-top:0.4rem">❌ @_importError</div>
                }
            </div>
            }
        </div>

        <!-- KI / QSO-Zusammenfassung -->
        <div class="settings-section @(IsOpen("ai") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("ai")'>
                🤖 @Loc.T("KI / QSO-Zusammenfassung", "AI / QSO Summary")
                <span class="section-chevron">@(IsOpen("ai") ? "▲" : "▼")</span>
            </h2>
            @if (IsOpen("ai")) {
            <div class="settings-grid">
                <label>@Loc.T("Aktiviert", "Enabled")</label>
                <label class="toggle-label">
                    <input type="checkbox" @bind="_model.AiEnabled" />
                    <span>@(_model.AiEnabled ? Loc.T("Aktiv", "Active") : Loc.T("Inaktiv", "Inactive"))</span>
                </label>

                <label>@Loc.T("Anbieter", "Provider")</label>
                <select @bind="_model.AiProvider">
                    <option value="openai">OpenAI (api.openai.com)</option>
                    <option value="grok">Grok / xAI (api.x.ai)</option>
                    <option value="azure">Azure OpenAI (Microsoft)</option>
                </select>

                <label>API Key</label>
                <input type="password" @bind="_model.AiApiKey" autocomplete="new-password"
                       placeholder="@(_model.AiProvider == "grok" ? "xai-..." : _model.AiProvider == "azure" ? "Azure API Key..." : "sk-...")" />

                @if (_model.AiProvider == "azure")
                {
                    <label>@Loc.T("Azure Endpoint", "Azure Endpoint")</label>
                    <input type="text" @bind="_model.AiAzureEndpoint"
                           placeholder="https://mein-name.openai.azure.com" />

                    <label>@Loc.T("API Version", "API Version")</label>
                    <input type="text" @bind="_model.AiAzureApiVersion"
                           placeholder="2024-08-01-preview" />
                }

                <label>@Loc.T("Modell / Deployment", "Model / Deployment")</label>
                @if (_model.AiProvider == "grok")
                {
                    <select @bind="_model.AiModel">
                        <option value="grok-3-mini">grok-3-mini (@Loc.T("empfohlen", "recommended"))</option>
                        <option value="grok-3">grok-3</option>
                    </select>
                }
                else if (_model.AiProvider == "azure")
                {
                    <input type="text" @bind="_model.AiModel"
                           placeholder="@Loc.T("Deployment-Name aus Azure Portal", "Deployment name from Azure Portal")" />
                }
                else
                {
                    <select @bind="_model.AiModel">
                        <option value="auto">🤖 @Loc.T("Automatisch (empfohlen)", "Automatic (recommended)")</option>
                        <option value="gpt-4o-mini">gpt-4o-mini</option>
                        <option value="gpt-4.1-nano">gpt-4.1-nano (@Loc.T("günstig", "budget"))</option>
                        <option value="gpt-4.1-mini">gpt-4.1-mini (@Loc.T("empfohlen für große Suche", "recommended for large search"))</option>
                        <option value="gpt-4.1">gpt-4.1</option>
                        <option value="gpt-4o">gpt-4o</option>
                        <option value="gpt-3.5-turbo">gpt-3.5-turbo</option>
                    </select>
                }

                <label>@Loc.T("Icon-Schwellwert (Tage)", "Icon threshold (days)")</label>
                <div>
                    <input type="number" min="0" max="365" @bind="_model.AiThresholdDays" />
                    <div style="font-size:11px;color:#8b949e;margin-top:2px">@Loc.T("Icon erscheint wenn letztes QSO ≥ X Tage zurück liegt. 0 = immer anzeigen.", "Icon appears when last QSO is ≥ X days ago. 0 = always show.")</div>
                </div>

                <label>@Loc.T("Auswertungszeitraum (Tage)", "Summary period (days)")</label>
                <div>
                    <input type="number" min="0" max="3650" @bind="_model.AiSummaryDays" />
                    <div style="font-size:11px;color:#8b949e;margin-top:2px">@Loc.T("Nachrichten der letzten X Tage werden ausgewertet. 0 = alle verfügbaren.", "Messages from the last X days are evaluated. 0 = all available.")</div>
                </div>

                <label>@Loc.T("Max. Nachrichten", "Max. messages")</label>
                <input type="number" min="10" max="500" @bind="_model.AiMaxMessages" />

                <label>@Loc.T("API-Anfragen loggen", "Log API requests")</label>
                <label class="toggle-label">
                    <input type="checkbox" @bind="_model.AiLogRequests" />
                    <span>@(_model.AiLogRequests ? Loc.T("Aktiv", "Active") : Loc.T("Inaktiv", "Inactive"))</span>
                </label>
            </div>
            @if (_model.AiEnabled && IsOpen("ai"))
            {
                <div class="settings-notice" style="background:#2a1a0a;border-color:#8a5a1a;margin-top:0.75rem">
                    ⚠️ @Loc.T(
                        "Datenschutzhinweis: Beim Generieren einer Zusammenfassung werden Nachrichtentexte an einen externen KI-Dienst gesendet. Bitte stelle sicher, dass alle Gesprächspartner damit einverstanden sind.",
                        "Privacy notice: When generating a summary, message texts are sent to an external AI service. Please ensure all conversation partners consent to this.")
                </div>

                <!-- Token-Statistik -->
                <div style="margin-top:0.75rem">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.4rem">
                        <strong style="font-size:0.92rem">📊 @Loc.T("Token-Verbrauch (seit letztem Start)", "Token usage (since last start)")</strong>
                        <button type="button" class="btn-add" style="padding:2px 8px;font-size:11px" @onclick="RefreshAiUsageStats">🔄</button>
                    </div>
                    @{
                        var usage = _aiUsageStats ?? QsoSummaryService.GetUsageStats();
                    }
                    <div style="display:grid;grid-template-columns:auto 1fr;gap:2px 12px;font-size:0.87rem;color:#c9d1d9;max-width:340px">
                        <span style="color:#8b949e">@Loc.T("Anfragen:", "Requests:")</span>
                        <span>@usage.RequestCount</span>
                        <span style="color:#8b949e">@Loc.T("Prompt-Token:", "Prompt tokens:")</span>
                        <span>@usage.PromptTokens.ToString("N0")</span>
                        <span style="color:#8b949e">@Loc.T("Completion-Token:", "Completion tokens:")</span>
                        <span>@usage.CompletionTokens.ToString("N0")</span>
                        <span style="color:#8b949e">@Loc.T("Gesamt-Token:", "Total tokens:")</span>
                        <span><strong>@usage.TotalTokens.ToString("N0")</strong></span>
                        @if (usage.LastRequestAt.HasValue)
                        {
                            <span style="color:#8b949e">@Loc.T("Letzte Anfrage:", "Last request:")</span>
                            <span>@usage.LastRequestAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
                        }
                    </div>
                </div>

                <!-- Guthaben-Abfrage (nur OpenAI) -->
                @if (_model.AiProvider == "openai")
                {
                    <div style="margin-top:0.75rem;display:flex;flex-direction:column;gap:0.4rem">
                        <div style="display:flex;gap:8px;align-items:center">
                            <button type="button" class="btn-send-now" @onclick="CheckAiBalanceAsync" disabled="@_aiBalanceChecking">
                                @if (_aiBalanceChecking)
                                {
                                    <span>⏳ @Loc.T("Prüfe…", "Checking…")</span>
                                }
                                else
                                {
                                    <span>💰 @Loc.T("Guthaben prüfen", "Check balance")</span>
                                }
                            </button>
                            <small style="color:#8b949e">@Loc.T(
                                "Verbrauch: Projekt-Key reicht. Limit/Restguthaben: User-Key (sk-…) erforderlich.",
                                "Usage: Project Key sufficient. Limit/balance: User Key (sk-…) required.")</small>
                        </div>
                        @if (_aiBalanceResult != null)
                        {
                            <div class="@(_aiBalanceResult.StartsWith("✅") ? "settings-success" : _aiBalanceResult.StartsWith("❌") ? "settings-error" : "settings-notice")" style="margin-top:0">
                                @if (_aiBalanceResult.Contains("https://"))
                                {
                                    var txt = _aiBalanceResult[.._aiBalanceResult.IndexOf("https://")].TrimEnd();
                                    <span>@txt </span>
                                    <a href="https://platform.openai.com/settings/organization/billing/overview" target="_blank" rel="noopener" style="color:#58a6ff">Billing →</a>
                                    <span style="color:#8b949e"> | </span>
                                    <a href="https://platform.openai.com/usage" target="_blank" rel="noopener" style="color:#58a6ff">Usage →</a>
                                }
                                else
                                {
                                    <span>@_aiBalanceResult </span>
                                    <a href="https://platform.openai.com/settings/organization/billing/overview" target="_blank" rel="noopener" style="color:#58a6ff">Billing →</a>
                                    <span style="color:#8b949e"> | </span>
                                    <a href="https://platform.openai.com/usage" target="_blank" rel="noopener" style="color:#58a6ff">Usage →</a>
                                }
                            </div>
                        }
                    </div>
                }

                <div style="margin-top:0.75rem;display:flex;flex-direction:column;gap:0.5rem">
                    <div style="display:flex;gap:8px;align-items:center">
                        <input type="text" @bind="_aiTestCallsign" placeholder="@Loc.T("Rufzeichen z.B. DL6WAB-1", "Callsign e.g. DL6WAB-1")"
                               style="width:180px" />
                        <button type="button" class="btn-send-now" @onclick="TestAiAsync" disabled="@_aiTesting">
                            @if (_aiTesting)
                            {
                                <span>⏳ @Loc.T("Teste...", "Testing...")</span>
                            }
                            else
                            {
                                <span>🔬 @Loc.T("DB + API testen", "Test DB + API")</span>
                            }
                        </button>
                    </div>
                    @if (_aiTestResult != null)
                    {
                        <div class="@(_aiTestResult.StartsWith("✅") ? "settings-success" : "settings-error")" style="margin-top:0.25rem;white-space:pre-wrap">
                            @_aiTestResult
                        </div>
                    }
                </div>
            }
            }
        </div>

        <!-- Datensicherung / Backup & Restore -->
        <div class="settings-section @(IsOpen("backup") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("backup")'>
                🔐 @Loc.T("Datensicherung", "Backup & Restore")
                <span class="section-chevron">@(IsOpen("backup") ? "▲" : "▼")</span>
            </h2>
            @if (IsOpen("backup")) {
            <div class="settings-notice" style="margin-bottom:0.75rem">
                🔒 @Loc.T(
                    "Alle Einstellungen inkl. Passwörter und API-Keys werden AES-256 verschlüsselt gespeichert. Das Passwort wird nirgendwo gespeichert – bei Verlust ist die Datei nicht wiederherstellbar.",
                    "All settings including passwords and API keys are saved AES-256 encrypted. The password is not stored anywhere – if lost, the file cannot be recovered.")
            </div>

            @* Export *@
            <div style="margin-bottom:1rem">
                <h3 style="font-size:0.9rem;margin:0 0 0.5rem;color:#a0c4ff">
                    📤 @Loc.T("Exportieren", "Export")
                </h3>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                    <input type="password" @bind="_backupPassword" autocomplete="new-password"
                           placeholder="@Loc.T("Passwort für Verschlüsselung", "Encryption password")"
                           style="flex:1;min-width:180px" />
                    <input type="text" @bind="_filenameBackup" style="width:220px;font-size:12px;padding:2px 6px" />
                    <button class="btn-action" @onclick="ExportSettingsAsync"
                            disabled="@string.IsNullOrWhiteSpace(_backupPassword)">
                        📤 @Loc.T("Backup erstellen", "Create Backup")
                    </button>
                </div>
            </div>

            @* Import *@
            <div>
                <h3 style="font-size:0.9rem;margin:0 0 0.5rem;color:#a0c4ff">
                    📥 @Loc.T("Importieren", "Import")
                </h3>
                <div class="settings-notice" style="margin-bottom:0.5rem;background:#2b0d0d;border-color:#6e2020;color:#f0a0a0">
                    ⚠️ @Loc.T(
                        "Alle aktuellen Einstellungen werden durch die Backup-Datei ersetzt.",
                        "All current settings will be replaced by the backup file.")
                </div>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                    <input type="password" @bind="_restorePassword" autocomplete="new-password"
                           placeholder="@Loc.T("Passwort der Backup-Datei", "Backup file password")"
                           style="flex:1;min-width:180px" />
                    <label class="btn-action" style="cursor:pointer"
                           title="@Loc.T("MeshComWebDesk-settings.enc öffnen", "Open MeshComWebDesk-settings.enc")">
                        📥 @Loc.T("Backup wiederherstellen", "Restore Backup")
                        <InputFile accept=".enc" style="display:none" OnChange="ImportSettingsAsync" />
                    </label>
                </div>
            </div>

            @if (_backupError != null)
            {
                <div class="settings-error" style="margin-top:0.5rem">❌ @_backupError</div>
            }
            @if (_backupSuccess || _restored)
            {
                <div class="settings-success" style="margin-top:0.5rem">
                    ✅ @Loc.T("Erfolgreich.", "Success.")
                </div>
            }
            }
        </div>

        <div class="settings-actions">
            @if (_saved)
            {
                <div class="settings-success">✅ @Loc.T("Einstellungen gespeichert.", "Settings saved.")</div>
            }
            <button class="btn-save" @onclick="SaveAsync">💾 @Loc.T("Speichern", "Save")</button>
        </div>

    </div>
</div>

@code {
    private FormModel _model = new();
    private bool _saved;
    private bool _restored;
    private string? _errorMessage;
    private bool   _sendingNow;
    private string? _sendResult;
    private string  _autoReplyTestCallsign = string.Empty;
    private bool    _autoReplySending;
    private string? _autoReplyResult;
    private bool    _showAutoReplyVars;
    private bool    _showBotVars;
    private bool    _showQuickTextVars;
    private string  _botTestCommand   = string.Empty;
    private string  _botTestCallsign  = string.Empty;
    private bool    _botTesting;
    private string? _botTestResult;
    private bool    _beaconSending;
    private string? _beaconResult;

    // Weather API
    private bool    _weatherApiLicensed;
    private bool    _weatherApiPolling;
    private string? _weatherApiStatus;

    private DbTestResult? _dbTestResult;
    private bool          _dbTesting;
    private bool          _dbSettingUp;
    private string?       _dbSetupError;

    private bool    _mqttTesting;
    private string? _mqttTestResult;

    // Telnet: unknown cert fingerprint from first-connect
    private string? _telnetUnknownCert;
    private string[] _availableSerialPorts = [];

    private void RefreshSerialPorts()
    {
        _availableSerialPorts = SerialConsoleService.GetAvailablePorts();
        StateHasChanged();
    }

    private bool    _qrzTesting;
    private string? _qrzTestResult;

    private bool    _aiTesting;
    private string? _aiTestResult;
    private string  _aiTestCallsign = string.Empty;
    private bool    _aiBalanceChecking;
    private string? _aiBalanceResult;
    private AiUsageStats? _aiUsageStats;

    private HashSet<string> _openSections = [];
    private bool IsOpen(string id) => _openSections.Contains(id);
    private void Toggle(string id)
    {
        if (!_openSections.Remove(id)) _openSections.Add(id);
        _ = JS.InvokeVoidAsync("meshcomChat.setSettingsSections",
                string.Join(",", _openSections)).AsTask();
    }

    // ── Multi-node helpers ─────────────────────────────────────────────────
    private void AddNode()
    {
        var isFirst = _model.Nodes.Count == 0;
        _model.Nodes.Add(new NodeProfile
        {
            Name       = $"Node {_model.Nodes.Count + 1}",
            Callsign   = _model.MyCallsign,
            DeviceIp   = _model.DeviceIp,
            DevicePort = _model.DevicePort,
            ListenIp   = _model.ListenIp,
            ListenPort = _model.ListenPort + _model.Nodes.Count,
            IsPrimary  = isFirst
        });
    }

    private void RemoveNode(NodeProfile node)
    {
        _model.Nodes.Remove(node);
        // If the removed node was primary, make the first remaining node primary.
        if (node.IsPrimary && _model.Nodes.Count > 0)
            _model.Nodes[0].IsPrimary = true;
    }

    private void SetPrimaryNode(NodeProfile node)
    {
        foreach (var n in _model.Nodes) n.IsPrimary = false;
        node.IsPrimary = true;
    }
    // ──────────────────────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var saved = await JS.InvokeAsync<string?>("meshcomChat.getSettingsSections");
            if (saved is not null)
            {
                _openSections = saved.Length > 0
                    ? new HashSet<string>(saved.Split(',', StringSplitOptions.RemoveEmptyEntries))
                    : [];
                StateHasChanged();
            }
        }
        catch (JSException) { }
    }

    private async Task SendTelemetryNowAsync()
    {
        _sendingNow = true;
        _sendResult = null;
        try
        {
            await UdpService.SendTelemetryNowAsync();
            _sendResult = $"✅ {Loc.T("Telemetrie gesendet.", "Telemetry sent.")}";
        }
        catch (Exception ex)
        {
            _sendResult = $"❌ {Loc.T("Fehler:", "Error:")} {ex.Message}";
        }
        finally
        {
            _sendingNow = false;
        }
    }

    private async Task PollWeatherApiNowAsync()
    {
        _weatherApiPolling = true;
        _weatherApiStatus  = null;
        try
        {
            // Always use the live decrypted API key from IOptionsMonitor so that the correct
            // plaintext key is sent even if the model was loaded before the last save or
            // before a settings.key rotation. All other fields (provider, station, …) come
            // from the form model so the user sees the effect of unsaved changes immediately.
            var liveKey = SettingsMonitor.CurrentValue.WeatherApi.ApiKey;
            var pollSettings = new MeshcomWebDesk.Models.WeatherApiSettings
            {
                Provider            = _model.WeatherApi.Provider,
                StationId           = _model.WeatherApi.StationId,
                PollIntervalMinutes = _model.WeatherApi.PollIntervalMinutes,
                LicenseKey          = _model.WeatherApi.LicenseKey,
                ApiKey              = string.IsNullOrEmpty(_model.WeatherApi.ApiKey)
                                        ? liveKey
                                        : _model.WeatherApi.ApiKey
            };
            await WeatherPollingService.PollAsync(pollSettings, CancellationToken.None);
            _weatherApiLicensed = WeatherPollingService.IsLicensed;
            if (WeatherPollingService.LastData?.Fields is { Count: > 0 } fields)
            {
                var preview = string.Join(" | ", fields.Take(5).Select(kv => $"{kv.Key}={kv.Value:F1}"));
                _weatherApiStatus = $"✅ {Loc.T("Empfangen", "Received")}: {preview}";
            }
            else
            {
                _weatherApiStatus = $"⚠️ {WeatherPollingService.LastError ?? Loc.T("Keine Daten.", "No data.")}";
            }
        }
        catch (Exception ex)
        {
            _weatherApiStatus = $"❌ {ex.Message}";
        }
        finally
        {
            _weatherApiPolling = false;
        }
    }

