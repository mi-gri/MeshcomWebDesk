                <!-- Token-Statistik -->
                <div style="margin-top:0.75rem">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.4rem">
                        <strong style="font-size:0.92rem">📊 @Loc.T("Token-Verbrauch (seit letztem Start)", "Token usage (since last start)", "Utilizzo token (dall'ultimo avvio)", "Uso de tokens (desde último inicio)")</strong>
                        <button type="button" class="btn-add" style="padding:2px 8px;font-size:11px" @onclick="RefreshAiUsageStats">🔄</button>
                    </div>
                    @{
                        var usage = _aiUsageStats ?? QsoSummaryService.GetUsageStats();
                    }
                    <div style="display:grid;grid-template-columns:auto 1fr;gap:2px 12px;font-size:0.87rem;color:#c9d1d9;max-width:340px">
                        <span style="color:#8b949e">@Loc.T("Anfragen:", "Requests:", "Richieste:", "Solicitudes:")</span>
                        <span>@usage.RequestCount</span>
                        <span style="color:#8b949e">@Loc.T("Prompt-Token:", "Prompt tokens:", "Token prompt:", "Tokens de prompt:")</span>
                        <span>@usage.PromptTokens.ToString("N0")</span>
                        <span style="color:#8b949e">@Loc.T("Completion-Token:", "Completion tokens:", "Token completion:", "Tokens de completion:")</span>
                        <span>@usage.CompletionTokens.ToString("N0")</span>
                        <span style="color:#8b949e">@Loc.T("Gesamt-Token:", "Total tokens:", "Token totali:", "Tokens totales:")</span>
