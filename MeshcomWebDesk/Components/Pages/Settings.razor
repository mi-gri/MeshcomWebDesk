    private List<TelemetryPreviewRow>? _telemetryPreview;
    private List<string>? _telemetryMessages;
    private string? _telemetryPreviewError;

    private sealed record TelemetryPreviewRow(string Key, string RawValue, string Formatted, bool IsWarning);

    private async Task LoadTelemetryPreviewAsync()
    {
        _telemetryPreview      = null;
        _telemetryMessages     = null;
        _telemetryPreviewError = null;

        var filePath = _model.TelemetryFilePath;
        if (string.IsNullOrWhiteSpace(filePath))
        {
            _telemetryPreviewError = Loc.T("Kein Dateipfad konfiguriert.", "No file path configured.");
            return;
        }
        if (!File.Exists(filePath))
        {
            _telemetryPreviewError = Loc.T($"Datei nicht gefunden: {filePath}", $"File not found: {filePath}");
            return;
        }

        try
        {
            var content = await File.ReadAllTextAsync(filePath);
            using var doc = System.Text.Json.JsonDocument.Parse(content);
            var root = doc.RootElement;

            var rows  = new List<TelemetryPreviewRow>();
            var parts = new List<string>();

            // Build a lookup of configured mapping entries by JsonKey for quick access
            var mappingLookup = _model.TelemetryMapping
                .Where(m => !string.IsNullOrWhiteSpace(m.JsonKey))
                .ToDictionary(m => m.JsonKey, m => m);

            // Iterate over ALL keys in the JSON file
            foreach (var jsonProp in root.EnumerateObject())
            {
                var jsonKey = jsonProp.Name;
                var valueProp = jsonProp.Value;

                double value;
                if (valueProp.ValueKind == System.Text.Json.JsonValueKind.Number)
                    value = valueProp.GetDouble();
                else if (valueProp.ValueKind == System.Text.Json.JsonValueKind.String &&
                         double.TryParse(valueProp.GetString(),
                             System.Globalization.NumberStyles.Float,
                             System.Globalization.CultureInfo.InvariantCulture, out var parsed))
                    value = parsed;
                else
                {
                    rows.Add(new(jsonKey, valueProp.ToString(), Loc.T("⚠️ Kein Zahlenwert", "⚠️ Not a numeric value"), true));
                    continue;
                }

                // Use configured mapping if available, otherwise show raw key/value
                mappingLookup.TryGetValue(jsonKey, out var entry);
                var decimals  = entry != null ? Math.Max(0, entry.Decimals) : 1;
                var formatted = value.ToString($"F{decimals}", System.Globalization.CultureInfo.InvariantCulture);
                var label     = entry != null && !string.IsNullOrWhiteSpace(entry.Label) ? entry.Label : jsonKey;
                var unit      = entry?.Unit ?? string.Empty;
                var part      = $"{label}={formatted}{unit}";
                // Mark rows that have no mapping configured
                var isWarning = entry == null;
                rows.Add(new(jsonKey, value.ToString(System.Globalization.CultureInfo.InvariantCulture), isWarning ? $"⚠️ {part}" : part, isWarning));
                if (!isWarning) parts.Add(part);
            }

            // Additionally report configured keys that are missing in the file
            foreach (var entry in _model.TelemetryMapping.Where(m => !string.IsNullOrWhiteSpace(m.JsonKey)))
            {
                if (!root.TryGetProperty(entry.JsonKey, out _))
                    rows.Add(new(entry.JsonKey, "–", Loc.T("⚠️ Key nicht in Datei", "⚠️ Key not found in file"), true));
            }

            _telemetryPreview = rows;

            // Build message buckets (same logic as MeshcomUdpService)
            const int MaxMsg    = 150;
            const int PrefixMax = 11; // longest prefix e.g. "JN48qn/99:"
            const int BucketLen = MaxMsg - PrefixMax;
            var buckets = new List<string>();
            var current = new System.Text.StringBuilder();
            foreach (var part in parts)
            {
                var sep = current.Length == 0 ? string.Empty : " ";
                if (current.Length + sep.Length + part.Length > BucketLen)
                {
                    if (current.Length > 0) buckets.Add(current.ToString());
                    current.Clear();
                }
                if (current.Length > 0) current.Append(' ');
                current.Append(part);
            }
            if (current.Length > 0) buckets.Add(current.ToString());

            var ownStatus = UdpService.Status;
            var locator   = (ownStatus.OwnLatitude.HasValue && ownStatus.OwnLongitude.HasValue)
                ? MeshcomWebDesk.Helpers.GeoHelper.ToMaidenhead(ownStatus.OwnLatitude.Value, ownStatus.OwnLongitude.Value)
                : null;

            _telemetryMessages = buckets
                .Select((b, i) => buckets.Count == 1
                    ? $"{locator ?? "TM"}: {b}"
                    : $"{locator ?? "TM"}/{i + 1}: {b}")
                .ToList();
        }
        catch (Exception ex)
        {
            _telemetryPreviewError = Loc.T($"Fehler: {ex.Message}", $"Error: {ex.Message}");
        }
    }

