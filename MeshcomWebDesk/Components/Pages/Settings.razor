                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (entries is null)
            {
                _importError = Loc.T("Import fehlgeschlagen: Ungültiges JSON-Format.",
                    "Import failed: invalid JSON format.",
                    "Importazione fallita: formato JSON non valido.",
                    "Importación fallida: formato JSON no válido.");
                return;
            }

            var invalid = entries.Where(e => string.IsNullOrWhiteSpace(e.Group)).ToList();
            if (invalid.Count > 0)
            {
                _importError = Loc.T(
                    $"Import fehlgeschlagen: {invalid.Count} Einträge ohne Gruppen-Nummer gefunden.",
                    $"Import failed: {invalid.Count} entries without a group number.",
                    $"Importazione fallita: {invalid.Count} voci senza numero gruppo.",
                    $"Importación fallida: {invalid.Count} entradas sin número de grupo.");
                return;
            }

            _model.GroupLabels = entries;
            await SaveAsync();
        }
        catch (System.Text.Json.JsonException ex)
        {
            _importError = Loc.T(
                $"Import fehlgeschlagen: JSON-Fehler – {ex.Message}",
                $"Import failed: JSON error – {ex.Message}",
                $"Importazione fallita: errore JSON – {ex.Message}",
                $"Importación fallida: error JSON – {ex.Message}");
        }
        catch (Exception ex) { _importError = $"Import: {ex.Message}"; }
    }

