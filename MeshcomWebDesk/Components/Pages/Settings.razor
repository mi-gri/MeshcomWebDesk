                            <tr><td><code>{snr}</code></td>       <td>@Loc.T("SNR (letzter Empfang)",    "SNR (last RX)",        "SNR (ultima RX)",          "SNR (última RX)")</td>        <td style="font-family:monospace">6.5</td></tr>
                            <tr><td><code>{hw}</code></td>        <td>@Loc.T("Hardware-Typ",             "Hardware type",        "Tipo hardware",            "Tipo hardware")</td>           <td style="font-family:monospace">T-Beam</td></tr>
                            <tr><td><code>{route}</code></td>     <td>@Loc.T("Relay-Pfad",               "Relay path",           "Percorso relay",           "Ruta relay")</td>              <td style="font-family:monospace">OE1KBC → DB0TAW</td></tr>
                            <tr><td><code>{hops}</code></td>      <td>@Loc.T("Anzahl Relay-Hops",        "Relay hop count",      "Numero hop relay",         "Número saltos")</td>           <td style="font-family:monospace">1</td></tr>
                            <tr><td><code>{version}</code></td>   <td>@Loc.T("App-Version",              "App version",          "Versione app",             "Versión app")</td>             <td style="font-family:monospace">1.0.0</td></tr>
                            <tr><td><code>{date}</code></td>      <td>@Loc.T("Aktuelles Datum",          "Current date",         "Data corrente",            "Fecha actual")</td>            <td style="font-family:monospace">@now.ToString("dd.MM.yyyy")</td></tr>
                            <tr><td><code>{time}</code></td>      <td>@Loc.T("Aktuelle Uhrzeit",         "Current time",         "Ora corrente",             "Hora actual")</td>             <td style="font-family:monospace">@now.ToString("HH:mm")</td></tr>
                        </tbody>
                    </table>
                </div>
            }
            </div>
            }
        </div>

        <!-- Gruppen-Labels -->
        <div class="settings-section @(IsOpen("grouplabels") ? "" : "settings-section-collapsed")">
            <h2 class="settings-section-title" @onclick='() => Toggle("grouplabels")'>
                🏷️ @Loc.T("Gruppen-Labels", "Group Labels", "Etichette Gruppo", "Etiquetas de Grupo")
                <span class="section-chevron">@(IsOpen("grouplabels") ? "▲" : "▼")</span>
            </h2>
            @if (IsOpen("grouplabels")) {
            <div class="settings-notice" style="background:#1a2535;border-color:#3a5a8a;margin-bottom:0.75rem">
                ℹ️ @Loc.T(
                    "Gruppen-Nummern werden im Chat-Tab mit einem Kurznamen angezeigt. Der vollständige Name erscheint als Tooltip. Quelle: icssw.org/meshcom-grc-gruppen/",
                    "Group numbers are shown with a short label in the chat tab. The full name appears as a tooltip. Source: icssw.org/meshcom-grc-gruppen/",
