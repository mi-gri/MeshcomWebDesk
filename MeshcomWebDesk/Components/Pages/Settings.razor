                                            <option value="wind_dir">wind_dir (@Loc.T("Windrichtung", "Wind direction"))</option>
                                            <option value="rain_rate">rain_rate (@Loc.T("Regenrate", "Rain rate"))</option>
                                            <option value="rain_day">rain_day (@Loc.T("Regen heute", "Rain today"))</option>
