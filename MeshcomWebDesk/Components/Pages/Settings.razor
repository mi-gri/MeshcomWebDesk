                                    }
                                    else
                                    {
                                        <span>✅ @Loc.T("Ja, anlegen", "Yes, create")</span>
                                    }
                                </button>
                                <button type="button" class="btn-remove" @onclick="ResetDbTestState">
                                    @Loc.T("Abbrechen", "Cancel")
                                </button>
                            </div>
                            @if (_dbSetupError != null)
                            {
                                <div class="settings-error" style="margin-top:0.5rem">❌ @_dbSetupError</div>
                            }
                        </div>
                    }
                }
            }
            }
