@page "/about"
@rendermode InteractiveServer
@using System.Reflection
@inject MeshcomWebDesk.Services.LanguageService Loc
@implements IDisposable

<PageTitle>@Loc.T("Über", "About") – MeshCom WebDesk</PageTitle>

<div class="about-page">
    <div class="about-card">
        <div class="about-icon">📡</div>
        <h1 class="about-title">MeshCom WebDesk</h1>
        <p class="about-tagline">Blazor Server &nbsp;·&nbsp; .NET 10</p>
        <p class="about-version">v@_version</p>

        <div class="about-divider"></div>

        <p class="about-copyright">
            &copy; by Ralf Altenbrand (DH1FR) &nbsp;
        </p>
        <p class="about-email">
            <a class="about-link" href="mailto:dh1fr@darc.de">✉️ dh1fr@darc.de</a>
        </p>

        <p class="about-description">
            @Loc.T("Webbasierter Client für die Kommunikation mit MeshCom-Nodes", "Web-based client for communicating with MeshCom nodes")<br />
            @Loc.T("über das EXTUDP JSON-Protokoll.", "via the EXTUDP JSON protocol.")<br />
            @Loc.T("Empfangen und senden von LoRa-Nachrichten direkt im Browser.", "Receive and send LoRa messages directly in the browser.")
        </p>

        <div class="about-divider"></div>

        <p class="about-build">
            🔨 Build &nbsp;<span class="about-build-date">@_buildDate</span>
        </p>

        <div class="about-links">
            <a class="about-link" href="https://github.com/DH1FR/MeshcomWebDesk" target="_blank">
                🔗 GitHub Repository
            </a>
            <a class="about-link" href="https://icssw.org/meshcom/" target="_blank">
                🌐 MeshCom Projekt
            </a>
        </div>

        <div class="about-divider"></div>

        <div class="about-coffee">
            <p class="about-coffee-text">
                💛 @Loc.T(
                    "Gefällt dir meine Arbeit? Unterstütze mich per PayPal!",
                    "Do you like my work? Support me via PayPal!")
            </p>
            <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap">
                <a class="about-coffee-btn" href="https://paypal.me/DH1FR" target="_blank" rel="noopener" style="background:#003087;border-color:#003087">
                    💳 PayPal · paypal.me/DH1FR
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    private void OnLocChange() => _ = InvokeAsync(StateHasChanged);

    protected override void OnInitialized() => Loc.OnChange += OnLocChange;
    public void Dispose() => Loc.OnChange -= OnLocChange;

    private static readonly string _version =
        typeof(About).Assembly.GetName().Version is { } v
            ? $"{v.Major}.{v.Minor}.{v.Build}"
            : "–";

    private static readonly string _buildDate =
        typeof(About).Assembly
            .GetCustomAttributes<AssemblyMetadataAttribute>()
            .FirstOrDefault(a => a.Key == "BuildDate")?.Value
        ?? "–";
}
