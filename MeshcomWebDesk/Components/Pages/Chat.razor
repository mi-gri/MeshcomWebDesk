        _showNewTabInput = true;
        _newTabCallsign = string.Empty;
    }

    private void CreateNewTab()
    {
        if (string.IsNullOrWhiteSpace(_newTabCallsign))
            return;

        var key = _newTabCallsign.Trim().ToUpperInvariant();
        ChatService.OpenTab(key);
        _activeTabKey = key;
        _activeTab = ChatService.GetTab(key);
        _showNewTabInput = false;
        _newTabCallsign = string.Empty;
        RefreshData();
    }

    private void OpenTabFromMonitor(string callsign)
    {
        var key = callsign.Trim().ToUpperInvariant();
        ChatService.OpenTab(key);
        SelectTab(key);
        RefreshData();
    }

    private void OnNewTabKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            CreateNewTab();
        else if (e.Key == "Escape")
            _showNewTabInput = false;
    }

    private async Task HandleSendMessage(string text)
    {
        if (_activeTab == null) return;
        // Strip leading '#' for group tabs – the node uses the raw group number (e.g. "262"),
        // the '#' is an internal UI convention only.
        // When destination is broadcast ("*"), also route the outgoing message to the "*" tab
        // so it appears together with incoming broadcasts instead of creating a separate tab.
        var isBroadcast = _activeTab.Key == "*" || _activeTab.Key.TrimStart('#').Equals("alle", StringComparison.OrdinalIgnoreCase);
        var destination = isBroadcast ? "*" : _activeTab.Key.TrimStart('#');
        var tabKey = isBroadcast ? "*" : _activeTab.Key;
        await UdpService.SendMessageAsync(destination, text, tabKey);
    }

    /// <summary>Formats a message destination for display in the monitor.
    /// Pure numbers are treated as group numbers and get a '#' prefix.
    /// Broadcast (*) and callsigns are returned as-is.</summary>
    private static string FormatDest(string to)
    {
        if (string.IsNullOrEmpty(to) || to == "*") return to;
        if (to.StartsWith('#')) return to;
        if (to.All(char.IsDigit)) return "#" + to;
        return to;
    }

    private string QrzSuffix(string callsign)
    {
        if (!SettingsOptions.Value.Qrz.Enabled) return string.Empty;
        if (!_qrzData.TryGetValue(callsign, out var info) || info is null) return string.Empty;
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(info.FirstName)) parts.Add(info.FirstName);
        if (!string.IsNullOrEmpty(info.Location))  parts.Add(info.Location);
        return parts.Count > 0 ? " · " + string.Join(", ", parts) : string.Empty;
    }

    private string? QrzFirstName(string callsign)
    {
        if (!SettingsOptions.Value.Qrz.Enabled) return null;
        var fn = _qrzData.GetValueOrDefault(callsign)?.FirstName;
        return string.IsNullOrEmpty(fn) ? null : fn;
    }

    private async Task<bool> LoadQrzDataAsync()
    {
        if (!SettingsOptions.Value.Qrz.Enabled) return false;
        var added = false;
        var callsigns = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var m in _allMessages)
        {
            if (!string.IsNullOrEmpty(m.From) && !m.From.StartsWith('#') && m.From != "*") callsigns.Add(m.From);
            if (!string.IsNullOrEmpty(m.To)   && !m.To.StartsWith('#')   && m.To   != "*") callsigns.Add(m.To);
        }
        foreach (var t in _tabs)
            if (t.Key != "*" && !t.Key.StartsWith('#')) callsigns.Add(t.Key);
        foreach (var cs in callsigns)
        {
            if (_qrzData.ContainsKey(cs)) continue;
            if (QrzService.TryGetCached(cs, out var cached))
                _qrzData[cs] = cached;          // already known – sync, no log entry
            else
            {
                _qrzData[cs] = await QrzService.LookupAsync(cs);   // new callsign, may hit API
                added = true;
            }
        }
        return added;
    }

    public void Dispose()
    {
        _disposed = true;
        _dotNetRef?.Dispose();
        Loc.OnChange -= StateHasChanged;
        ChatService.OnChange -= OnChatChanged;
        UdpService.OnStatusChange -= OnStatusChanged;
        ChatService.OnWatchlistHit -= HandleWatchlistHit;
    }

    private void ApplyTabOrder()
    {
        if (_tabOrder.Count == 0) return;
        _tabs = _tabs
            .OrderBy(t =>
            {
                var idx = _tabOrder.IndexOf(t.Key);
                return idx < 0 ? int.MaxValue : idx;
            })
            .ToList();
    }

    [JSInvokable]
    public void MoveTab(string fromKey, string toKey)
    {
        if (string.IsNullOrEmpty(fromKey) || string.IsNullOrEmpty(toKey) || fromKey == toKey)
            return;
        var fromIdx = _tabs.FindIndex(t => t.Key == fromKey);
        var toIdx   = _tabs.FindIndex(t => t.Key == toKey);
        if (fromIdx < 0 || toIdx < 0) return;
        var tab = _tabs[fromIdx];
        _tabs.RemoveAt(fromIdx);
        _tabs.Insert(toIdx, tab);
        _tabOrder = _tabs.Select(t => t.Key).ToList();
        _ = JS.InvokeVoidAsync("meshcomChat.setTabOrder", _tabOrder).AsTask();
        StateHasChanged();
    }

    private async void HandleWatchlistHit(string callsign, MeshcomMessage message)
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                var eventType = message.IsPositionBeacon ? "POS" : message.IsTelemetry ? "TEL" : message.IsAck ? "ACK" : "MSG";
                var existing = _watchlistAlerts.FirstOrDefault(a =>
                    string.Equals(a.Callsign, callsign, StringComparison.OrdinalIgnoreCase));
                if (existing is not null)
                    _watchlistAlerts.Remove(existing);
                _watchlistAlerts.Insert(0, new WatchlistAlert(callsign, eventType, DateTime.Now));
                if (_soundEnabled)
                    _playWatchlistSound = true;
                StateHasChanged();
            });
            await Task.Delay(TimeSpan.FromSeconds(Math.Max(1, SettingsOptions.Value.WatchAlertMinutes) * 60 + 2));
            if (!_disposed)
                await InvokeAsync(() =>
                {
                    var limit = Math.Max(1, SettingsOptions.Value.WatchAlertMinutes);
                    _watchlistAlerts.RemoveAll(a => (DateTime.Now - a.Time).TotalMinutes > limit);
                    StateHasChanged();
                });
        }
        catch (Exception) { }
    }

    private string FormatAlertAge(DateTime t)
    {
        var s = (int)(DateTime.Now - t).TotalSeconds;
        return s < 60
            ? Loc.T($"vor {s}\u00a0s", $"{s}\u00a0s ago", $"{s}\u00a0s fa", $"hace {s}\u00a0s")
            : Loc.T($"vor {s / 60}\u00a0min", $"{s / 60}\u00a0min ago", $"{s / 60}\u00a0min fa", $"hace {s / 60}\u00a0min");
    }

