    private static string MonType(MeshcomMessage m)
    {
        if (m.IsTimeSync)                  return "SYS";
        if (m.IsTelemetry)                 return "TEL";
        if (m.IsPositionBeacon)            return "POS";
        if (m.IsAck)                       return "ACK";
        if (m.IsOutgoing)                  return "MSG";
        if (!string.IsNullOrEmpty(m.From)) return "MSG";
        return "SYS";
    }

    private static string MonBadgeClass(MeshcomMessage m) => MonType(m) switch
    {
        "TEL" => "badge-tel",
        "POS" => "badge-pos",
        "ACK" => "badge-ack",
        "MSG" when m.IsOutgoing => "badge-tx",
        "MSG" => "badge-msg",
        _ => "badge-sys"
    };

    private static string MonRowClass(MeshcomMessage m) =>
        m.IsOutgoing ? "mon-row-tx" :
        m.IsTimeSync ? "mon-row-sys" :
        m.IsTelemetry ? "mon-row-tele" :
        m.IsPositionBeacon ? "mon-row-pos" :
        m.IsAck ? "mon-row-ack" :
        !string.IsNullOrEmpty(m.From) ? "mon-row-msg" :
        "mon-row-sys";

    private static readonly Regex UrlRegex = new(
        @"https?://[^\s<>""'\]\)\[]{1,2000}",
        RegexOptions.Compiled | RegexOptions.IgnoreCase);

    private MarkupString FormatMessageWithLinks(string text)
    {
        if (string.IsNullOrEmpty(text) || !text.Contains("://"))
            return new MarkupString(System.Net.WebUtility.HtmlEncode(text));

        var confirmMsg = System.Net.WebUtility.HtmlEncode(Loc.T(
            "Externer Link – diese Seite wird außerhalb von MeshCom WebDesk geöffnet.\nFortfahren?",
            "External link – this page opens outside MeshCom WebDesk.\nContinue?",
            "Link esterno – questa pagina si aprirà fuori da MeshCom WebDesk.\nContinuare?",
            "Enlace externo – esta página se abrirá fuera de MeshCom WebDesk.\n¿Continuar?"));

        var sb = new System.Text.StringBuilder();
        var lastIndex = 0;
        foreach (Match match in UrlRegex.Matches(text))
        {
            sb.Append(System.Net.WebUtility.HtmlEncode(text[lastIndex..match.Index]));
            var href    = System.Net.WebUtility.HtmlEncode(match.Value);
            var display = System.Net.WebUtility.HtmlEncode(
                match.Value.Length > 55 ? match.Value[..55] + "\u2026" : match.Value);
            sb.Append($"<a class=\"msg-url\" href=\"{href}\" data-ext-url=\"{href}\" data-ext-msg=\"{confirmMsg}\" target=\"_blank\" rel=\"noopener noreferrer\">{display}</a>");
            lastIndex = match.Index + match.Length;
        }
        sb.Append(System.Net.WebUtility.HtmlEncode(text[lastIndex..]));
        return new MarkupString(sb.ToString());
    }

    private static string MonTruncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    private string MonDistance(MeshcomMessage m)
    {
        if (!_status.OwnLatitude.HasValue || !_status.OwnLongitude.HasValue ||
            !m.Latitude.HasValue || !m.Longitude.HasValue)
            return string.Empty;

        var km = GeoHelper.CalculateDistanceKm(
            _status.OwnLatitude.Value, _status.OwnLongitude.Value,
            m.Latitude.Value, m.Longitude.Value);
        return GeoHelper.FormatDistance(km);
    }

