    private void ApplyTabOrder()
    {
        if (_tabOrder.Count == 0) return;
        _tabs = _tabs
            .OrderBy(t =>
            {
                var idx = _tabOrder.IndexOf(t.Key);
                return idx < 0 ? int.MaxValue : idx;
            })
            .ToList();
    }

    [JSInvokable]
    public void MoveTab(string fromKey, string toKey)
    {
        if (string.IsNullOrEmpty(fromKey) || string.IsNullOrEmpty(toKey) || fromKey == toKey)
            return;
        var fromIdx = _tabs.FindIndex(t => t.Key == fromKey);
        var toIdx   = _tabs.FindIndex(t => t.Key == toKey);
        if (fromIdx < 0 || toIdx < 0) return;
        var tab = _tabs[fromIdx];
        _tabs.RemoveAt(fromIdx);
        _tabs.Insert(toIdx, tab);
        _tabOrder = _tabs.Select(t => t.Key).ToList();
        _ = JS.InvokeVoidAsync("meshcomChat.setTabOrder", _tabOrder).AsTask();
        StateHasChanged();
    }

    private async void HandleWatchlistHit(string callsign, MeshcomMessage message)
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                var eventType = message.IsPositionBeacon ? "POS" : message.IsTelemetry ? "TEL" : message.IsAck ? "ACK" : "MSG";
                var existing = _watchlistAlerts.FirstOrDefault(a =>
                    string.Equals(a.Callsign, callsign, StringComparison.OrdinalIgnoreCase));
                if (existing is not null)
                    _watchlistAlerts.Remove(existing);
                _watchlistAlerts.Insert(0, new WatchlistAlert(callsign, eventType, DateTime.Now));
                if (_soundEnabled)
                    _playWatchlistSound = true;
                if (_voiceEnabled == true)
                {
                    // Wenn die Nachricht eine direkte MSG ans eigene Rufzeichen ist, hat die
                    // "Neue Nachricht von …"-Ansage (HandleNewDirectTab / HandleDirectMessage) Vorrang.
                    // Die Watchlist-TTS wird in diesem Fall unterdrückt.
                    bool isDirectMsg = !message.IsPositionBeacon && !message.IsTelemetry && !message.IsAck
                        && string.Equals(message.To, _myCallsign, StringComparison.OrdinalIgnoreCase);
                    if (!isDirectMsg)
                    {
                        var phonetic = PhoneticAlphabetHelper.Spell(callsign, Loc.Current);
                        _pendingSpeech.Enqueue(Loc.T(
                            $"{phonetic} ist aktiv",
                            $"{phonetic} heard",
                            $"{phonetic} ascoltato",
                            $"{phonetic} escuchado"));
                    }
                }
                StateHasChanged();
            });
            await Task.Delay(TimeSpan.FromSeconds(Math.Max(1, SettingsOptions.CurrentValue.WatchAlertMinutes) * 60 + 2));
            if (!_disposed)
                await InvokeAsync(() =>
                {
                    var limit = Math.Max(1, SettingsOptions.CurrentValue.WatchAlertMinutes);
                    _watchlistAlerts.RemoveAll(a => (DateTime.Now - a.Time).TotalMinutes > limit);
                    StateHasChanged();
                });
        }
        catch (Exception) { }
    }

    private async void HandleCqHeard(string callsign, string group, string text)
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                var existing = _cqAlerts.FirstOrDefault(a =>
                    string.Equals(a.Callsign, callsign, StringComparison.OrdinalIgnoreCase)
                    && a.Group == group);
                if (existing is not null)
                    _cqAlerts.Remove(existing);
                _cqAlerts.Insert(0, new CqAlert(callsign, group, DateTime.Now));
                if (_soundEnabled)
                    _playCqSound = true;
                if (_voiceEnabled == true)
                {
                    var phonetic = PhoneticAlphabetHelper.Spell(callsign, Loc.Current);
                    var groupSpelled = string.Join(" ", group.ToCharArray());
                    _pendingSpeech.Enqueue(Loc.T(
                        $"C Q C Q von {phonetic} in Gruppe {groupSpelled}",
                        $"C Q C Q from {phonetic} in group {groupSpelled}",
                        $"C Q C Q da {phonetic} nel gruppo {groupSpelled}",
                        $"C Q C Q de {phonetic} en grupo {groupSpelled}"));
                }
                StateHasChanged();
            });
            await Task.Delay(TimeSpan.FromSeconds(62));
            if (!_disposed)
                await InvokeAsync(() =>
                {
                    _cqAlerts.RemoveAll(a => (DateTime.Now - a.Time).TotalSeconds > 60);
                    StateHasChanged();
                });
        }
        catch (Exception) { }
    }

    private string FormatRecentTime(DateTime t)
    {
        var local = LT(t);
        var diff  = DateTime.Now - local;
        if (diff.TotalMinutes < 60)
            return Loc.T($"vor {(int)diff.TotalMinutes} min", $"{(int)diff.TotalMinutes} min ago", $"{(int)diff.TotalMinutes} min fa", $"hace {(int)diff.TotalMinutes} min");
        if (diff.TotalHours < 24)
            return Loc.T($"vor {(int)diff.TotalHours} h", $"{(int)diff.TotalHours} h ago", $"{(int)diff.TotalHours} h fa", $"hace {(int)diff.TotalHours} h");
        if (diff.TotalDays < 7)
            return Loc.T($"vor {(int)diff.TotalDays} d", $"{(int)diff.TotalDays} d ago", $"{(int)diff.TotalDays} g fa", $"hace {(int)diff.TotalDays} d");
        return local.ToString("dd.MM.yy");
    }

    private string FormatAlertAge(DateTime t)
    {
        var s = (int)(DateTime.Now - t).TotalSeconds;
        return s < 60
            ? Loc.T($"vor {s}\u00a0s", $"{s}\u00a0s ago", $"{s}\u00a0s fa", $"hace {s}\u00a0s")
            : Loc.T($"vor {s / 60}\u00a0min", $"{s / 60}\u00a0min ago", $"{s / 60}\u00a0min fa", $"hace {s / 60}\u00a0min");
    }

