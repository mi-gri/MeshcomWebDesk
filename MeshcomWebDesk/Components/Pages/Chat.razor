    private MarkupString HighlightText(string text, string? filter)
    {
        if (string.IsNullOrWhiteSpace(filter)) return new MarkupString(System.Net.WebUtility.HtmlEncode(text));
        var encoded = System.Net.WebUtility.HtmlEncode(text);
        var encodedFilter = System.Net.WebUtility.HtmlEncode(filter);
        var highlighted = System.Text.RegularExpressions.Regex.Replace(
            encoded, System.Text.RegularExpressions.Regex.Escape(encodedFilter),
            m => $"<mark class='hist-highlight'>{m.Value}</mark>",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return new MarkupString(highlighted);
    }

