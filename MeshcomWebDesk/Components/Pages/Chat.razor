    /// <summary>
    /// Lightweight handler for node-echo timeouts – only re-renders the current
    /// message list without a full RefreshData() to avoid disturbing the TX cooldown timer.
    /// </summary>
    private async void OnEchoTimeout()
    {
        if (_disposed) return;
        try
        {
            if (!string.IsNullOrEmpty(_activeTabKey))
                _activeTabMessages = ChatService.GetTabMessages(_activeTabKey, _activeNodeId);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception) { }
