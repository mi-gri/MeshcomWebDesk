@page "/"
@using MeshcomWebDesk.Models
@using MeshcomWebDesk.Services
@using MeshcomWebDesk.Helpers
@using Microsoft.Extensions.Options
@using System.Text.RegularExpressions
@rendermode InteractiveServer
@using MeshcomWebDesk.Services.Database
@inject ChatService ChatService
@inject MeshcomUdpService UdpService
@inject ILogger<Chat> Logger
@inject LanguageService Loc
@inject QrzService QrzService
@inject MqttService MqttService
@inject MonitorSinkService MonitorSink
@inject MeshcomWebDesk.Services.QsoSummaryService QsoSummaryService
@inject TelnetService TelnetService
@inject SerialConsoleService SerialConsoleService
@inject HmacConsoleService HmacConsoleService
@inject NodeManager NodeManager
@implements IDisposable

<PageTitle>MeshCom Web Client</PageTitle>

<ErrorBoundary>
    <ChildContent>
<div class="meshcom-container">
    @* ===== NODE SWITCHER (only when multi-node is enabled) ===== *@
    @if (NodeManager.MultiNodeEnabled) {
    <div class="node-switcher-bar">
        @foreach (var node in NodeManager.Nodes) {
            var status   = NodeManager.GetNodeStatus(node.Id);
            var dotClass = status switch {
                NodeOnlineStatus.Online  => "online",
                NodeOnlineStatus.Stale   => "stale",
                NodeOnlineStatus.Offline => "offline",
                _                        => "unknown"
            };
            var lastSeen = NodeManager.GetLastSeen(node.Id);
            var tooltip  = lastSeen.HasValue
                ? $"{node.Callsign}  |  {node.DeviceIp}:{node.DevicePort}  |  {Loc.T("Zuletzt", "Last seen")}: {FormatLastSeen(lastSeen.Value)}"
                : $"{node.Callsign}  |  {node.DeviceIp}:{node.DevicePort}  |  {Loc.T("Noch kein Paket", "No packet yet")}";
            <button class="node-switcher-btn @(NodeManager.SelectedNode?.Id == node.Id ? "active" : "")"
                    @onclick="() => SelectNode(node.Id)"
                    title="@tooltip">
                <span class="node-status-dot @dotClass"></span>
                @if (node.IsPrimary) { <span>★</span> }
                @node.Name
                <small style="opacity:.7;font-size:.75em">@node.Callsign</small>
            </button>
        }
    </div>
    }
    @* ===== UPPER AREA: Tabs with conversations ===== *@
    <div class="upper-pane">
        <div class="tab-bar">
            <div class="tab-new-wrap">
                @if (QsoSummaryService.IsDbReady)
                {
                    <button class="tab-button tab-recent-btn @(_showRecentPartners ? "active" : "")"
                            @onclick="ToggleRecentPartnersAsync"
                            title="@Loc.T("Letzte QSO-Partner", "Recent QSO partners")">📋</button>
                    <button class="tab-button tab-recent-btn @(_globalSearchMode && _qsoSummaryVisible ? "active" : "")"
                            @onclick="OpenGlobalSearchAsync"
                            title="@Loc.T("Alle Direkt-Nachrichten durchsuchen", "Search all direct messages")">🔍</button>
                }
            </div>
            @foreach (var tab in _tabs)
            {
                <button class="tab-button @(tab.Key == _activeTabKey ? "active" : "")"
                        draggable="true"
                        data-tab-key="@tab.Key"
                        @onclick="() => SelectTab(tab.Key)"
                        title="@(tab.Key != "*" && !tab.Key.StartsWith('#') ? tab.Title + QrzSuffix(tab.Key) : tab.Key.StartsWith('#') ? ChatService.GetGroupLabel(tab.Key)?.Label : null)">
                    <span class="tab-label-wrap">
                        <span>@(tab.Key == "*" ? Loc.T("Alle", "All") : tab.Title)</span>
                        @if (tab.Key != "*" && !tab.Key.StartsWith('#') && QrzFirstName(tab.Key) is { } tabFn)
                        {
                            <span class="tab-qrz-name">@tabFn</span>
                        }
                        @if (tab.Key.StartsWith('#') && ChatService.GetGroupLabel(tab.Key) is { } grp)
                        {
                            <span class="tab-qrz-name" title="@grp.Label">@grp.ShortLabel</span>
                        }
                        @if (tab.MessageCount > 0)
                        {
                            <span class="tab-msg-count" title="@Loc.T($"{tab.MessageCount} Nachrichten", $"{tab.MessageCount} messages")">Msg.:&nbsp;@tab.MessageCount</span>
                        }
                    </span>
                    @if (tab.UnreadCount > 0)
                    {
                        <span class="tab-unread">@(tab.UnreadCount > 99 ? "99+" : tab.UnreadCount.ToString())</span>
                    }
                    @if (QsoSummaryService.IsDbReady && tab.Key != "*" && !tab.Key.StartsWith('#'))
                    {
                        <span class="tab-ai-icon" title="@(tab.HasQsoSummary ? Loc.T("QSO-Zusammenfassung verfügbar", "QSO summary available") : Loc.T("QSO-Verlauf & Suche", "QSO History & Search"))"
                              @onclick="() => OpenQsoSummary(tab)" @onclick:stopPropagation="true">🔎</span>
                    }
                    <span class="tab-close" @onclick="() => ConfirmCloseTab(tab.Key)" @onclick:stopPropagation="true">&times;</span>
                </button>
            }
            <div class="tab-new-wrap">
                <button class="tab-button tab-new" @onclick="ShowNewTabDialog" title="@Loc.T("Neuen Tab öffnen", "Open new tab")">+</button>
            </div>
        </div>

        @if (_showNewTabInput)
        {
            <div class="new-tab-dialog">
                <input @bind="_newTabCallsign" @bind:event="oninput"
                       placeholder="@Loc.T("Rufzeichen oder Gruppe (z.B. OE1KBC, #gruppe, *)", "Callsign or group (e.g. OE1KBC, #group, *)") "
                       @onkeydown="OnNewTabKeyDown" />
                <button class="btn-action" @onclick="CreateNewTab">@Loc.T("\u00d6ffnen", "Open")</button>
                <button class="btn-cancel" @onclick="() => _showNewTabInput = false">@Loc.T("Abbrechen", "Cancel")</button>
            </div>
        }

        @if (_showRecentPartners)
        {
            <div class="recent-partners-flyout">
                <div class="recent-partners-header">
                    📡 @Loc.T("Letzte QSO-Partner", "Recent QSO partners")
                    <button class="recent-partners-close" @onclick="() => _showRecentPartners = false">✕</button>
                </div>
                @if (_recentPartners.Count == 0)
                {
                    <div class="recent-partners-empty">@Loc.T("Keine Daten gefunden.", "No data found.")</div>
                }
                else
                {
                    @foreach (var p in _recentPartners)
                    {
                        var fn = QrzFirstName(p.Callsign);
                        <button class="recent-partner-row" @onclick="() => OpenRecentPartner(p.Callsign)">
                            <span class="recent-partner-call">@p.Callsign@if (fn is not null){<span class="qrz-badge"> · @fn</span>}</span>
                            <span class="recent-partner-time">@FormatRecentTime(p.LastContact)</span>
                        </button>
                    }
                }
            </div>
        }

        <div class="tab-content">
            @if (_activeTab != null)
            {
                <div class="message-list" id="tab-messages">
                    @{ var msgIdx = 0; }
                    @foreach (var msg in _activeTabMessages)
                    {
                        @if (_newMessagesFromIndex >= 0 && msgIdx == _newMessagesFromIndex)
                        {
                            <div class="new-messages-divider">
                                <span>@Loc.T("Neue Nachrichten", "New Messages")</span>
                            </div>
                        }
                        msgIdx++;
                        <div class="message @(msg.IsOutgoing ? (_settings.OwnMessagesAlignLeft ? "msg-out-left" : "msg-out") : "msg-in")">
                            <span class="msg-time">
                                @{ var msgTs = LT(msg.Timestamp); var msgDate = TsDate(msgTs); }
                                @msgTs.ToString("HH:mm:ss")
                                @if (msgDate != null) { <span class="ts-date">@msgDate</span> }
                            </span>
                            @if (msg.IsOutgoing)
                            {
                                <span class="msg-call">@msg.From:</span>
                            }
                            else
                            {
                                <span class="msg-call-group">
                                    <CallsignPopup Callsign="@msg.From" OnOpenChat="cs => OpenTabFromMonitor(cs)" />:
                                    <button class="btn-mention" @onclick="() => InsertMentionAsync(msg.From)" title="@MentionTitle(msg.From)">&#64;</button>
                                </span>
                            }
                            <span class="msg-text">@FormatMessageWithLinks(msg.Text)</span>
                            <button class="btn-copy-msg" title="@Loc.T("Text kopieren", "Copy text")" @onclick="() => CopyMessageAsync(msg.Text)">📋</button>
                            @if (msg.IsOutgoing)
                            {
                                <span class="@AckCssClass(msg)" title="@AckTooltip(msg)">@AckIcon(msg)</span>
                            }
                        </div>
                    }
                </div>

                <SendBar @key="@("sendbar")" @ref="_sendBar" OnSend="HandleSendMessage" Callsign="@_activeTab.Key" />
            }
            else
            {
                <div class="no-tab-selected">
                    <p>@Loc.T("Kein Tab ausgewählt. Klicke", "No tab selected. Click") <strong>+</strong> @Loc.T("um einen neuen Chat zu öffnen, oder warte auf eine eingehende Nachricht.", "to open a new chat, or wait for an incoming message.")</p>
                </div>
            }
        </div>
    </div>

    <div id="pane-divider" class="pane-divider @(_showMonitor ? "" : "pane-divider-collapsed")"></div>

    @* ===== LOWER AREA: Monitor ===== *@
    <div id="lower-pane" class="lower-pane @(_showMonitor ? "" : "lower-pane-collapsed")">
        <div class="pane-header">
            <span class="pane-header-title">📡 Monitor</span>
            <span class="mon-filter-wrap">
                <span class="mon-filter-icon">🔍</span>
                <input class="mon-filter-input"
                       value="@_monitorFilter"
                       @oninput="OnMonitorFilterInput"
                       @onkeydown="OnMonitorFilterKeyDown"
                       placeholder="@Loc.T("Rufzeichen oder Text…", "Callsign or text…")" />
                @if (!string.IsNullOrEmpty(_monitorFilter))
                {
                    <button class="mon-filter-clear" @onclick="ClearMonitorFilter" title="@Loc.T("Filter löschen", "Clear filter")">×</button>
                }
            </span>
            <span class="msg-count">
                @if (string.IsNullOrEmpty(_monitorFilter))
                {
                    @($"{_allMessages.Count} {Loc.T("Einträge", "Entries")}")
                }
                else
                {
                    @($"{_cachedFilteredMessages.Count} / {_allMessages.Count} {Loc.T("Einträge", "Entries")}")
                }
            </span>
            <button class="mon-toggle-btn" @onclick="ToggleMonitorAsync"
                    title="@(_showMonitor ? Loc.T("Monitor ausblenden", "Hide Monitor") : Loc.T("Monitor einblenden", "Show Monitor"))">
                @(_showMonitor ? "▼" : "▲")
            </button>
        </div>
        <div class="mon-list" id="raw-messages">
            @foreach (var m in _cachedFilteredMessages)
            {
                <div class="mon-row @MonRowClass(m)">
                    @{ var monTs = LT(m.Timestamp); var monDate = TsDate(monTs); }
                    <span class="mon-time @(monDate != null ? "mon-time-dated" : "")" title="@(m.MsgId is not null ? $"ID: {m.MsgId}" : null)">
                        @monTs.ToString("HH:mm:ss")
                        @if (monDate != null) { <span class="ts-date">@monDate</span> }
                    </span>

                    <span class="mon-badge @MonBadgeClass(m)">@MonType(m)</span>

                    <span class="mon-dir @(m.IsOutgoing ? "mon-tx" : "mon-rx")">
                        @(m.IsOutgoing ? "TX" : "RX")
                    </span>

                    @if (!m.IsOutgoing && !string.IsNullOrEmpty(m.SrcType))
                    {
                        <span class="mon-src @SrcTypeCss(m.SrcType)">@SrcTypeLabel(m.SrcType)</span>
                    }

                    @* Routing: From [⟶ Relay1 ⟶ Relay2 …] → To *@
                    @if (!string.IsNullOrEmpty(m.From))
                            {
                                <span class="mon-routing">
                                    @if (!string.Equals(m.From, _myCallsign, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="mon-call-group">
                                            <CallsignPopup Callsign="@m.From" OnOpenChat="cs => OpenTabFromMonitor(cs)" />
                                            <button class="btn-mention" @onclick="() => InsertMentionAsync(m.From)" title="@MentionTitle(m.From)">&#64;</button>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="mon-call">@m.From</span>
                                    }
                            @* Show each relay hop inline *@
                            @if (m.RelayPath != null)
                            {
                                foreach (var hop in m.RelayPath.Split(',').Skip(1))
                                {
                                    <span class="mon-relay-arrow">⟶</span>
                                    <span class="mon-relay-node" title="@hop">@hop</span>
                                }
                            }
                            @if (!string.IsNullOrEmpty(m.To))
                            {
                                <span class="mon-arrow">→</span>
                                if (m.IsBroadcast)
                                {
                                    <span class="mon-call mon-bcast">@Loc.T("alle", "all")</span>
                                }
                                else if (!string.Equals(m.To, _myCallsign, StringComparison.OrdinalIgnoreCase))
                                {
                                    var grpLabel = ChatService.GetGroupLabel(m.To);
                                    @if (grpLabel is not null)
                                    {
                                        <span class="mon-call mon-call-link" @onclick="() => OpenTabFromMonitor(m.To)"
                                              title="@grpLabel.Label">@FormatDest(m.To)<span class="qrz-badge"> · @grpLabel.ShortLabel</span></span>
                                    }
                                    else
                                    {
                                        <CallsignPopup Callsign="@m.To" OnOpenChat="cs => OpenTabFromMonitor(cs)" />
                                    }
                                }
                                else
                                {
                                    <span class="mon-call">@m.To</span>
                                }
                            }
                        </span>
                    }

                    @* Content *@
                    @if (m.IsTelemetry)
                    {
                        <span class="mon-content mon-tele">
                            @if (m.Temp1.HasValue && m.Temp1 != 0)  { <span>🌡️ @m.Temp1.Value.ToString("F1")°C</span> }
                            @if (m.Humidity.HasValue && m.Humidity != 0) { <span class="mon-alt">&nbsp;·&nbsp;💧 @m.Humidity.Value.ToString("F0")%</span> }
                            @if (m.Pressure.HasValue && m.Pressure != 0) { <span class="mon-alt">&nbsp;·&nbsp;🧭 @m.Pressure.Value.ToString("F1") hPa</span> }
                            @if (m.Battery.HasValue) { <span class="mon-alt">&nbsp;·&nbsp;🔋 @m.Battery%</span> }
                        </span>
                    }
                    else if (m.IsPositionBeacon && m.Latitude.HasValue)
                    {
                        <span class="mon-content mon-pos">
                            📍&nbsp;@($"{Math.Abs(m.Latitude.Value):F4}°{(m.Latitude >= 0 ? "N" : "S")}")
                            &nbsp;@($"{Math.Abs(m.Longitude!.Value):F4}°{(m.Longitude >= 0 ? "E" : "W")}")
                            @if (m.Altitude.HasValue)
                            {
                                <span class="mon-alt">&nbsp;·&nbsp;@m.Altitude&nbsp;m</span>
                            }
                            @{ var dist = MonDistance(m); }
                            @if (!string.IsNullOrEmpty(dist))
                            {
                                <span class="mon-dist">&nbsp;·&nbsp;📏&nbsp;@dist</span>
                            }
                            @if (m.Battery.HasValue)
                            {
                                <span class="mon-alt">&nbsp;·&nbsp;🔋 @m.Battery%</span>
                            }
                            @if (!string.IsNullOrEmpty(MeshcomLookup.HwName(m.HwId)))
                            {
                                <span class="mh-hw-badge">&nbsp;@MeshcomLookup.HwName(m.HwId)</span>
                            }
                            @if (!string.IsNullOrEmpty(m.Firmware))
                            {
                                <span class="mh-fw-badge">@m.Firmware</span>
                            }
                        </span>
                    }
                    else if (!string.IsNullOrEmpty(m.Text) && !m.Text.StartsWith('{'))
                    {
                        <span class="mon-content mon-text">"@FormatMessageWithLinks(m.Text)"</span>
                    }
                    else if (string.IsNullOrEmpty(m.From))
                    {
                        <span class="mon-content mon-sys">@MonTruncate(m.RawData, 80)</span>
                    }

                    @* Sequence number for outgoing MSG (appears once node echo assigns it) *@
                    @if (m.IsOutgoing && !m.IsAck && !m.IsPositionBeacon && !m.IsTelemetry &&
                         m.SequenceNumber != null && m.SequenceNumber != "TX")
                    {
                        <span class="mon-seq" title="@Loc.T("Sequenznummer", "Sequence number")">{@m.SequenceNumber}</span>
                    }

                    @* MsgId for incoming messages *@
                    @if (!m.IsOutgoing && !m.IsAck && !m.IsPositionBeacon && !m.IsTelemetry &&
                         !string.IsNullOrEmpty(m.MsgId))
                    {
                        <span class="mon-msgid" title="@Loc.T("Message-ID", "Message ID")">@m.MsgId</span>
                    }

                    @* Signal *@
                    @if (m.Rssi.HasValue)
                    {
                        <span class="mon-signal @RssiCssClass(m.Rssi.Value)">
                            @m.Rssi&nbsp;dBm
                            @if (m.Snr.HasValue)
                            {
                                <span class="mon-snr">/ @m.Snr.Value.ToString("F1")&nbsp;dB</span>
                            }
                        </span>
                    }
                </div>
            }
        </div>
    </div>

    @* ===== ALERT TOASTS (Watchlist + CQ) ===== *@
    @if (_watchlistAlerts.Count > 0 || _cqAlerts.Count > 0)
    {
        <div class="alert-toast-stack">
            @if (_watchlistAlerts.Count > 0)
            {
                <div class="watchlist-toast">
                    <div class="watchlist-toast-header">
                        <span>📻 @Loc.T("Rufzeichen empfangen", "Callsign received")</span>
                        <button class="watchlist-toast-close" @onclick="() => _watchlistAlerts.Clear()">✕</button>
                    </div>
                    @foreach (var alert in _watchlistAlerts)
                    {
                        <div class="watchlist-toast-row">
                            <span class="watchlist-callsign">@alert.Callsign</span>
                            <span class="watchlist-badge">@alert.EventType</span>
                            <span class="watchlist-age">@FormatAlertAge(alert.Time)</span>
                        </div>
                    }
                </div>
            }
            @if (_cqAlerts.Count > 0)
            {
                <div class="watchlist-toast" style="border-color:#e3b341">
                    <div class="watchlist-toast-header" style="background:#2a1e00;color:#e3b341">
                        <span>📡 @Loc.T("CQ empfangen", "CQ received")</span>
                        <button class="watchlist-toast-close" @onclick="() => _cqAlerts.Clear()">✕</button>
                    </div>
                    @foreach (var cq in _cqAlerts)
                    {
                        <div class="watchlist-toast-row">
                            <span class="watchlist-callsign">@cq.Callsign</span>
                            <span class="watchlist-badge" style="background:#e3b341;color:#000">CQ #@cq.Group</span>
                            <span class="watchlist-age">@FormatAlertAge(cq.Time)</span>
                        </div>
                    }
                </div>
            }
        </div>
    }

    @* ===== STATUS BAR ===== *@
    <div class="status-bar">
        <button class="status-mute-btn @(_soundEnabled ? "" : "status-mute-off")"
                @onclick="() => _soundEnabled = !_soundEnabled"
                title="@(_soundEnabled ? Loc.T("Ton ausschalten", "Mute sound") : Loc.T("Ton einschalten", "Unmute sound"))">
            <span class="status-badge @(_soundEnabled ? "status-badge-neutral" : "status-badge-err")">@(_soundEnabled ? "🔔" : "🔕")</span>
        </button>
        <button class="status-mute-btn @(_voiceEnabled == true ? "" : "status-mute-off")"
                @onclick="ToggleVoiceAsync"
                style="@(_voiceEnabled is null ? "visibility:hidden" : "")"
                title="@(_voiceEnabled == true ? Loc.T("Sprachansagen ausschalten", "Disable voice announcements") : Loc.T("Sprachansagen einschalten", "Enable voice announcements"))">
            <span class="status-badge @(_voiceEnabled == true ? "status-badge-neutral" : "status-badge-err")">@(_voiceEnabled == true ? "🔊" : "🔇")</span>
        </button>
        @if (TelnetService.IsEnabled)
        {
            var consoleConnected = _settings.ConsoleMode switch
            {
                "serial" => SerialConsoleService.IsConnected,
                "hmac"   => HmacConsoleService.IsConnected,
                _        => TelnetService.IsConnected
            };
            var consoleIcon = "🖥️";
            <button class="status-mute-btn @(consoleConnected ? "" : "status-mute-off")"
                    @onclick="ToggleTelnetAsync"
                    title="@(consoleConnected ? Loc.T("Console verbunden – klicken zum Trennen", "Console connected – click to disconnect") : Loc.T("Console getrennt – klicken zum Verbinden", "Console disconnected – click to connect"))">
                <span class="status-badge @(consoleConnected ? "status-badge-ok" : "status-badge-err")">@(consoleConnected ? consoleIcon : consoleIcon + "✗")</span>
            </button>
        }
        <span class="status-sep">|</span>
        <span class="status-item" title="@UdpStatusTooltip">
            <span class="status-badge @UdpStatusBadgeCss">@UdpStatusIcon UDP</span>
        </span>
        @if (MonitorSink.IsEnabled)
        {
            <span class="status-sep">|</span>
            <span class="status-item" title="@DbStatusTooltip">
                <span class="status-badge @DbStatusBadgeCss">@DbStatusIcon DB</span>
            </span>
        }
        @if (MqttService.IsEnabled)
        {
            <span class="status-sep">|</span>
            <span class="status-item" title="@MqttStatusTooltip">
                <span class="status-badge @MqttStatusBadgeCss">@MqttStatusIcon MQTT</span>
            </span>
        }
        <span class="status-sep status-compact">|</span>
        <span class="status-item status-compact">
            <span class="status-badge status-badge-neutral">📡 @_settings.DeviceIp:@_settings.DevicePort</span>
        </span>
        <span class="status-sep">|</span>
        <span class="status-item">
            <span class="status-badge status-badge-neutral">🎙️ @_myCallsign</span>
        </span>
        @if (!string.IsNullOrEmpty(MeshcomLookup.HwName(_status.NodeHwId)))
        {
            <span class="status-sep status-medium">|</span>
            <span class="status-item status-medium" title="@Loc.T($"Node Hardware · Firmware: {_status.NodeFirmware}", $"Node hardware · Firmware: {_status.NodeFirmware}")">
                <span class="status-badge status-badge-info">⚙️ @MeshcomLookup.HwName(_status.NodeHwId)@if (!string.IsNullOrEmpty(_status.NodeFirmware)) {<text>&nbsp;·&nbsp;@_status.NodeFirmware</text>}</span>
            </span>
        }
        @if (_status.OwnLatitude.HasValue && _status.OwnLongitude.HasValue)
        {
            <span class="status-sep status-medium">|</span>
            <span class="status-item status-medium">
                <span class="status-badge status-badge-info">📍 @GeoHelper.FormatCoord(_status.OwnLatitude, _status.OwnLongitude)@if (_status.OwnAltitude.HasValue) {<text>&nbsp;·&nbsp;@_status.OwnAltitude&nbsp;m</text>}</span>
            </span>
        }
        <span class="status-sep status-detail">|</span>
        <span class="status-item status-detail">
            <span class="status-badge status-badge-neutral">📨 RX @_status.RxCount / TX @_status.TxCount</span>
        </span>
        @if (_status.BeaconActive)
        {
            <span class="status-sep status-detail">|</span>
            <span class="status-item status-detail" title="@Loc.T($"Bake aktiv · Gruppe {_settings.BeaconGroup} · alle {_settings.BeaconIntervalHours} h", $"Beacon active · Group {_settings.BeaconGroup} · every {_settings.BeaconIntervalHours} h")">
                <span class="status-badge status-badge-warn">●&nbsp;@Loc.T("Bake", "Beacon")@if (_status.BeaconNextSend.HasValue) {<text>&nbsp;·&nbsp;@_status.BeaconNextSend.Value.ToString("HH:mm")</text>}</span>
            </span>
        }
        @if (_status.LastRxTime.HasValue)
        {
            <span class="status-sep status-detail">|</span>
            <span class="status-item status-detail">
                <span class="status-badge status-badge-neutral">⏱️ @LT(_status.LastRxTime.Value).ToString("HH:mm:ss") @Loc.T("von", "from") @_status.LastRxFrom</span>
            </span>
        }
        @if (_status.LastRssi.HasValue)
        {
            <span class="status-sep status-detail">|</span>
            <span class="status-item status-detail">
                <span class="status-badge @RssiStatusBadgeCss(_status.LastRssi.Value)">📶 RSSI @_status.LastRssi dBm&nbsp;·&nbsp;SNR @_status.LastSnr?.ToString("F1") dB</span>
            </span>
        }
        @if (_status.LastTxTime.HasValue)
        {
            <span class="status-sep status-detail">|</span>
            <span class="status-item status-detail">
                <span class="status-badge status-badge-neutral">📤 @LT(_status.LastTxTime.Value).ToString("HH:mm:ss")</span>
            </span>
        }
    </div>
</div>

@* ===== QSO Summary Modal ===== *@
@if (_qsoSummaryVisible)
