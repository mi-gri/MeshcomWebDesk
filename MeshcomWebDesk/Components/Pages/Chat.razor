    private void RefreshData()
    {
        _tabs = ChatService.GetTabs(_activeNodeId).ToList();
        ApplyTabOrder();
        _allMessages = ChatService.GetAllMessages(_activeNodeId);
        RebuildFilterCache();

        // If active tab was closed, select first available
        if (!string.IsNullOrEmpty(_activeTabKey))
        {
            _activeTab = _tabs.FirstOrDefault(t => t.Key == _activeTabKey)
                      ?? ChatService.GetTab(_activeTabKey, _activeNodeId);
        }

        if (_activeTab == null && _tabs.Count > 0)
        {
            _activeTabKey = _tabs[0].Key;
            _activeTab = _tabs[0];
        }

        // Create a snapshot of the active tab's messages for thread-safe rendering
        _activeTabMessages = (_activeTab != null && !string.IsNullOrEmpty(_activeTabKey))
            ? ChatService.GetTabMessages(_activeTabKey!, _activeNodeId)
            : [];

        if (!string.IsNullOrEmpty(_activeTabKey))
            ChatService.ClearUnread(_activeTabKey, _activeNodeId);
        _scrollMessages = true;

        // Sound notification: play beep when a new direct chat message to own callsign arrives.
        // _lastNotificationTime is always updated (even on first load) so that pre-existing
        // saved messages don't trigger the sound after a page reload.
        // Explicitly exclude ACKs, position beacons and telemetry.
        var latestDirect = _allMessages.FirstOrDefault(m =>
            !m.IsOutgoing &&
            !m.IsAck &&
            !m.IsPositionBeacon &&
            !m.IsTelemetry &&
            string.Equals(m.To, _myCallsign, StringComparison.OrdinalIgnoreCase));
        if (latestDirect != null)
        {
            var notifyKey = _activeNodeId ?? Guid.Empty;
            var lastTime = _lastNotificationTime.GetValueOrDefault(notifyKey, DateTime.MinValue);
            if (_isInitialized && _soundEnabled && latestDirect.Timestamp > lastTime)
                _playSound = true;
            _lastNotificationTime[notifyKey] = latestDirect.Timestamp;
        }
    }

