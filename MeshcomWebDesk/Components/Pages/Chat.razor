@code {
    private List<ChatTab> _tabs = [];
    private IReadOnlyList<MeshcomMessage> _allMessages = [];
    private IReadOnlyList<MeshcomMessage> _activeTabMessages = [];
    private readonly Dictionary<string, QrzInfo?> _qrzData = new(StringComparer.OrdinalIgnoreCase);
    private string _activeTabKey = string.Empty;
    private ChatTab? _activeTab;
    /// <summary>Index of the first "new" message in _activeTabMessages. -1 = no divider.</summary>
    private int _newMessagesFromIndex = -1;
    private string _newTabCallsign = string.Empty;
    private bool _showNewTabInput;
    private string _myCallsign = string.Empty;
    private bool _disposed;
    private ConnectionStatus _status = new();

    /// <summary>Id des aktuell ausgewählten Nodes. Null = Legacy/Primary.</summary>
    private Guid? _activeNodeId => NodeManager.SelectedNode?.Id;
    private MeshcomSettings _settings = new();
    private bool _showMonitor = false;
    private SendBar? _sendBar;

    // QSO Summary modal state
    private bool               _qsoSummaryVisible;
    private bool               _qsoSummaryLoading;
    private string?            _qsoSummaryCallsign;
    private string?            _qsoSummaryError;
    private QsoSummaryRecord?  _qsoSummaryRecord;
    private ChatTab?           _qsoSummaryTab;
    private int                _qsoModalTab;        // 0=Summary 1=History 2=TextSearch 3=AI Search

    // History tab state
    private List<QsoHistoryMessage> _historyMessages   = [];
    private bool     _historyLoading;
    private int      _historyPage       = 1;
    private int      _historyTotal;
    private int      _historyTotalPages = 1;
    private const int HistoryPageSize   = 50;
    private DateTime? _historyFrom;
    private DateTime? _historyTo;
    private string    _historyTextFilter = string.Empty;

    // Text search tab state
    private List<QsoHistoryMessage> _textSearchMessages   = [];
    private bool     _textSearchLoading;
    private int      _textSearchPage       = 1;
    private int      _textSearchTotal;
    private int      _textSearchTotalPages = 1;
    private string   _textSearchTerm       = string.Empty;
    private DateTime? _textSearchFrom;
    private DateTime? _textSearchTo;

    // AI Search tab state
    private string?   _aiSearchResult;
    private string?   _aiSearchError;
    private bool      _aiSearchLoading;
    private DateTime? _aiSearchTrimmedFrom;
    private string   _searchQuery = string.Empty;
    private DateTime? _searchFrom;
    private DateTime? _searchTo;
    private bool     _aiSearchAllContacts;   // true = search across all direct QSOs
    private bool     _globalSearchMode;       // true = dialog opened from tab-bar search button (no single callsign)

    private bool _scrollMessages;

    private bool _soundEnabled = true;
    private bool? _voiceEnabled = false;  // false until restored from localStorage; null = hide button
    private bool _playSound;
    private readonly Queue<string> _pendingSpeech = new();
    // Zeitpunkt der letzten TTS-Ansage "Nachricht von …" pro Rufzeichen
    private readonly Dictionary<string, DateTime> _lastDirectSpeechTime = new(StringComparer.OrdinalIgnoreCase);
    private static readonly TimeSpan DirectSpeechCooldown = TimeSpan.FromMinutes(5);

    // Recent partners flyout
    private bool _showRecentPartners;
    private List<RecentPartner> _recentPartners = [];
    private bool _recentPartnersLoaded;
    private bool _isInitialized;
    private readonly Dictionary<Guid, DateTime> _lastNotificationTime = new();
    private string _monitorFilter = string.Empty;
    private IReadOnlyList<MeshcomMessage> _cachedFilteredMessages = [];
    private CancellationTokenSource? _filterDebounce;
    private List<string> _tabOrder = [];
    private DotNetObjectReference<Chat>? _dotNetRef;

    private IReadOnlyList<MeshcomMessage> _filteredMessages =>
        string.IsNullOrWhiteSpace(_monitorFilter)
            ? _allMessages
            : _allMessages.Where(m =>
                Contains(m.From,    _monitorFilter) ||
                Contains(m.To,      _monitorFilter) ||
                Contains(m.Text,    _monitorFilter) ||
                Contains(m.RawData, _monitorFilter))
              .ToList();

    private void RebuildFilterCache()
    {
        _cachedFilteredMessages = _filteredMessages;
    }

    private async Task OnMonitorFilterInput(ChangeEventArgs e)
    {
        _monitorFilter = e.Value?.ToString() ?? string.Empty;

        // Empty field: apply immediately without debounce
        if (string.IsNullOrEmpty(_monitorFilter))
        {
            _filterDebounce?.Cancel();
            RebuildFilterCache();
            return;
        }

        // Cancel any pending debounce
        _filterDebounce?.Cancel();
        _filterDebounce = new CancellationTokenSource();
        var token = _filterDebounce.Token;
        try
        {
            await Task.Delay(250, token);
            RebuildFilterCache();
            StateHasChanged();
        }
        catch (OperationCanceledException) { }
    }

    private void OnMonitorFilterKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _filterDebounce?.Cancel();
            RebuildFilterCache();
            StateHasChanged();
        }
    }

    private void ClearMonitorFilter()
    {
        _filterDebounce?.Cancel();
        _monitorFilter = string.Empty;
        RebuildFilterCache();
    }

    private static bool Contains(string? value, string filter) =>
        !string.IsNullOrEmpty(value) &&
        value.Contains(filter, StringComparison.OrdinalIgnoreCase);

    private record WatchlistAlert(string Callsign, string EventType, DateTime Time);
    private List<WatchlistAlert> _watchlistAlerts = [];
    private bool _playWatchlistSound;
    private Dictionary<string, DateTime> _watchlistLastTts = new(StringComparer.OrdinalIgnoreCase);

    private record CqAlert(string Callsign, string Group, DateTime Time);
    private List<CqAlert> _cqAlerts = [];
    private bool _playCqSound;

    // ── Welcome dialog ────────────────────────────────────────────────────
    private static readonly string _appVersion =
        typeof(Chat).Assembly.GetName().Version is { } v
            ? $"{v.Major}.{v.Minor}.{v.Build}" : "?";

    [Inject] private IConfiguration Configuration { get; set; } = default!;
    [Inject] private IOptionsMonitor<MeshcomSettings> SettingsOptions { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override void OnInitialized()
    {
        Loc.OnChange += OnLocChange;
        _settings = SettingsOptions.CurrentValue;
        _myCallsign = _settings.MyCallsign;
        _status = UdpService.Status;
        ChatService.OnChange += OnChatChanged;
        ChatService.OnEchoTimeout += OnEchoTimeout;
        UdpService.OnStatusChange += OnStatusChanged;
        ChatService.OnWatchlistHit += HandleWatchlistHit;
        ChatService.OnCqHeard += HandleCqHeard;
        ChatService.OnNewDirectTab += HandleNewDirectTab;
        ChatService.OnDirectMessage += HandleDirectMessage;
        TelnetService.OnChange += OnTelnetChanged;
        SerialConsoleService.OnChange += OnTelnetChanged;
        NodeManager.OnSelectedNodeChanged += OnNodeChanged;
        // Restore active tab from service memory so the first render already shows the correct tab
        _activeTabKey = ChatService.GetActiveTabKey(_activeNodeId);
        // Server-seitig gespeicherte Tab-Reihenfolge vor dem ersten Render anwenden
        var serverOrder = ChatService.GetTabOrder(_activeNodeId);
        if (serverOrder.Count > 0)
            _tabOrder = [.. serverOrder];
        RefreshData();
        _isInitialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("meshcomChat.initResizer"); }
            catch (JSException) { }

            try { await JS.InvokeVoidAsync("meshcomChat.initStatusBar"); }
            catch (JSException) { }

            var needsRender = false;

            // Restore monitor visibility: null = never saved → default visible
            try
            {
                var monVis = await JS.InvokeAsync<bool?>("meshcomChat.getMonitorVisible");
                var targetVisible = monVis ?? true;   // first visit: show monitor
                if (targetVisible != _showMonitor)
                {
                    _showMonitor = targetVisible;
                    needsRender = true;
                }
            }
            catch (JSException) { }

            // Restore voice-announcement toggle state (default: off)
            try
            {
                var voiceOn = await JS.InvokeAsync<bool?>("meshcomChat.getVoiceEnabled");
                _voiceEnabled = voiceOn ?? false;
                needsRender = true;
            }
            catch (JSException) { _voiceEnabled = false; needsRender = true; }

            // Fallback restore for hard browser reload: ChatService.ActiveTabKey is empty in that case.
            // On normal navigation (Map → Chat) this is a no-op because OnInitialized already
            // read the correct key from ChatService.ActiveTabKey.
            try
            {
                if (string.IsNullOrEmpty(ChatService.GetActiveTabKey(_activeNodeId)))
                {
                    var savedKey = await JS.InvokeAsync<string>("meshcomChat.getActiveTab");
                    if (!string.IsNullOrEmpty(savedKey) && _tabs.Any(t => t.Key == savedKey))
                    {
                        _activeTabKey          = savedKey;
                        _activeTab             = ChatService.GetTab(savedKey, _activeNodeId);
                        _activeTabMessages     = ChatService.GetTabMessages(savedKey, _activeNodeId);
                        ChatService.SetActiveTabKey(_activeNodeId, savedKey);
                        ChatService.ClearUnread(savedKey, _activeNodeId);
                        needsRender = true;
                    }
                }
            }
            catch (JSException) { }

            // Restore saved tab order – localStorage als Fallback wenn server-seitig noch nichts gespeichert
            try
            {
                if (_tabOrder.Count == 0)
                {
                    var order = await JS.InvokeAsync<string[]?>("meshcomChat.getTabOrder");
                    if (order != null && order.Length > 0)
                    {
                        _tabOrder = [.. order];
                        // Reihenfolge auch server-seitig sichern damit nächster Reload kein JS braucht
                        ChatService.SetTabOrder(_activeNodeId, _tabOrder);
                        ApplyTabOrder();
                        needsRender = true;
                    }
                }
            }
            catch (JSException) { }

            // Initialize tab drag-and-drop
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("meshcomChat.initTabDrag", _dotNetRef); }
            catch (JSException) { }

            if (await LoadQrzDataAsync())
                needsRender = true;

            if (needsRender)
                StateHasChanged();
        }

        if (_scrollMessages)
        {
            _scrollMessages = false;
            try { await JS.InvokeVoidAsync("scrollToBottom", "tab-messages"); }
            catch (JSException) { }
        }

        if (_playSound)
        {
            _playSound = false;
            try { await JS.InvokeVoidAsync("playNotificationBeep"); }
            catch (JSException) { }
        }

        if (_playCqSound)
        {
            _playCqSound = false;
            try { await JS.InvokeVoidAsync("playCqBeep"); }
            catch (Exception) { }
        }
        if (_playWatchlistSound)
        {
            _playWatchlistSound = false;
            try { await JS.InvokeVoidAsync("playWatchlistBeep"); }
            catch (JSException) { }
        }

        if (_pendingSpeech.TryDequeue(out var speechText))
        {
            try { await JS.InvokeVoidAsync("speakText", speechText, Loc.Current); }
            catch (JSException) { }
        }
    }

