    /// <summary>
    /// Spielt die "Nachricht von …"-Ansage, wenn seit der letzten Ansage für dieses
    /// Rufzeichen mehr als <see cref="DirectSpeechCooldown"/> vergangen sind (oder
    /// noch keine Ansage stattfand). Mehrfach-Ansagen bei schnellen Folgenachrichten
    /// werden so unterdrückt.
    /// </summary>
    private void SpeakDirectMessage(string callsign)
    {
        var now = DateTime.Now;
        if (_lastDirectSpeechTime.TryGetValue(callsign, out var last) &&
            (now - last) < DirectSpeechCooldown)
            return;

        _lastDirectSpeechTime[callsign] = now;
        var phonetic  = PhoneticAlphabetHelper.Spell(callsign, Loc.Current);
        var firstName = QrzFirstName(callsign);
        var text = Loc.T(
            $"Nachricht von {phonetic}{(firstName != null ? ". " + firstName : "")}",
            $"Message from {phonetic}{(firstName != null ? ". " + firstName : "")}",
            $"Messaggio da {phonetic}{(firstName != null ? ". " + firstName : "")}",
            $"Mensaje de {phonetic}{(firstName != null ? ". " + firstName : "")}");
        // Direct message has highest priority – prepend before any watchlist entries
        var existing = _pendingSpeech.ToArray();
        _pendingSpeech.Clear();
        _pendingSpeech.Enqueue(text);
        foreach (var e in existing) _pendingSpeech.Enqueue(e);
    }

