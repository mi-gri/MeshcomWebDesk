    private void SelectTab(string key)
    {
        _activeTabKey = key;
        _activeTab = ChatService.GetTab(key);
        _activeTabMessages = ChatService.GetTabMessages(key);
        ChatService.ClearUnread(key);
        ChatService.ActiveTabKey = key;
        _scrollMessages = true;
        _ = JS.InvokeVoidAsync("meshcomChat.setActiveTab", key).AsTask();
    }

    private async Task ConfirmCloseTab(string key)
    {
        var tab = _tabs.FirstOrDefault(t => t.Key == key);
        var label = tab?.Title ?? key;
        var msg = Loc.T(
            $"Tab \"{label}\" wirklich schließen?",
            $"Close tab \"{label}\"?",
            $"Chiudere la scheda \"{label}\"?",
            $"¿Cerrar la pestaña \"{label}\"?");
        var confirmed = await JS.InvokeAsync<bool>("confirm", msg);
        if (confirmed)
            CloseTab(key);
    }

    private void CloseTab(string key)
    {
        ChatService.CloseTab(key);
        if (_tabOrder.Remove(key))
            _ = JS.InvokeVoidAsync("meshcomChat.setTabOrder", _tabOrder).AsTask();
        if (_activeTabKey == key)
        {
            _activeTabKey = string.Empty;
            _activeTab = null;
            ChatService.ActiveTabKey = string.Empty;
            _ = JS.InvokeVoidAsync("meshcomChat.setActiveTab", (object?)null).AsTask();
        }
        RefreshData();
    }

    private void ShowNewTabDialog()
