    private bool IsAiActive => SettingsOptions.CurrentValue.Ai.Enabled && !string.IsNullOrWhiteSpace(SettingsOptions.CurrentValue.Ai.ApiKey);

    private async Task RunAiSearchAsync()
    {
        Logger.LogInformation("Chat: RunAiSearchAsync called – query='{Q}', callsign='{C}', allContacts={A}",
            _searchQuery, _qsoSummaryCallsign, _aiSearchAllContacts);

        if (string.IsNullOrWhiteSpace(_searchQuery) || (_qsoSummaryCallsign is null && !_aiSearchAllContacts))
        {
            Logger.LogWarning("Chat: RunAiSearchAsync aborted – query empty or callsign null");
            return;
        }
        _aiSearchLoading     = true;
        _aiSearchResult      = null;
        _aiSearchError       = null;
        _aiSearchTrimmedFrom = null;
        StateHasChanged();

        var result = await QsoSummaryService.SearchAsync(
            _qsoSummaryCallsign ?? string.Empty,
            _myCallsign,
            _searchQuery,
            mhList:           ChatService.MhList,
            from:             _searchFrom,
            to:               _searchTo.HasValue ? _searchTo.Value.AddDays(1) : null,
            allDirectContacts: _aiSearchAllContacts);

        if (result is null)
            _aiSearchError = Loc.T(
                "Suche fehlgeschlagen. Bitte API-Key und Konfiguration prüfen.",
                "Search failed. Please check API key and configuration.");
        else
        {
            _aiSearchResult      = result.Value.Answer;
            _aiSearchTrimmedFrom = result.Value.TrimmedFrom;
        }

        _aiSearchLoading = false;
        StateHasChanged();
    }

