                    else
                    {
                        <div class="qso-summary-hint">
                            <span>💡</span>
                            <span>
                                @if (_aiSearchAllContacts)
                                {
                                    @Loc.T(
                                        "Alle Direkt-QSOs werden durchsucht. Stelle eine Frage zu beliebigen Gesprächen. Die KI nennt Rufzeichen, Datum und Originaltext.",
                                        "All direct QSOs will be searched. Ask a question about any conversation. The AI cites callsign, date and original text.")
                                }
                                else
                                {
                                    @Loc.T(
                                        "Stelle eine Frage zum Gesprächsverlauf. Die KI durchsucht alle Nachrichten und nennt dir genaue Zeitstempel.",
                                        "Ask a question about the conversation. The AI searches all messages and cites exact timestamps.")
                                }
                            </span>
                        </div>
                    }
                    @if (_aiSearchTrimmedFrom.HasValue)
                    {
                        <div class="qso-summary-hint" style="flex-direction:column;align-items:flex-start;gap:6px">
                            <span>
                                ⚠️ @Loc.T(
                                    $"Ältere Nachrichten (vor {_aiSearchTrimmedFrom.Value:dd.MM.yyyy}) wurden wegen des Token-Limits nicht durchsucht.",
                                    $"Older messages (before {_aiSearchTrimmedFrom.Value:dd.MM.yyyy}) were excluded due to the token limit.")
                            </span>
                            <button class="btn-action" style="font-size:11px;padding:3px 10px"
                                    @onclick="SearchPreviousPeriodAsync">
                                🔍 @Loc.T("Im vorherigen Zeitraum suchen", "Search in previous period")
                            </button>
                        </div>
                    }
                    @if (_aiSearchError != null)
                    {
                        <div class="qso-summary-error">❌ @_aiSearchError</div>
                    }
                </div>
                <div class="qso-summary-footer">
                    <button class="btn-cancel" @onclick="CloseQsoSummary">@Loc.T("Schließen", "Close")</button>
                </div>
            }

            @if (_qsoSummaryError != null && _qsoModalTab == 0)
            {
                <div class="qso-summary-error">❌ @_qsoSummaryError</div>
            }
        </div>
    </div>
}

