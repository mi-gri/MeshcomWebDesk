    private string FormatLastSeen(DateTime utc)
    {
        var age = DateTime.UtcNow - utc;
        if (age.TotalSeconds < 60)  return Loc.T($"vor {(int)age.TotalSeconds}s", $"{(int)age.TotalSeconds}s ago");
        if (age.TotalMinutes < 60)  return Loc.T($"vor {(int)age.TotalMinutes}min", $"{(int)age.TotalMinutes}min ago");
        return Loc.T($"vor {(int)age.TotalHours}h", $"{(int)age.TotalHours}h ago");
    }

