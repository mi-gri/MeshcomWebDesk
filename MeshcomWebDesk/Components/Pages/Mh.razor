@page "/mh"
@rendermode InteractiveServer
@using MeshcomWebDesk.Models
@using MeshcomWebDesk.Services
@using MeshcomWebDesk.Helpers
@using Microsoft.Extensions.Options
@implements IDisposable
@inject ChatService ChatService
@inject MeshcomUdpService UdpService
@inject IOptions<MeshcomSettings> SettingsOptions
@inject LanguageService Loc
@inject QrzService QrzService
@inject NavigationManager Nav

<PageTitle>MH – @Loc.T("Zuletzt gehört", "Most Recently Heard", "Più recenti", "Más recientes")</PageTitle>

<div class="mh-page">

    @* ── Own position bar ── *@
    <div class="mh-ownpos @(HasOwnPos ? "mh-ownpos-ok" : "mh-ownpos-unknown")">
        <span class="mh-ownpos-label">📍 @Loc.T("Eigene Position:", "Own Position:", "Posizione propria:", "Posición propia:")</span>
        @if (HasOwnPos)
        {
            <span class="mh-ownpos-val">
                @GeoHelper.FormatCoord(_status.OwnLatitude, _status.OwnLongitude)
                @if (_status.OwnAltitude.HasValue)
                { <span class="mh-ownpos-alt">&nbsp;· @_status.OwnAltitude m ü.NN</span> }
            </span>
            <span class="mh-ownpos-src">[Node]</span>
            <a class="mh-osm-link" href="@GeoHelper.OsmUrl(_status.OwnLatitude!.Value, _status.OwnLongitude!.Value)"
               target="_blank" title="@Loc.T("Auf Karte anzeigen", "Show on map", "Mostra sulla mappa", "Mostrar en el mapa")">&#x1f5fa;&#xfe0f;</a>
        }
        else
        {
            <span class="mh-ownpos-unknown-txt">⏳ @Loc.T($"Warte auf Positionsdaten vom Node ({_myCallsign})…", $"Waiting for position data from node ({_myCallsign})…", $"In attesa di dati di posizione dal nodo ({_myCallsign})…", $"Esperando datos de posición del nodo ({_myCallsign})…")</span>
        }
    </div>

    @* ── Filtered list (cached, rebuilt on search change or station update) ── *@
    @{
        var filteredList = _cachedFilteredStations;
    }

    @* ── Header ── *@
    <div class="mh-header">
        <div class="mh-title-row">
            <h2 class="mh-title">📻 Most Recently Heard</h2>
            <span class="mh-subtitle">
                @filteredList.Count
                @if (!string.IsNullOrWhiteSpace(_searchText)) { <span class="mh-search-total"> / @_stations.Count</span> }
                @Loc.T("Station", "Station", "Station", "Station")@(filteredList.Count != 1 ? Loc.T("en", "s", "s", "s") : "")
            </span>
        </div>
        @if (_stations.Count > 0)
        {
            <div class="mh-search-wrap">
                <input class="mh-search" type="search"
                       placeholder="@Loc.T("Suchen…", "Search…", "Cerca…", "Buscar…")"
                       value="@_searchText"
                       @oninput="OnSearchInput"
                       @onkeydown="OnSearchKeyDown" />
                @if (!string.IsNullOrEmpty(_searchText))
                {
                    <button class="mh-search-clear" @onclick="ClearSearch"
                            title="@Loc.T("Suche löschen", "Clear search", "Cancella ricerca", "Limpiar búsqueda")">&#xd7;</button>
                }
            </div>
            <button class="mh-clear-btn" @onclick="ClearList">🗑️ @Loc.T("Liste leeren", "Clear List", "Svuota lista", "Vaciar lista")</button>
        }
    </div>

    @* ── Table ── *@
    @if (_stations.Count == 0)
    {
        <div class="mh-empty">
            <p>@Loc.T("Noch keine Stationen gehört.", "No stations heard yet.", "Nessuna stazione ricevuta.", "Ninguna estación escuchada aún.")</p>
            <p class="mh-empty-hint">@Loc.T("Empfangene LoRa-Nachrichten erscheinen hier automatisch.", "Received LoRa messages will appear here automatically.", "I messaggi LoRa ricevuti appariranno qui automaticamente.", "Los mensajes LoRa recibidos aparecerán aquí automáticamente.")</p>
        </div>
    }
    else
    {
        <div class="mh-table-wrapper">
            <table class="mh-table">
                <thead>
                    <tr>
                        <th>@Loc.T("Rufzeichen", "Callsign", "Nominativo", "Indicativo")</th>
                        @if (SettingsOptions.Value.Qrz.Enabled)
                        {
                            <th>@Loc.T("Name / Ort", "Name / Location", "Nome / Luogo", "Nombre / Lugar")</th>
                        }
                        <th>@Loc.T("Zuletzt gehört", "Last Heard", "Ultima ricezione", "último recibido")</th>
                        <th class="col-center">@Loc.T("Anz.", "Cnt.", "N.", "N.")</th>
                        <th>@Loc.T("Letzte Nachricht", "Last Message", "Ultimo messaggio", "último mensaje")</th>
                        <th>@Loc.T("GPS-Position", "GPS Position", "Posizione GPS", "Posición GPS")</th>
                        <th class="col-center">@Loc.T("Höhe", "Alt.", "Alt.", "Alt.")</th>
                        <th class="col-center">@Loc.T("Entfernung", "Distance", "Distanza", "Distancia")</th>
                        <th class="col-center">🔋</th>
                        <th class="col-center">RSSI</th>
                        <th class="col-center">SNR</th>
                        <th class="col-center" title="Hops (0=direkt)">🔁</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in filteredList)
                    {
                        var dist = CalcDistance(s);
                        <tr class="mh-row">
                            <td class="mh-callsign">
                                <div class="mh-cs-wrap @(_cardCallsign == s.Callsign ? "mh-cs-pinned" : "")"
                                     @onmouseenter="() => _cardCallsign = s.Callsign"
                                     @onmouseleave="() => { if (_cardCallsign == s.Callsign) _cardCallsign = null; }">
                                    <span class="mh-cs-label" @onclick="() => ToggleCard(s.Callsign)">
                                        @s.Callsign
                                    </span>
                                    @if (!string.IsNullOrEmpty(MeshcomLookup.HwName(s.HwId)))
                                    {
                                        <span class="mh-hw-badge">@MeshcomLookup.HwName(s.HwId)</span>
                                    }
                                    @if (!string.IsNullOrEmpty(s.Firmware))
                                    {
                                        <span class="mh-fw-badge">@s.Firmware</span>
                                    }

                                    @* ── Station Card (hover + tap) ── *@
                                    <div class="mh-station-card">
                                        @{ var qrzCard = _qrzData.GetValueOrDefault(s.Callsign);
                                           var distCard = CalcDistance(s); }
                                        <div class="mh-sc-header">
                                            <span class="mh-sc-call">@s.Callsign</span>
                                            @if (!string.IsNullOrEmpty(MeshcomLookup.HwName(s.HwId)))
                                            {
                                                <span class="mh-hw-badge">@MeshcomLookup.HwName(s.HwId)</span>
                                            }
                                        </div>
                                        @if (qrzCard is not null)
                                        {
                                            <div class="mh-sc-qrz">
                                                @if (!string.IsNullOrEmpty(qrzCard.FirstName)) { <span>@qrzCard.FirstName</span> }
                                                @if (!string.IsNullOrEmpty(qrzCard.Location))  { <span class="mh-sc-loc">@qrzCard.Location</span> }
                                            </div>
                                        }
                                        <div class="mh-sc-grid">
                                            @if (s.LastRssi.HasValue)
                                            {
                                                <span class="mh-sc-lbl">RSSI</span>
                                                <span class="@RssiClass(s.LastRssi)">@s.LastRssi dBm</span>
                                            }
                                            @if (s.LastSnr.HasValue)
                                            {
                                                <span class="mh-sc-lbl">SNR</span>
                                                <span>@($"{s.LastSnr:F1}") dB</span>
                                            }
                                            @if (s.Battery.HasValue)
                                            {
                                                <span class="mh-sc-lbl">🔋</span>
                                                <span class="@BattClass(s.Battery.Value)">@s.Battery%</span>
                                            }
                                            @if (distCard.HasValue)
                                            {
                                                <span class="mh-sc-lbl">📏</span>
                                                <span>@GeoHelper.FormatDistance(distCard.Value)</span>
                                            }
                                            @if (s.Latitude.HasValue && s.Longitude.HasValue)
                                            {
                                                <span class="mh-sc-lbl">QTH</span>
                                                <span style="font-family:monospace">@GeoHelper.ToMaidenhead(s.Latitude.Value, s.Longitude.Value)</span>
                                                <span class="mh-sc-lbl">GPS</span>
                                                <span>
                                                    <a class="mh-sc-gps" href="@GeoHelper.OsmUrl(s.Latitude.Value, s.Longitude.Value)"
                                                       target="_blank" rel="noopener" @onclick:stopPropagation="true">
                                                        @($"{s.Latitude.Value:F4}°{(s.Latitude >= 0 ? "N" : "S")}")
                                                        @($" {s.Longitude.Value:F4}°{(s.Longitude >= 0 ? "E" : "W")}")
                                                    </a>
                                                </span>
                                            }
                                            @if (!string.IsNullOrEmpty(s.Firmware))
                                            {
                                                <span class="mh-sc-lbl">FW</span>
                                                <span>@s.Firmware</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(s.LastMessage))
                                        {
                                            <div class="mh-sc-msg">@Truncate(s.LastMessage, 60)</div>
                                        }
                                        <div class="mh-sc-actions">
                                            <button class="mh-sc-btn mh-sc-btn-chat"
                                                    @onclick="() => OpenChat(s.Callsign)"
                                                    @onclick:stopPropagation="true">
                                                💬 @Loc.T("Chat öffnen", "Open Chat", "Apri chat", "Abrir chat")
                                            </button>
                                            <a class="mh-sc-btn mh-sc-btn-aprs"
                                               href="https://aprs.fi/#!call=a/@(Uri.EscapeDataString(s.Callsign))"
                                               target="_blank" rel="noopener"
                                               @onclick:stopPropagation="true">
                                                🔗 aprs.fi
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            @if (SettingsOptions.Value.Qrz.Enabled)
                            {
                                var qrzInfo = _qrzData.GetValueOrDefault(s.Callsign);
                                <td class="mh-qrz">
                                    @if (qrzInfo is not null)
                                    {
                                        @if (!string.IsNullOrEmpty(qrzInfo.FirstName))
                                        {
                                            <span class="mh-qrz-name">@qrzInfo.FirstName</span>
                                        }
                                        @if (!string.IsNullOrEmpty(qrzInfo.Location))
                                        {
                                            <span class="mh-qrz-loc">@qrzInfo.Location</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="mh-no-pos">–</span>
                                    }
                                </td>
                            }
                            <td class="mh-time">
                                <span class="mh-date">@LT(s.LastHeard).ToString("dd.MM.yy")</span>
                                <span class="mh-hour">@LT(s.LastHeard).ToString("HH:mm:ss")</span>
                            </td>
                            <td class="col-center mh-count-cell">@s.MessageCount</td>
                            <td class="mh-msg">@Truncate(s.LastMessage, 35)</td>
                            <td class="mh-pos">
                                @if (s.Latitude.HasValue && s.Longitude.HasValue)
                                {
                                    <a class="mh-coord-link"
                                       href="@GeoHelper.OsmUrl(s.Latitude.Value, s.Longitude.Value)"
                                          target="_blank"
                                          title="@Loc.T("Auf Karte anzeigen", "Show on map", "Mostra sulla mappa", "Mostrar en el mapa")">
                                        @($"{s.Latitude.Value:F4}°{(s.Latitude >= 0 ? "N" : "S")}")
                                        <br />
                                        @($"{s.Longitude.Value:F4}°{(s.Longitude >= 0 ? "E" : "W")}")
                                    </a>
                                    <span class="mh-locator">@GeoHelper.ToMaidenhead(s.Latitude.Value, s.Longitude.Value)</span>
                                }
                                else
                                {
                                    <span class="mh-no-pos">–</span>
                                }
                            </td>
                            <td class="col-center mh-alt">
                                @(s.Altitude.HasValue ? $"{s.Altitude} m" : "–")
                            </td>
                            <td class="col-center mh-dist @(dist.HasValue ? "dist-known" : "")">
                                @(dist.HasValue ? GeoHelper.FormatDistance(dist.Value) : "–")
                            </td>
                            <td class="col-center mh-batt">
                                @if (s.Battery.HasValue)
                                {
                                    <span class="@BattClass(s.Battery.Value)" title="@Loc.T($"Akku {s.Battery}%", $"Battery {s.Battery}%", $"Batteria {s.Battery}%", $"Bateriía {s.Battery}%")">@s.Battery%</span>
                                }
                                else
                                {
                                    <span class="mh-no-pos">–</span>
                                }
                            </td>
                            <td class="col-center @RssiClass(s.LastRssi)">
                                @(s.LastRssi.HasValue ? $"{s.LastRssi} dBm" : "–")
                            </td>
                            <td class="col-center @RssiClass(s.LastRssi)">
                                @(s.LastSnr.HasValue ? $"{s.LastSnr:F1} dB" : "–")
                            </td>
                            <td class="col-center">
                                @if (s.HopCount == 0 && s.LastSrcType == "lora")
                                {
                                    <span class="mh-hop-direct" title="Direkt LoRa">📡</span>
                                }
                                else if (s.HopCount == 0 && s.LastSrcType == "udp")
                                {
                                    <span class="mh-hop-gateway" title="Gateway (UDP)">🌐</span>
                                }
                                else
                                {
                                    <span class="mh-hop-relay" title="@(s.HopCount) Hop(s): @(s.LastRelayPath ?? string.Empty)">🔁@s.HopCount</span>
                                }
                            </td>
                            <td>
                                <button class="mh-chat-btn"
                                        title="@Loc.T($"Chat mit {s.Callsign} öffnen", $"Open chat with {s.Callsign}", $"Apri chat con {s.Callsign}", $"Abrir chat con {s.Callsign}")">&#x1f4ac;</button>
                                <button class="mh-remove-btn" @onclick="() => RemoveStation(s.Callsign)"
                                        title="@Loc.T($"{s.Callsign} aus Liste entfernen", $"Remove {s.Callsign} from list", $"Rimuovi {s.Callsign} dalla lista", $"Eliminar {s.Callsign} de la lista")">✕</button>
                            </td>
                        </tr>
                    }
                    @if (filteredList.Count == 0 && !string.IsNullOrWhiteSpace(_searchText))
                    {
                        <tr>
                            <td colspan="99" class="mh-no-results">
                                🔍 @Loc.T($"Keine Ergebnisse für \u201e{_searchText}\u201c",
                                          $"No results for \"{_searchText}\"",
                                          $"Nessun risultato per \"{_searchText}\"",
                                          $"Sin resultados para \"{_searchText}\"")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private IReadOnlyList<HeardStation> _stations = [];
    private ConnectionStatus _status = new();
    private string _myCallsign = string.Empty;
    private bool _disposed;
    private string _searchText = string.Empty;
    private IReadOnlyList<HeardStation> _cachedFilteredStations = [];
    private CancellationTokenSource? _searchDebounce;
    private string? _cardCallsign;
    private readonly Dictionary<string, QrzInfo?> _qrzData = new(StringComparer.OrdinalIgnoreCase);

    private IReadOnlyList<HeardStation> FilteredStations =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _stations
            : _stations.Where(MatchesSearch).ToList();

    private void RebuildSearchCache() =>
        _cachedFilteredStations = FilteredStations;

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrEmpty(_searchText))
        {
            _searchDebounce?.Cancel();
            RebuildSearchCache();
            return;
        }
        _searchDebounce?.Cancel();
        _searchDebounce = new CancellationTokenSource();
        var token = _searchDebounce.Token;
        try
        {
            await Task.Delay(250, token);
            RebuildSearchCache();
            StateHasChanged();
        }
        catch (OperationCanceledException) { }
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _searchDebounce?.Cancel();
            RebuildSearchCache();
            StateHasChanged();
        }
    }

    private void ClearSearch()
    {
        _searchDebounce?.Cancel();
        _searchText = string.Empty;
        RebuildSearchCache();
    }

    private bool MatchesSearch(HeardStation s)
    {
        var q = _searchText.Trim();
        if (s.Callsign.Contains(q, StringComparison.OrdinalIgnoreCase))    return true;
        if (s.LastMessage.Contains(q, StringComparison.OrdinalIgnoreCase)) return true;
        if (SettingsOptions.Value.Qrz.Enabled &&
            _qrzData.TryGetValue(s.Callsign, out var qrz) && qrz is not null)
        {
            if (!string.IsNullOrEmpty(qrz.FirstName) &&
                qrz.FirstName.Contains(q, StringComparison.OrdinalIgnoreCase)) return true;
            if (!string.IsNullOrEmpty(qrz.Location) &&
                qrz.Location.Contains(q, StringComparison.OrdinalIgnoreCase))  return true;
        }
        return false;
    }

    private bool HasOwnPos => _status.OwnLatitude.HasValue && _status.OwnLongitude.HasValue;

    protected override void OnInitialized()
    {
        Loc.OnChange += StateHasChanged;
        _myCallsign = SettingsOptions.Value.MyCallsign;
        _status     = UdpService.Status;
        _stations   = ChatService.MhList;
        RebuildSearchCache();
        ChatService.OnChange      += OnChanged;
        UdpService.OnStatusChange += OnStatusChanged;

        // Pre-fill QRZ data synchronously from the persistent in-memory cache so the
        // first render already shows names/locations without a round-trip to OnAfterRenderAsync.
        if (SettingsOptions.Value.Qrz.Enabled)
            foreach (var s in _stations)
                if (QrzService.TryGetCached(s.Callsign, out var info))
                    _qrzData[s.Callsign] = info;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && await LoadQrzDataAsync(_stations))
            StateHasChanged();
    }

    private async void OnChanged()
    {
        if (_disposed) return;
        try
        {
            var newList = ChatService.MhList;
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                _stations = newList;
                RebuildSearchCache();
                StateHasChanged();
            });
            if (await LoadQrzDataAsync(newList) && !_disposed)
                await InvokeAsync(StateHasChanged);
        }
        catch (Exception) { }
    }

    private async void OnStatusChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(() =>
            {
                if (_disposed) return;
                _status = UdpService.Status;
                StateHasChanged();
            });
        }
        catch (Exception) { }
    }

    private async Task<bool> LoadQrzDataAsync(IReadOnlyList<HeardStation> stations)
    {
        if (!SettingsOptions.Value.Qrz.Enabled) return false;
        var changed = false;
        foreach (var s in stations)
        {
            if (_qrzData.ContainsKey(s.Callsign)) continue;
            changed = true;   // any new entry warrants a re-render
            if (QrzService.TryGetCached(s.Callsign, out var cached))
                _qrzData[s.Callsign] = cached;          // sync – already in persistent cache
            else
                _qrzData[s.Callsign] = await QrzService.LookupAsync(s.Callsign);   // API call
        }
        return changed;
    }

    private double? CalcDistance(HeardStation s)
    {
        if (!HasOwnPos || !s.Latitude.HasValue || !s.Longitude.HasValue)
            return null;
        return GeoHelper.CalculateDistanceKm(
            _status.OwnLatitude!.Value, _status.OwnLongitude!.Value,
            s.Latitude.Value, s.Longitude.Value);
    }

    private void OpenChat(string callsign)
    {
        ChatService.OpenTab(callsign.ToUpperInvariant());
        Nav.NavigateTo("/");
    }

    private void ToggleCard(string callsign) =>
        _cardCallsign = _cardCallsign == callsign ? null : callsign;

    private void RemoveStation(string callsign)
    {
        ChatService.RemoveFromMhList(callsign);
    }

    private void ClearList()
    {
        _searchDebounce?.Cancel();
        _searchText = string.Empty;
        ChatService.ClearMhList();
    }

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max] + "…";

    private static string RssiClass(int? rssi) => rssi switch
    {
        > -70 => "rssi-good",
        > -90 => "rssi-fair",
        null  => "",
        _     => "rssi-weak"
    };

    private static string BattClass(int batt) => batt switch
    {
        > 60 => "batt-ok",
        > 30 => "batt-warn",
        _    => "batt-low"
    };

    private static string BuildStationTooltip(HeardStation s, string firstLabel, QrzInfo? qrz = null)
    {
        var parts = new List<string>();
        if (qrz is not null)
        {
            var qrzParts = new List<string>();
            if (!string.IsNullOrEmpty(qrz.FirstName)) qrzParts.Add(qrz.FirstName);
            if (!string.IsNullOrEmpty(qrz.Location))  qrzParts.Add(qrz.Location);
            if (qrzParts.Count > 0) parts.Add(string.Join(", ", qrzParts));
        }
        if (s.HwId.HasValue)                         parts.Add($"HW-ID: {s.HwId}");
        if (s.FirstHeard != default)                 parts.Add($"{firstLabel}: {s.FirstHeard:dd.MM.yy HH:mm}");
        return parts.Count > 0 ? string.Join(" | ", parts) : s.Callsign;
    }

    private DateTime LT(DateTime dt) => dt.AddHours(SettingsOptions.Value.TimeOffsetHours);

    public void Dispose()
    {
        _disposed = true;
        Loc.OnChange      -= StateHasChanged;
        ChatService.OnChange      -= OnChanged;
        UdpService.OnStatusChange -= OnStatusChanged;
    }
}
