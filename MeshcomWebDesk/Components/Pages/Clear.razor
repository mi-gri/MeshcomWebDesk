@page "/clear"
@rendermode InteractiveServer
@inject ChatService ChatService
@inject DataPersistenceService PersistenceService
@inject MeshcomWebDesk.Services.LanguageService Loc
@implements IDisposable

<PageTitle>@Loc.T("Daten löschen", "Clear Data") – MeshCom WebDesk</PageTitle>

<div class="about-page">
    <div class="about-card clear-card">
        <div class="about-icon">🗑️</div>
        <h1 class="about-title">@Loc.T("Daten löschen", "Clear Data")</h1>

        <div class="about-divider"></div>

        @if (_done)
        {
            <p class="clear-success">✅ @Loc.T("Alle Daten wurden gelöscht.", "All data has been deleted.")</p>
            <p class="clear-hint">@Loc.T("Die Datei auf der Disk wurde ebenfalls geleert.", "The file on disk was also cleared.")</p>
        }
        else if (_confirm)
        {
            <p class="clear-warning">
                ⚠️ @Loc.T("Alle Chat-Nachrichten, Monitor-Einträge und die MH-Liste werden", "All chat messages, monitor entries and the MH list will be")
                <strong>@Loc.T("unwiderruflich", "permanently")</strong>
                @Loc.T("gelöscht. Fortfahren?", "deleted. Continue?")
            </p>
            <div class="clear-buttons">
                <button class="btn-danger" @onclick="ExecuteClear">@Loc.T("Ja, alles löschen", "Yes, delete everything")</button>
                <button class="btn-cancel" @onclick="() => _confirm = false">@Loc.T("Abbrechen", "Cancel")</button>
            </div>
        }
        else
        {
            <p class="about-description">
                @Loc.T("Löscht alle gespeicherten Daten:", "Deletes all stored data:")<br />
                @Loc.T("Chat-Tabs & Nachrichten · MH-Liste · Monitor-Feed", "Chat tabs & messages · MH list · monitor feed")
            </p>
            <div class="clear-buttons">
                <button class="btn-danger" @onclick="() => _confirm = true">@Loc.T("Alle Daten löschen …", "Delete all data …")</button>
            </div>
        }
    </div>
</div>

@code {
    private bool _confirm;
    private bool _done;

    private void OnLocChange() => _ = InvokeAsync(StateHasChanged);

    protected override void OnInitialized() => Loc.OnChange += OnLocChange;
    public void Dispose() => Loc.OnChange -= OnLocChange;

    private async Task ExecuteClear()
    {
        ChatService.ClearAllData();
        await PersistenceService.SaveAsync();
        _confirm = false;
        _done    = true;
    }
}
