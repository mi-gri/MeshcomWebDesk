@page "/map"
@rendermode InteractiveServer
@using MeshcomWebDesk.Models
@using MeshcomWebDesk.Services
@using MeshcomWebDesk.Helpers
@using Microsoft.Extensions.Options
@inject ChatService ChatService
@inject MeshcomUdpService UdpService
@inject LanguageService Loc
@inject IOptionsMonitor<MeshcomSettings> SettingsMonitor
@inject IJSRuntime JS
@inject QrzService QrzService
@inject QsoSummaryService QsoSummaryService
@inject ElevationService ElevationService
@inject ILogger<Map> Logger
@implements IDisposable

<PageTitle>🗺️ @Loc.T("Karte", "Map", "Mappa", "Mapa") – MeshCom WebDesk</PageTitle>

<div class="map-page">
    <div class="map-controls-bar">
        <button class="map-ctrl-btn" @onclick='() => JS.InvokeVoidAsync("meshcomMap.fitAll")'>
            📡 @Loc.T("Alle", "All", "Tutti", "Todos")
        </button>
        <button class="map-ctrl-btn" @onclick='() => JS.InvokeVoidAsync("meshcomMap.fitEurope")'>
            🌍 @Loc.T("Europa", "Europe", "Europa", "Europa")
        </button>
        <button class="map-ctrl-btn" @onclick="FitOwnAsync"
                disabled="@(!UdpService.Status.OwnLatitude.HasValue)"
                title="@Loc.T("50 km Radius um eigene Position", "50 km radius around own position", "50 km raggio intorno alla propria posizione", "Radio de 50 km alrededor de la propia posición")">
            📍 50 km
        </button>
        <button class="map-ctrl-btn" @onclick="FitOwn25Async"
                disabled="@(!UdpService.Status.OwnLatitude.HasValue)"
                title="@Loc.T("25 km Radius um eigene Position", "25 km radius around own position", "25 km raggio intorno alla propria posizione", "Radio de 25 km alrededor de la propia posición")">
            📍 25 km
        </button>
        <button class="map-ctrl-btn @(_showRelayLines ? "map-ctrl-active" : "")"
                @onclick="ToggleRelayLines"
                title="@Loc.T("Weiterleitungspfade ein/ausblenden", "Toggle relay paths", "Mostra/nascondi percorsi relay", "Mostrar/ocultar rutas de relé")">
            🔗 @Loc.T("Pfade", "Paths", "Percorsi", "Rutas")
        </button>
        <button class="map-ctrl-btn @(_showCoverage ? "map-ctrl-active" : "")"
                @onclick="ToggleCoverageAsync"
                title="@Loc.T("Reichweiten-Wolke ein/ausblenden", "Toggle coverage cloud", "Mostra/nascondi copertura", "Mostrar/ocultar cobertura")">
            <span>📶</span>
            @Loc.T("Reichweite", "Coverage", "Copertura", "Cobertura")
        </button>
        <span class="map-ctrl-sep"></span>
        <div class="map-search-wrap-ctrl">
            <input class="map-search-input"
                   value="@_searchCallsign"
                   @oninput="OnSearchInput"
                   @onkeyup="OnSearchKeyUp"
                   placeholder="@Loc.T("Rufzeichen...", "Callsign...", "Nominativo...", "Indicativo...")" />
            <button class="map-ctrl-btn" @onclick="SearchCallsignAsync"
                    title="@Loc.T("Rufzeichen suchen", "Search callsign", "Cerca nominativo", "Buscar indicativo")">
                🔍
            </button>
            @if (_showSearchResults && _searchResults.Count > 0)
            {
                <div class="map-search-results">
                    @foreach (var cs in _searchResults)
                    {
                        var c = cs;
                        <div class="map-search-result-item" @onclick="() => SelectSearchResultAsync(c)">
                            @c
                        </div>
                    }
                </div>
            }
        </div>
        @if (_searchNotFound)
        {
            <span class="map-search-notfound">@Loc.T("Nicht gefunden", "Not found", "Non trovato", "No encontrado")</span>
        }
    </div>
    <div class="map-wrapper">
        <div id="meshcom-map" class="map-container"></div>

        @* ===== Floating legend ===== *@
        <div class="map-legend @(_showLegend ? "" : "map-legend-collapsed")">
            <button class="map-legend-toggle" @onclick="() => _showLegend = !_showLegend"
                    title="@Loc.T("Legende ein/ausblenden", "Toggle legend", "Mostra/nascondi legenda", "Mostrar/ocultar leyenda")">
                @(_showLegend ? "▼" : "▲") @Loc.T("Legende", "Legend", "Legenda", "Leyenda")
            </button>
            @if (_showLegend)
            {
                <div class="map-legend-body">
                    <div class="map-legend-section">@Loc.T("Stationen", "Stations", "Stazioni", "Estaciones")</div>
                    <div class="map-legend-row">
                        <span class="leg-dot"></span>
                        <span>@Loc.T("Direkt empfangen", "Directly heard", "Ricezione diretta", "Recepción directa")</span>
                    </div>
                    <div class="map-legend-row">
                        <span class="leg-dot aprs-relay-1"></span>
                        <span>@Loc.T("1 Relay-Hop", "1 relay hop", "1 hop relay", "1 salto relay")</span>
                    </div>
                    <div class="map-legend-row">
                        <span class="leg-dot aprs-relay-2"></span>
                        <span>@Loc.T("2+ Relay-Hops", "2+ relay hops", "2+ hop relay", "2+ saltos relay")</span>
                    </div>
                    <div class="map-legend-row">
                        <span class="leg-dot-own"></span>
                        <span>@Loc.T("Eigene Position", "Own position", "Posizione propria", "Posición propia")</span>
                    </div>
                    @if (_showCoverage)
                    {
                        <div class="map-legend-section">@Loc.T("Reichweite", "Coverage", "Copertura", "Cobertura")</div>
                        <div class="map-legend-row">
                            <div style="display:inline-block;width:28px;height:14px;min-width:28px;border-radius:3px;background:rgba(77,171,247,0.35);border:2px dashed rgba(77,171,247,0.95);flex-shrink:0"></div>
                            <span>📡 @Loc.T("Gemessen (Convex Hull)", "Measured (convex hull)", "Misurata (hull)", "Medida (hull)")</span>
                        </div>
                        <div class="map-legend-row">
                            <div style="display:inline-block;width:28px;height:14px;min-width:28px;border-radius:3px;background:rgba(227,179,65,0.12);border:2px dashed rgba(227,179,65,0.85);flex-shrink:0"></div>
                            <span>📻 @Loc.T("FSPL-Reichweite (theor.)", "FSPL range (theor.)", "Portata FSPL (teor.)", "Alcance FSPL (teór.)")</span>
                        </div>
                    }
                    @if (_showRelayLines)
                    {
                        <div class="map-legend-section">@Loc.T("Relay-Pfade", "Relay paths", "Percorsi relay", "Rutas relay")</div>
                        <div class="map-legend-row">
                            <span class="leg-line leg-line-good"></span>
                            <span>RSSI &gt; −90 dBm</span>
                        </div>
                        <div class="map-legend-row">
                            <span class="leg-line leg-line-ok"></span>
                            <span>RSSI −90 … −105 dBm</span>
                        </div>
                        <div class="map-legend-row">
                            <span class="leg-line leg-line-weak"></span>
                            <span>RSSI &lt; −105 dBm</span>
                        </div>
                        <div class="map-legend-row">
                            <span class="leg-line leg-line-partial"></span>
                            <span>@Loc.T("Unvollst. Pfad", "Partial path", "Percorso parziale", "Ruta parcial")</span>
                        </div>
                        <div class="map-legend-row">
                            <span class="leg-line-weight"></span>
                            <span>@Loc.T("= Häufigkeit", "= frequency", "= frequenza", "= frecuencia")</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (!_hasPositions)
    {
        <div class="map-no-data">
            📡 @Loc.T("Noch keine GPS-Positionen empfangen.", "No GPS positions received yet.",
                       "Nessuna posizione GPS ricevuta.", "Aún no se han recibido posiciones GPS.")
        </div>
    }

    @{
        var withGps = ChatService.MhList.Where(s => s.Latitude.HasValue).ToList();
        var ownStatus = UdpService.Status;
    }
    @if (withGps.Count > 0 || ownStatus.OwnLatitude.HasValue)
    {
        <div class="map-info-bar">
            <span>📡 @withGps.Count @Loc.T("Station(en) auf der Karte", "station(s) on map", "stazione/i sulla mappa", "estación/es en el mapa")</span>
            @if (ownStatus.OwnLatitude.HasValue)
            {
                <span class="map-info-sep"> · </span>
                <span>📍 @SettingsMonitor.CurrentValue.MyCallsign</span>
            }
        </div>
    }
</div>

@code {
    private bool _hasPositions;
    private bool _mapInitialized;
    private bool _disposed;
    private bool _showRelayLines   = true;
    private bool _showLegend       = true;
    private bool _showCoverage;
    private string       _searchCallsign    = "";
    private bool         _searchNotFound;
    private List<string> _searchResults     = [];
    private bool         _showSearchResults;
    private DotNetObjectReference<Map>? _dotNetRef;

    // Debounce: avoid rebuilding markers on every single incoming packet
    private CancellationTokenSource? _markerDebounce;
    private static readonly TimeSpan MarkerDebounceDelay = TimeSpan.FromMilliseconds(400);

    protected override void OnInitialized()
    {
        Loc.OnChange              += StateHasChanged;
        ChatService.OnMhChange    += OnMhDataChanged;
        UdpService.OnStatusChange += OnMhDataChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await InitMapAsync();
        else if (_mapInitialized)
            await UpdateMarkersAsync();
    }

    private async void OnMhDataChanged()
    {
        if (_disposed) return;
        // Cancel any pending debounce and start a new one
        _markerDebounce?.Cancel();
        _markerDebounce = new CancellationTokenSource();
        var token = _markerDebounce.Token;
        try
        {
            await Task.Delay(MarkerDebounceDelay, token);
            if (token.IsCancellationRequested) return;
            await InvokeAsync(async () =>
            {
                if (_disposed || !_mapInitialized) return;
                await UpdateMarkersAsync();
                StateHasChanged();
            });
        }
        catch (OperationCanceledException) { }
        catch (Exception) { }
    }

    private async Task InitMapAsync()
    {
        for (var attempt = 1; attempt <= 3; attempt++)
        {
            try
            {
                var status = UdpService.Status;
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("meshcomMap.init", "meshcom-map",
                    status.OwnLatitude.HasValue  ? (object)status.OwnLatitude.Value  : null,
                    status.OwnLongitude.HasValue ? (object)status.OwnLongitude.Value : null,
                    _dotNetRef);
                _mapInitialized = true;
                await UpdateMarkersAsync();
                StateHasChanged();
                return;
            }
            catch (Exception ex) when (attempt < 3 && !_disposed)
            {
                Logger.LogWarning("Map init attempt {Attempt} failed: {Message} – retrying in 500 ms", attempt, ex.Message);
                await Task.Delay(500);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Map init failed after 3 attempts");
            }
        }
    }

    private async Task UpdateMarkersAsync()
    {
        var qrzEnabled = SettingsMonitor.CurrentValue.Qrz.Enabled;
        var mhList     = ChatService.MhList;
        var status     = UdpService.Status;

        var stations = mhList
            .Where(s => s.Latitude.HasValue && s.Longitude.HasValue)
            .Select(s =>
            {
                var qrz = qrzEnabled ? QrzService.GetCached(s.Callsign) : null;
                return new
                {
                    callsign  = s.Callsign,
                    lat       = s.Latitude!.Value,
                    lon       = s.Longitude!.Value,
                    alt       = s.Altitude,
                    rssi      = s.LastRssi,
                    text      = s.LastMessage,
                    battery   = s.Battery,
                    hwName    = MeshcomLookup.HwName(s.HwId),
                    firmware  = s.Firmware,
                    qrzName   = qrz?.FirstName,
                    qrzLoc    = qrz?.Location,
                    hopCount  = s.HopCount,
                    relayPath = s.LastRelayPath,
                    locator   = GeoHelper.ToMaidenhead(s.Latitude!.Value, s.Longitude!.Value),
                    temp      = s.Temp1,
                    humidity  = s.Humidity,
                    pressure  = s.Pressure,
                    telemMins = s.LastTelemetryTime.HasValue
                        ? (int)(DateTime.UtcNow - s.LastTelemetryTime.Value).TotalMinutes
                        : (int?)null
                };
            })
            .ToArray();

        // Build relay polylines: only when all hops have known GPS positions
        var posLookup = mhList
            .Where(s => s.Latitude.HasValue && s.Longitude.HasValue)
            .ToDictionary(s => s.Callsign,
                          s => new[] { s.Latitude!.Value, s.Longitude!.Value },
                          StringComparer.OrdinalIgnoreCase);

        double[]? ownPos = status.OwnLatitude.HasValue && status.OwnLongitude.HasValue
            ? [status.OwnLatitude.Value, status.OwnLongitude.Value]
            : null;

        var relayLines = new List<object>();
        if (ownPos is not null)
        {
            foreach (var s in mhList.Where(s => s.HopCount > 0 && !string.IsNullOrEmpty(s.LastRelayPath)))
            {
                var hops    = s.LastRelayPath!.Split(',');
                var coords  = new List<double[]>();
                var skipped = 0;

                foreach (var hop in hops)
                {
                    if (posLookup.TryGetValue(hop.Trim(), out var p))
                        coords.Add(p);
                    else
                        skipped++;
                }

                // Need at least the originating station to draw a meaningful line
                if (coords.Count >= 1)
                {
                    coords.Add(ownPos);
                    relayLines.Add(new
                    {
                        coords  = coords.ToArray(),
                        rssi    = s.LastRssi,
                        label   = string.Join(" ⟶ ", hops),
                        count   = s.RelayPathCount,
                        partial = skipped > 0
                    });
                }
            }

            // Direct connections: ACK or direct chat received without relay, GPS position known
            foreach (var s in mhList.Where(s => s.HopCount == 0 && s.DirectLinkConfirmed && posLookup.ContainsKey(s.Callsign)))
            {
                relayLines.Add(new
                {
                    coords  = new[] { posLookup[s.Callsign], ownPos },
                    rssi    = s.LastRssi,
                    label   = s.Callsign,
                    count   = Math.Max(s.RelayPathCount, 1),
                    partial = false
                });
            }
        }

        _hasPositions = stations.Length > 0 || status.OwnLatitude.HasValue;

        var cfg = SettingsMonitor.CurrentValue;

        // Own station telemetry: prefer values captured directly on send (always available),
        // fall back to MhList lookup in case the node echoes back its own tele packet via UDP.
        var ownMh = mhList.FirstOrDefault(s =>
            string.Equals(s.Callsign, cfg.MyCallsign, StringComparison.OrdinalIgnoreCase));

        var ownTemp      = status.OwnTemp      ?? ownMh?.Temp1;
        var ownHumidity  = status.OwnHumidity  ?? ownMh?.Humidity;
        var ownPressure  = status.OwnPressure  ?? ownMh?.Pressure;
        var ownTelemTime = status.OwnTelemetrySentTime ?? ownMh?.LastTelemetryTime;

        var ownInfo = new
        {
            alt        = status.OwnAltitude,
            posSource  = status.OwnPositionSource,
            rssi       = status.LastRssi,
            snr        = status.LastSnr,
            rxCount    = status.RxCount,
            txCount    = status.TxCount,
            beacon     = status.BeaconActive,
            beaconNext = status.BeaconNextSend.HasValue
                ? status.BeaconNextSend.Value.ToString("HH:mm") : null,
            deviceIp   = cfg.DeviceIp,
            devicePort = cfg.DevicePort,
            temp       = ownTemp,
            humidity   = ownHumidity,
            pressure   = ownPressure,
            telemMins  = ownTelemTime.HasValue
                ? (int)(DateTime.UtcNow - ownTelemTime.Value).TotalMinutes
                : (int?)null
        };

        await JS.InvokeVoidAsync("meshcomMap.updateMarkers",
            stations,
            cfg.MyCallsign,
            status.OwnLatitude,
            status.OwnLongitude,
            relayLines,
            _showRelayLines,
            ownInfo);

        // Wenn Coverage aktiv ist, nach jedem Marker-Update neu berechnen
        if (_showCoverage)
        {
            if (status.OwnLatitude.HasValue && status.OwnLongitude.HasValue)
            {
                var covPoints = mhList
                    .Where(s => s.Latitude.HasValue && s.Longitude.HasValue
                        && s.HopCount == 0
                        && GeoHelper.CalculateDistanceKm(
                            status.OwnLatitude.Value, status.OwnLongitude.Value,
                            s.Latitude!.Value, s.Longitude!.Value) <= 500)
                    .Select(s => new[] { s.Latitude!.Value, s.Longitude!.Value })
                    .ToArray();
                await JS.InvokeVoidAsync("meshcomMap.setCoverage",
                    covPoints,
                    null,
                    status.OwnLatitude.Value,
                    status.OwnLongitude.Value);

                var cfg2          = SettingsMonitor.CurrentValue;
                var cableLossPerM2 = cfg2.CableType == "custom"
                    ? cfg2.CustomCableLossDbPer10m / 10.0
                    : CableLossPerM(cfg2.CableType);
                var cableLoss2    = cableLossPerM2 * cfg2.CableLengthM;
                var eirp2         = cfg2.TxPowerDbm - cableLoss2 + cfg2.AntennaGainDbi;
                await JS.InvokeVoidAsync("meshcomMap.setFsplCircle",
                    status.OwnLatitude.Value,
                    status.OwnLongitude.Value,
                    eirp2,
                    cfg2.FrequencyMhz,
                    cfg2.AntennaHeightM,
                    -120,
                    cfg2.SystemMarginDb);
            }
            else
            {
                await JS.InvokeVoidAsync("meshcomMap.setCoverage", null, null, null, null);
                await JS.InvokeVoidAsync("meshcomMap.removeFsplCircle");
                _showCoverage = false;
            }
        }
    }

    private async Task ToggleRelayLines()
    {
        _showRelayLines = !_showRelayLines;
        if (_mapInitialized)
            await UpdateMarkersAsync();
    }

    private static string RssiCss(int rssi) =>
        rssi > -90 ? "rssi-good" : rssi > -105 ? "rssi-ok" : "rssi-weak";

    private async Task FitOwnAsync()
    {
        try
        {
            var status = UdpService.Status;
            if (status.OwnLatitude.HasValue && status.OwnLongitude.HasValue)
                await JS.InvokeVoidAsync("meshcomMap.fitOwn",
                    status.OwnLatitude.Value, status.OwnLongitude.Value, 50);
        }
        catch (Exception) { }
    }

    private async Task FitOwn25Async()
    {
        try
        {
            var status = UdpService.Status;
            if (status.OwnLatitude.HasValue && status.OwnLongitude.HasValue)
                await JS.InvokeVoidAsync("meshcomMap.fitOwn",
                    status.OwnLatitude.Value, status.OwnLongitude.Value, 25);
        }
        catch (Exception) { }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchCallsign    = e.Value?.ToString() ?? "";
        _searchNotFound    = false;
        _showSearchResults = false;
        _searchResults     = [];
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SearchCallsignAsync();
        else if (e.Key == "Escape")
            CloseSearchResults();
    }

    private void CloseSearchResults()
    {
        _showSearchResults = false;
        _searchResults     = [];
        _searchNotFound    = false;
    }

    private async Task SearchCallsignAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchCallsign)) return;
        try
        {
            var results = await JS.InvokeAsync<string[]>("meshcomMap.findCallsigns", _searchCallsign.Trim());
            if (results.Length == 0)
            {
                _searchNotFound    = true;
                _showSearchResults = false;
                _searchResults     = [];
            }
            else if (results.Length == 1)
            {
                await JS.InvokeVoidAsync("meshcomMap.jumpToCallsign", results[0]);
                _searchCallsign = results[0];
                CloseSearchResults();
            }
            else
            {
                _searchResults     = [.. results];
                _showSearchResults = true;
                _searchNotFound    = false;
            }
        }
        catch (Exception) { }
    }

    private async Task SelectSearchResultAsync(string callsign)
    {
        try { await JS.InvokeVoidAsync("meshcomMap.jumpToCallsign", callsign); }
        catch (Exception) { }
        _searchCallsign = callsign;
        CloseSearchResults();
    }

    public void Dispose()
    {
        _disposed = true;
        _markerDebounce?.Cancel();
        _dotNetRef?.Dispose();
        Loc.OnChange              -= StateHasChanged;
        ChatService.OnMhChange    -= OnMhDataChanged;
        UdpService.OnStatusChange -= OnMhDataChanged;
    }

    [JSInvokable]
    public async Task OnAiPopupRequestAsync(string callsign)
    {
        try
        {
            var mhList     = ChatService.MhList;
            var myCallsign = SettingsMonitor.CurrentValue.MyCallsign;
            var station    = mhList.FirstOrDefault(s =>
                s.Callsign.Equals(callsign, StringComparison.OrdinalIgnoreCase));

            // Build a station context prompt for the AI
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"Gib eine kurze Stationsbeschreibung für {callsign} anhand der folgenden Daten.");
            sb.AppendLine("Antworte kompakt in 2-4 Sätzen. Sprache: Deutsch.");
            sb.AppendLine();
            if (station != null)
            {
                sb.AppendLine($"Rufzeichen: {station.Callsign}");
                if (station.Firmware   != null) sb.AppendLine($"Firmware: {station.Firmware}");
                if (station.HwId       != null) sb.AppendLine($"Hardware: {MeshcomLookup.HwName(station.HwId)}");
                if (station.LastRssi   != null) sb.AppendLine($"RSSI: {station.LastRssi} dBm");
                if (station.LastSnr    != null) sb.AppendLine($"SNR: {station.LastSnr:F1} dB");
                if (station.Battery    != null) sb.AppendLine($"Akku: {station.Battery}%");
                if (station.Latitude.HasValue && station.Longitude.HasValue)
                {
                    sb.AppendLine($"Position: {station.Latitude:F4}°N {station.Longitude:F4}°E");
                    sb.AppendLine($"Maidenhead: {GeoHelper.ToMaidenhead(station.Latitude.Value, station.Longitude.Value)}");
                }
                if (station.HopCount > 0)
                    sb.AppendLine($"Relay-Hops: {station.HopCount} via {station.LastRelayPath}");
                sb.AppendLine($"Nachrichten empfangen: {station.MessageCount}");
                sb.AppendLine($"Zuletzt gehört: {station.LastHeard:dd.MM.yyyy HH:mm}");
                if (!string.IsNullOrWhiteSpace(station.LastMessage))
                    sb.AppendLine($"Letzte Nachricht: {station.LastMessage}");
            }

            var qrz = QrzService.GetCached(callsign);
            if (qrz != null)
            {
                if (qrz.FirstName != null) sb.AppendLine($"Name (QRZ): {qrz.FirstName}");
                if (qrz.Location  != null) sb.AppendLine($"QTH (QRZ): {qrz.Location}");
            }

            var result = await QsoSummaryService.SearchAsync(
                callsign, myCallsign, sb.ToString(), mhList);

            var html = result is not null
                ? System.Net.WebUtility.HtmlEncode(result).Replace("\n", "<br>")
                : "<span style='color:#f85149'>KI nicht verfügbar (API-Key prüfen)</span>";

            await JS.InvokeVoidAsync("meshcomMap.updatePopupAiContent", callsign, html);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Map: OnAiPopupRequestAsync failed for {Callsign}", callsign);
            await JS.InvokeVoidAsync("meshcomMap.updatePopupAiContent", callsign,
                "<span style='color:#f85149'>Error: " +
                System.Net.WebUtility.HtmlEncode(ex.Message) + "</span>");
        }
    }

    private async Task ToggleCoverageAsync()
    {
        _showCoverage = !_showCoverage;
        if (!_mapInitialized) return;

        if (!_showCoverage)
        {
            await JS.InvokeVoidAsync("meshcomMap.setCoverage", null, null, null, null);
            await JS.InvokeVoidAsync("meshcomMap.removeFsplCircle");
            return;
        }

        var status = UdpService.Status;
        if (!status.OwnLatitude.HasValue || !status.OwnLongitude.HasValue)
        {
            await JS.InvokeVoidAsync("meshcomMap.setCoverage", null, null, null, null);
            await JS.InvokeVoidAsync("meshcomMap.removeFsplCircle");
            _showCoverage = false;
            return;
        }

        // Reichweiten-Hull: nur direkt gehörte Stationen (HopCount == 0), max. 500 km
        var measuredPoints = ChatService.MhList
            .Where(s => s.Latitude.HasValue && s.Longitude.HasValue
                && s.HopCount == 0
                && GeoHelper.CalculateDistanceKm(
                    status.OwnLatitude.Value, status.OwnLongitude.Value,
                    s.Latitude!.Value, s.Longitude!.Value) <= 500)
            .Select(s => new[] { s.Latitude!.Value, s.Longitude!.Value })
            .ToArray();

        await JS.InvokeVoidAsync("meshcomMap.setCoverage",
            measuredPoints,
            null,
            status.OwnLatitude.Value,
            status.OwnLongitude.Value);

        // FSPL-Kreis aus Station-Einstellungen
        var cfg    = SettingsMonitor.CurrentValue;
        var cableLossPerM = cfg.CableType == "custom"
            ? cfg.CustomCableLossDbPer10m / 10.0
            : CableLossPerM(cfg.CableType);
        var cableLoss     = cableLossPerM * cfg.CableLengthM;
        var eirp          = cfg.TxPowerDbm - cableLoss + cfg.AntennaGainDbi;
        await JS.InvokeVoidAsync("meshcomMap.setFsplCircle",
            status.OwnLatitude.Value,
            status.OwnLongitude.Value,
            eirp,
            cfg.FrequencyMhz,
            cfg.AntennaHeightM,
            -120,
            cfg.SystemMarginDb);
    }

    private static double CableLossPerM(string cableType) => cableType switch
    {
        "rg174"    => 5.00 / 10.0,
        "rg58"     => 2.50 / 10.0,
        "rg8x"     => 3.00 / 10.0,
        "rg8"      => 1.80 / 10.0,
        "rg213"    => 1.20 / 10.0,
        "h155"     => 0.80 / 10.0,
        "lmr200"   => 1.00 / 10.0,
        "lmr240"   => 0.75 / 10.0,
        "aircell7" => 0.60 / 10.0,
        "lmr400"   => 0.40 / 10.0,
        "cfd400"   => 0.45 / 10.0,
        "ecoflex10"=> 0.55 / 10.0,
        "ecoflex15"=> 0.37 / 10.0,
        "h2000flex"=> 0.33 / 10.0,
        "lmr600"   => 0.25 / 10.0,
        _          => 0.0,
    };
}
