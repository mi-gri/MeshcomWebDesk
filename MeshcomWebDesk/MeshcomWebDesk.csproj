<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>MeshcomWebDesk</AssemblyName>
    <RootNamespace>MeshcomWebDesk</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
    <AssemblyVersion>1.12.2.0</AssemblyVersion>
    <FileVersion>1.12.2.0</FileVersion>
    <InformationalVersion>1.12.2</InformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.0" />
    <PackageReference Include="MQTTnet" Version="4.3.7.1207" />
    <PackageReference Include="MySqlConnector" Version="2.5.0" />
    <PackageReference Include="Serilog.AspNetCore" Version="10.0.0" />
    <PackageReference Include="System.IO.Ports" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <!-- Embeds the build timestamp into the assembly at compile time.
         Readable via AssemblyMetadataAttribute at runtime, works in single-file deployments. -->
    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>BuildDate</_Parameter1>
      <_Parameter2>$([System.DateTime]::UtcNow.ToString("yyyy-MM-dd HH:mm")) UTC</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <!-- Runtime-generated files must NOT be copied to the output directory.
         appsettings.override.json is written by SettingsService at runtime and must
         never be overwritten by a build. -->
    <None Update="data\appsettings.override.json">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
    <None Update="data\**\*">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="MeshcomWebDesk\Components\Pages\" />
  </ItemGroup>

  <ItemGroup>
    <None Include=".github\workflows\docker-publish.yml" />
  </ItemGroup>

</Project>




